---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;

const featureNotes = [
  {
    title: "显示器和桌面",
    titleEn: "Display and desktop",
    body: "亮度、分辨率、夜览和菜单栏空间管理集中处理。",
    bodyEn: "Brightness, resolution, Night Shift, and menu bar controls stay close.",
  },
  {
    title: "清理和维护",
    titleEn: "Cleanup and maintenance",
    body: "缓存清理、图标设置和常用维护都有清楚边界。",
    bodyEn: "Cleanup, icon settings, and maintenance tasks keep clear boundaries.",
  },
  {
    title: "插件化扩展",
    titleEn: "Plugin extension",
    body: "插件排序、可见性、分类和设置页由宿主统一管理。",
    bodyEn: "Plugin order, visibility, categories, and settings are managed in one place.",
  },
] as const;

const settingsShots = [
  {
    slot: "general",
    label: "通用设置页",
    variants: [
      { lang: "zh", theme: "light", src: "/assets/screenshots/settings-general-zh-light.png" },
      { lang: "zh", theme: "dark", src: "/assets/screenshots/settings-general-zh-dark.png" },
      { lang: "en", theme: "light", src: "/assets/screenshots/settings-general-en-light.png" },
      { lang: "en", theme: "dark", src: "/assets/screenshots/settings-general-en-dark.png" },
    ],
  },
  {
    slot: "plugins",
    label: "插件设置页",
    variants: [
      { lang: "zh", theme: "light", src: "/assets/screenshots/settings-plugins-zh-light.png" },
      { lang: "zh", theme: "dark", src: "/assets/screenshots/settings-plugins-zh-dark.png" },
      { lang: "en", theme: "light", src: "/assets/screenshots/settings-plugins-en-light.png" },
      { lang: "en", theme: "dark", src: "/assets/screenshots/settings-plugins-en-dark.png" },
    ],
  },
] as const;
---

<section class="showcase" id="features" aria-labelledby="features-title">
  <div class="section-heading">
    <h2 id="features-title">
      <span data-i18n-zh>系统工具，统一入口。</span>
      <span data-i18n-en>System utilities, one entry point.</span>
    </h2>
    <p>
      <span data-i18n-zh>菜单栏快速执行，组件面板持续查看，设置页管理权限、快捷键和插件。</span>
      <span data-i18n-en>Run actions from the menu bar, monitor state in components, and manage permissions, shortcuts, and plugins in settings.</span>
    </p>
  </div>

  <div class="feature-overview">
    <div class="feature-notes" aria-label="核心能力">
      {featureNotes.map((item) => (
        <article>
          <h3>
            <span data-i18n-zh>{item.title}</span>
            <span data-i18n-en>{item.titleEn}</span>
          </h3>
          <p>
            <span data-i18n-zh>{item.body}</span>
            <span data-i18n-en>{item.bodyEn}</span>
          </p>
        </article>
      ))}
    </div>

    <div class="settings-showcase" aria-hidden="true">
      <div class="settings-stage">
        {settingsShots.map((shot) => (
          <figure class={`settings-shot settings-shot-${shot.slot}`}>
            {shot.variants.map((variant) => (
              <img
                class="settings-shot-variant"
                src={withBase(variant.src)}
                width="2080"
                height="1608"
                alt=""
                loading="lazy"
                decoding="async"
                data-settings-lang={variant.lang}
                data-settings-theme={variant.theme}
                data-settings-label={`${variant.lang}-${variant.theme}-${shot.label}`}
              />
            ))}
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>

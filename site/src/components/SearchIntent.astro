---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;

const featureGroups = [
  {
    title: "菜单栏和桌面",
    titleEn: "Menu bar and desktop",
    items: [
      "Hide Menu Bar Icons",
      "Auto Hide Menu Bar",
      "Auto Hide Dock",
      "Stage Manager",
      "Hide Notch",
      "Launchpad",
    ],
  },
  {
    title: "显示器和系统开关",
    titleEn: "Display and system toggles",
    items: [
      "Display Brightness",
      "DDC/CI",
      "Display Resolution",
      "True Tone",
      "Night Shift",
      "Prevent Sleep",
    ],
  },
  {
    title: "维护和状态",
    titleEn: "Maintenance and status",
    items: [
      "Disk Cleanup",
      "Xcode Cleanup",
      "System Status",
      "Device Battery",
      "Fan Control",
      "Battery Charge Limit",
    ],
  },
] as const;
---

<section class="search-intent" aria-labelledby="search-intent-title">
  <div class="section-heading">
    <h2 id="search-intent-title">
      <span data-i18n-zh>寻找 macOS 菜单栏工具时，MacTools 覆盖更多系统场景。</span>
      <span data-i18n-en>When you search for macOS menu bar tools, MacTools covers more system tasks.</span>
    </h2>
    <p>
      <span data-i18n-zh>MacTools 更偏向免费开源、原生 SwiftUI + AppKit、插件化和可审计的系统工具集合，覆盖菜单栏整理、系统开关、显示器控制、清理维护和状态监控。</span>
      <span data-i18n-en>MacTools focuses on a free, open-source, native SwiftUI + AppKit, plugin-based system toolbox for menu bar organization, system toggles, display controls, cleanup, maintenance, and status monitoring.</span>
    </p>
  </div>

  <div class="intent-grid">
    <article class="intent-copy">
      <h3>
        <span data-i18n-zh>不是单一开关面板，也不只是隐藏菜单栏图标。</span>
        <span data-i18n-en>More than a toggle panel, more than menu bar icon hiding.</span>
      </h3>
      <p>
        <span data-i18n-zh>MacTools 把菜单栏整理、显示器亮度、分辨率切换、DDC/CI 外接屏控制、夜览、深色模式、休眠控制、磁盘清理、Xcode 清理、电池保护、风扇控制和系统状态放在同一个轻量入口里。</span>
        <span data-i18n-en>MacTools brings menu bar organization, display brightness, resolution switching, DDC/CI external monitor control, Night Shift, Dark Mode, sleep control, disk cleanup, Xcode cleanup, battery health, fan control, and system status into one lightweight entry point.</span>
      </p>
      <a href={withBase("/plugins")}>
        <span data-i18n-zh>查看插件目录</span>
        <span data-i18n-en>View plugin catalog</span>
      </a>
    </article>

    <div class="intent-keywords" aria-label="MacTools 功能关键词">
      {featureGroups.map((group) => (
        <article>
          <h3>
            <span data-i18n-zh>{group.title}</span>
            <span data-i18n-en>{group.titleEn}</span>
          </h3>
          <div>
            {group.items.map((item) => (
              <span>{item}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

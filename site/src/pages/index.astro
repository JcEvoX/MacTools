---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteNav from "@/components/SiteNav.astro";
import HomeHero from "@/components/HomeHero.astro";
import FeatureShowcase from "@/components/FeatureShowcase.astro";
import SearchIntent from "@/components/SearchIntent.astro";
import SiteFooter from "@/components/SiteFooter.astro";

const pageTitle = "MacTools | 免费开源的原生 macOS 菜单栏工具集";
const pageDescription = "MacTools 是免费开源的原生 macOS 菜单栏工具集，集中管理显示器、清理、休眠、菜单栏图标、启动台、系统状态、电池、风扇和插件市场。";
const homeKeywords = [
  "MacTools",
  "macOS menu bar tools",
  "Mac menu bar app",
  "native macOS utility",
  "open source macOS app",
  "free macOS utilities",
  "One Switch alternative",
  "AnySwitch alternative",
  "OnlySwitch alternative",
  "Bartender alternative",
  "Hidden Bar alternative",
  "Ice alternative",
  "Thaw alternative",
  "macOS menu bar icon manager",
  "Hide Menu Bar Icons",
  "Display Brightness",
  "DDC/CI",
  "Display Resolution",
  "Night Shift",
  "True Tone",
  "Prevent Sleep",
  "Disk Cleanup",
  "Xcode Cleanup",
  "Launchpad replacement",
  "System Status",
  "Device Battery",
  "Fan Control",
  "Battery Charge Limit",
];
const siteURL = Astro.site?.href ?? "https://mactools.ggbond.app/";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "MacTools",
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "macOS 14.0 or later",
    url: siteURL,
    downloadUrl: "https://github.com/ggbond268/MacTools/releases/latest/download/MacTools.dmg",
    installUrl: "https://github.com/ggbond268/MacTools/releases",
    codeRepository: "https://github.com/ggbond268/MacTools",
    license: "https://www.apache.org/licenses/LICENSE-2.0",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
    },
    description: pageDescription,
    featureList: [
      "Display brightness and resolution controls",
      "Menu bar icon hiding and desktop controls",
      "Disk cleanup and Xcode cleanup",
      "System status, device battery, fan control, and battery charge limit",
      "Plugin catalog and configurable shortcuts",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "MacTools",
    url: siteURL,
    inLanguage: ["zh-CN", "en"],
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={homeKeywords}
  image="/assets/screenshots/readme-hero-en-dark.png"
  structuredData={structuredData}
  page="home"
>
  <SiteNav active="home" />
  <main>
    <HomeHero />
    <FeatureShowcase />
    <SearchIntent />
  </main>
  <SiteFooter />
  <script src="../scripts/site-controls.ts"></script>
</BaseLayout>

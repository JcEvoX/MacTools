---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  keywords?: string[];
  lang?: "zh" | "en";
  page?: "home" | "plugins" | "about";
  image?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const {
  title = "MacTools",
  description = "MacTools 是一组原生 macOS 菜单栏工具，把高频系统操作收进一个轻量、可扩展的入口。",
  keywords = [],
  lang = "zh",
  page = "home",
  image = "/assets/logo-mactools-rounded.png",
  structuredData = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const previewImage = new URL(image, Astro.site);
const locale = lang === "zh" ? "zh_CN" : "en_US";
const keywordContent = keywords.length > 0 ? [...new Set(keywords)].join(", ") : undefined;
const structuredDataItems = Array.isArray(structuredData) ? structuredData : [structuredData];
---

<!doctype html>
<html lang={lang === "zh" ? "zh-CN" : "en"} data-theme="light" data-lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {keywordContent ? <meta name="keywords" content={keywordContent} /> : null}
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="application-name" content="MacTools" />
    <meta name="apple-mobile-web-app-title" content="MacTools" />
    <meta name="theme-color" content="#f5f5f7" />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content="MacTools" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={previewImage} />
    <meta property="og:locale" content={locale} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={previewImage} />
    <title>{title}</title>
    {structuredDataItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <script is:inline>
      (() => {
        const root = document.documentElement;

        try {
          const storedTheme = localStorage.getItem("mactools-theme");
          const storedLang = localStorage.getItem("mactools-lang");

          if (storedTheme === "dark" || storedTheme === "light") {
            root.dataset.theme = storedTheme;
          } else {
            root.dataset.theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          }

          const applyLanguage = (lang) => {
            root.dataset.lang = lang;
            root.lang = lang === "zh" ? "zh-CN" : "en";
          };

          if (storedLang === "zh" || storedLang === "en") {
            applyLanguage(storedLang);
          } else {
            const browserLanguages = navigator.languages?.length ? navigator.languages : [navigator.language];
            const prefersChinese = browserLanguages.some((language) => language.toLowerCase().startsWith("zh"));
            applyLanguage(prefersChinese ? "zh" : "en");
          }
        } catch {
          root.dataset.theme = root.dataset.theme || "light";
          root.dataset.lang = root.dataset.lang || "zh";
        }
      })();
    </script>
  </head>
  <body data-page={page}>
    <slot />
  </body>
</html>

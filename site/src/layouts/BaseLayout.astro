---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  lang?: "zh" | "en";
  page?: "home" | "plugins" | "about";
};

const {
  title = "MacTools",
  description = "MacTools 是一组原生 macOS 菜单栏工具，把高频系统操作收进一个轻量、可扩展的入口。",
  lang = "zh",
  page = "home",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang === "zh" ? "zh-CN" : "en"} data-theme="light" data-lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f5f7" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body data-page={page}>
    <slot />
  </body>
</html>

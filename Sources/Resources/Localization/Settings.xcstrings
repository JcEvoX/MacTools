    "plugins.installed.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتمكين المكونات الإضافية وإخفائها وسحبها لتغيير ترتيب شريط القوائم الخاص بها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren, verbergen und ziehen Sie Plugins, um ihre Menüleistenreihenfolge zu ändern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable, hide, and drag plugins to change their menu bar order."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilite, oculte y arrastre complementos para cambiar el orden de la barra de menú."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez, masquez et faites glisser les plugins pour modifier l'ordre de leur barre de menus."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プラグインを有効化、非表示にし、ドラッグしてメニュー バーの順序を変更します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "플러그인을 활성화하고 숨기고 드래그하여 메뉴 표시줄 순서를 변경하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative, oculte e arraste plug-ins para alterar a ordem da barra de menus."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включайте, скрывайте и перетаскивайте плагины, чтобы изменить порядок их строк меню."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用、隐藏并拖拽调整插件在菜单栏里的显示顺序。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用、隱藏並拖拽調整外掛在選單列裏的顯示順序。"
          }
        }
      }
    },

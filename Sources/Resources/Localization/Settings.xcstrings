    "plugins.configuration.empty.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظهر المكونات الإضافية هنا بعد أن توفر الأذونات أو الاختصارات أو الإعدادات المخصصة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Plugins werden hier angezeigt, nachdem sie Berechtigungen, Verknüpfungen oder benutzerdefinierte Einstellungen bereitstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plugins appear here after they provide permissions, shortcuts, or custom settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los complementos aparecen aquí después de proporcionar permisos, accesos directos o configuraciones personalizadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les plugins apparaissent ici après avoir fourni des autorisations, des raccourcis ou des paramètres personnalisés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プラグインは、権限、ショートカット、またはカスタム設定を提供した後にここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "플러그인은 권한, 바로가기 또는 사용자 정의 설정을 제공한 후 여기에 표시됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os plug-ins aparecem aqui depois de fornecerem permissões, atalhos ou configurações personalizadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плагины появляются здесь после того, как они предоставляют разрешения, ярлыки или пользовательские настройки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当插件提供权限、快捷键或自定义设置后，会显示在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當外掛提供權限、快速鍵或自定義設定後，會顯示在這裏。"

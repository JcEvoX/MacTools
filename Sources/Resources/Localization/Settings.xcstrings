    "menuBarIcon.sourceDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يدعم الصور وملفات GIF/MP4 خفيفة الوزن والأيقونات المتحركة عبر الإنترنت. تتم إزالة الخلفيات ذات الألوان الصلبة عند الاستيراد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unterstützt Bilder, einfache GIF/MP4-Dateien und animierte Online-Symbole. Einfarbige Hintergründe werden beim Import entfernt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Supports images, lightweight GIF/MP4 files, and online animated icons. Solid-color backgrounds are removed on import."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Admite imágenes, archivos ligeros GIF/MP4 e íconos animados en línea. Los fondos de colores sólidos se eliminan al importar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prend en charge les images, les fichiers légers GIF/MP4 et les icônes animées en ligne. Les arrière-plans de couleur unie sont supprimés lors de l'importation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像、軽量の GIF/MP4 ファイル、オンライン アニメーション アイコンをサポートします。単色の背景はインポート時に削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미지, 가벼운 GIF/MP4 파일 및 온라인 애니메이션 아이콘을 지원합니다. 단색 배경은 가져올 때 제거됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Suporta imagens, arquivos GIF/MP4 leves e ícones animados on-line. Planos de fundo de cores sólidas são removidos na importação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поддерживает изображения, легкие файлы GIF/MP4 и анимированные значки онлайн. Однотонный фон удаляется при импорте."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "支持图片、轻量 GIF/MP4 和在线动态图标；导入时会自动扣除纯色背景。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "支持圖片、輕量 GIF/MP4 和在線動態圖標；導入時會自動扣除純色背景。"
          }
        }
      }
    },
    "menuBarIcon.speedDescription.adaptiveSystemLoad": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ارتفاع CPU، GPU، وتحميل الذاكرة يجعل التشغيل أسرع."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Höhere CPU, GPU und Speicherauslastung beschleunigen die Wiedergabe."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Higher CPU, GPU, and memory load makes playback faster."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una mayor carga de memoria y CPU, GPU hace que la reproducción sea más rápida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des CPU, GPU et une charge mémoire plus élevés accélèrent la lecture."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CPU、GPU、メモリ負荷が高いほど、再生が速くなります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "CPU, GPU 및 메모리 로드가 높을수록 재생 속도가 빨라집니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Maiores CPU, GPU e carga de memória tornam a reprodução mais rápida."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Более высокие CPU, GPU и загрузка памяти ускоряют воспроизведение."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CPU、GPU、内存越高越快。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "CPU、GPU、內存越高越快。"
          }
        }
      }

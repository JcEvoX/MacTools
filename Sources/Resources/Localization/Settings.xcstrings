    "menuBarIcon.importError.animationTooComplex": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحتوي الرسوم المتحركة على عدد كبير جدًا من الإطارات. اختر رسمًا متحركًا قصيرًا وأبسط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Animation hat zu viele Frames. Wählen Sie eine einfachere kurze Animation."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The animation has too many frames. Choose a simpler short animation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La animación tiene demasiados fotogramas. Elija una animación corta más sencilla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'animation comporte trop d'images. Choisissez une courte animation plus simple."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アニメーションのフレームが多すぎます。よりシンプルな短いアニメーションを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "애니메이션에 프레임이 너무 많습니다. 더 간단한 짧은 애니메이션을 선택하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A animação tem muitos quadros. Escolha uma animação curta mais simples."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В анимации слишком много кадров. Выберите более простую короткую анимацию."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "动画帧数过多，请选择更简单的短动画。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "動畫幀數過多，請選擇更簡單的短動畫。"
          }
        }
      }
    },
    "menuBarIcon.importError.animationTooLarge": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ملف الرسوم المتحركة كبير جدًا أو ذو دقة عالية جدًا. اختر ملفًا أبسط حجمه أقل من 5 ميغابايت."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Animationsdatei ist zu groß oder zu hochauflösend. Wählen Sie eine einfachere Datei unter 5 MB."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The animation file is too large or too high-resolution. Choose a simpler file under 5 MB."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo de animación es demasiado grande o tiene una resolución demasiado alta. Elija un archivo más simple de menos de 5 MB."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier d'animation est trop volumineux ou sa résolution est trop élevée. Choisissez un fichier plus simple de moins de 5 Mo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アニメーション ファイルが大きすぎるか、解像度が高すぎます。 5 MB 未満のシンプルなファイルを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "애니메이션 파일이 너무 크거나 해상도가 너무 높습니다. 5MB 미만의 더 간단한 파일을 선택하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivo de animação é muito grande ou de resolução muito alta. Escolha um arquivo mais simples com menos de 5 MB."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Файл анимации слишком велик или имеет слишком высокое разрешение. Выберите файл попроще размером до 5 МБ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "动画文件过大或分辨率过高，请选择 5 MB 以内、画面更简单的文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "動畫檔案過大或分辨率過高，請選擇 5 MB 以內、畫面更簡單的檔案。"
          }
        }
      }
    },

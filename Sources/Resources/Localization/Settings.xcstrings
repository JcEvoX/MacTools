    "menuBarIcon.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتعيين رمز شريط قائمة واحد للمظاهر الفاتحة والداكنة. تتم إزالة الخلفيات ذات الألوان الصلبة عند الاستيراد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie ein Menüleistensymbol für helle und dunkle Darstellungen fest. Einfarbige Hintergründe werden beim Import entfernt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set one menu bar icon for light and dark appearances. Solid-color backgrounds are removed on import."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establezca un ícono de barra de menú para apariencias claras y oscuras. Los fondos de colores sólidos se eliminan al importar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez une icône dans la barre de menus pour les apparences claires et sombres. Les arrière-plans de couleur unie sont supprimés lors de l'importation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "明暗の外観用に 1 つのメニュー バー アイコンを設定します。単色の背景はインポート時に削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "밝은 모양과 어두운 모양에 대해 하나의 메뉴 표시줄 아이콘을 설정합니다. 단색 배경은 가져올 때 제거됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Defina um ícone na barra de menu para aparências claras e escuras. Os planos de fundo de cores sólidas são removidos na importação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите один значок в строке меню для светлого и темного внешнего вида. Однотонные фоны удаляются при импорте."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "统一设置浅色和深色菜单栏图标，导入时会自动扣除纯色背景。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "統一設定淺色和深色選單列圖標，導入時會自動扣除純色背景。"
          }
        }
      }
    },

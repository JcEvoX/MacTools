    "language.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتبع لغة النظام بشكل افتراضي، أو اختر لغة ثابتة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Folgen Sie standardmäßig der Systemsprache oder wählen Sie eine feste Sprache."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow the system language by default, or choose a fixed language."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue el idioma del sistema de forma predeterminada o elige un idioma fijo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez la langue du système par défaut ou choisissez une langue fixe."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトでシステム言語に従うか、固定言語を選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본적으로 시스템 언어를 따르거나 고정 언어를 선택하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Siga o idioma do sistema por padrão ou escolha um idioma fixo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте язык системы по умолчанию или выберите фиксированный язык."

    "language.restartAlert.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يصبح إعداد اللغة ساري المفعول بعد إعادة تشغيل MacTools."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Spracheinstellung wird nach dem Neustart von MacTools wirksam."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The language setting takes effect after MacTools restarts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La configuración del idioma entra en vigor después de que se reinicie MacTools."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le paramètre de langue prend effet après le redémarrage de MacTools."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "言語設定は、MacTools の再起動後に有効になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언어 설정은 MacTools이(가) 다시 시작된 후에 적용됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A configuração de idioma entra em vigor após a reinicialização de MacTools."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройка языка вступит в силу после перезапуска MacTools."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语言设置将在重启 MacTools 后生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "語言設定將在重啟 MacTools 後生效。"
          }
        }
      }
    },

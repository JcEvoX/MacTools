    "menuBarClick.rightClickShortcutNotice": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك استخدام الخيار + النقر بزر الماوس الأيسر لتشغيل إجراء النقر بزر الماوس الأيمن."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können Option + Linksklick verwenden, um die Rechtsklick-Aktion auszulösen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can use Option + left-click to trigger the right-click action."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes usar Opción + clic izquierdo para activar la acción de clic derecho."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez utiliser Option + clic gauche pour déclencher l'action du clic droit."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Option + 左クリックを使用して、右クリック アクションをトリガーできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Option + 왼쪽 클릭을 사용하여 오른쪽 클릭 동작을 실행할 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode usar Opção + clique com o botão esquerdo para acionar a ação do clique com o botão direito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете использовать Option + щелчок левой кнопкой мыши, чтобы вызвать действие щелчка правой кнопкой мыши."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可以使用 Option + 左键触发右键功能。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可以使用 Option + 左鍵觸發右鍵功能。"
          }
        }
      }
    },
    "menuBarClick.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند إيقاف التشغيل، يؤدي النقر بزر الماوس الأيسر إلى فتح لوحة المعلومات ويفتح إجراء النقر بزر الماوس الأيمن لوحة الميزات. عند التشغيل، يتم تبديل الإجراءات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn diese Option deaktiviert ist, öffnet ein Linksklick das Dashboard und ein Rechtsklick öffnet das Funktionsfenster. Wenn diese Option aktiviert ist, werden die Aktionen vertauscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, left-click opens the dashboard and the right-click action opens the feature panel. When on, the actions are swapped."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está desactivado, el clic izquierdo abre el panel y la acción de clic derecho abre el panel de funciones. Cuando está activado, las acciones se intercambian."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est désactivée, un clic gauche ouvre le tableau de bord et l'action d'un clic droit ouvre le panneau de fonctionnalités. Lorsque cette option est activée, les actions sont inversées."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフの場合、左クリックするとダッシュボードが開き、右クリックすると機能パネルが開きます。オンにすると、アクションが入れ替わります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해제된 경우 마우스 왼쪽 버튼을 클릭하면 대시보드가 열리고 마우스 오른쪽 버튼을 클릭하면 기능 패널이 열립니다. 켜져 있으면 작업이 교체됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando desativado, o clique com o botão esquerdo abre o painel e a ação do clique com o botão direito abre o painel de recursos. Quando ativado, as ações são trocadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если параметр отключен, щелчок левой кнопкой мыши открывает панель мониторинга, а щелчок правой кнопкой мыши открывает панель функций. Если включено, действия меняются местами."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭时左键打开仪表盘、右键功能打开功能面板；开启后互换。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉時左鍵打開儀表盤、右鍵功能打開功能面板；開啟後互換。"
          }
        }
      }
    },
    "menuBarClick.help": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التمكين، يؤدي النقر بزر الماوس الأيسر إلى فتح لوحة الميزات ويفتح إجراء النقر بزر الماوس الأيمن لوحة التحكم"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn diese Option aktiviert ist, öffnet ein Linksklick das Funktionsfeld und ein Rechtsklick öffnet das Dashboard"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, left-click opens the feature panel and the right-click action opens the dashboard"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está habilitado, el clic izquierdo abre el panel de funciones y la acción de clic derecho abre el panel"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, un clic gauche ouvre le panneau de fonctionnalités et l'action d'un clic droit ouvre le tableau de bord"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、左クリックで機能パネルが開き、右クリックでダッシュボードが開きます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성화되면 왼쪽 버튼을 클릭하면 기능 패널이 열리고 오른쪽 버튼을 클릭하면 대시보드가 열립니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o clique com o botão esquerdo abre o painel de recursos e a ação do clique com o botão direito abre o painel"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если эта функция включена, щелчок левой кнопкой мыши открывает панель функций, а щелчок правой кнопкой мыши открывает панель мониторинга"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后左键打开功能面板，右键功能打开仪表盘"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後左鍵打開功能面板，右鍵功能打開儀表盤"
          }
        }
      }
    },

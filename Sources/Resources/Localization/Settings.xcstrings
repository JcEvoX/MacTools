    "menuBarIcon.contrast.warningBoth": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد يكون من الصعب رؤية الرمز الحالي في شريطي القائمة الفاتحة والداكنة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das aktuelle Symbol ist möglicherweise sowohl in hellen als auch in dunklen Menüleisten schwer zu erkennen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The current icon may be hard to see in both light and dark menu bars."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es posible que sea difícil ver el icono actual en las barras de menú claras y oscuras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'icône actuelle peut être difficile à voir dans les barres de menu claires et sombres."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のアイコンは、明るいメニュー バーでも暗いメニュー バーでも見にくい場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 아이콘은 밝은 메뉴 표시줄과 어두운 메뉴 표시줄 모두에서 보기 어려울 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O ícone atual pode ser difícil de ver nas barras de menu claras e escuras."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Текущий значок может быть плохо виден как в светлой, так и в темной строке меню."
          }
        },
        "zh-Hans": {

    "menuBarClick.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, left-click opens the dashboard and right-click opens the feature panel. When on, the click behaviors are swapped."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭时左键打开仪表盘、右键打开功能面板；开启后左右键行为互换。"
          }
        }
      }
    },
    "menuBarClick.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, left-click opens the feature panel and right-click opens the dashboard"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后左键打开功能面板，右键打开仪表盘"
          }
        }
      }
    },
    "menuBarClick.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swap Left and Right Click"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "交换左右键点击行为"
          }
        }
      }
    },
    "menuBarClick.toggle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {

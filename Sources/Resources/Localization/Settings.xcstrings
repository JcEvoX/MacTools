    "plugins.installed.filteringReorderHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تعطيل إعادة الترتيب أثناء التصفية. امسح الكلمة الرئيسية أو اختر \"الكل\" لإعادة الترتيب مرة أخرى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Neuordnung ist beim Filtern deaktiviert. Löschen Sie das Schlüsselwort oder wählen Sie „Alle“, um die Reihenfolge erneut festzulegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reordering is disabled while filtering. Clear the keyword or choose “All” to reorder again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La reordenación está deshabilitada durante el filtrado. Borre la palabra clave o elija \"Todos\" para volver a realizar el pedido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La réorganisation est désactivée lors du filtrage. Effacez le mot clé ou choisissez « Tous » pour réorganiser à nouveau."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィルタリング中は並べ替えが無効になります。キーワードをクリアするか、「すべて」を選択して再度並べ替えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "필터링 중에는 재정렬이 비활성화됩니다. 키워드를 지우거나 \"모두\"를 선택하여 다시 순서를 바꾸세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A reordenação está desativada durante a filtragem. Limpe a palavra-chave ou escolha “Todos” para reordenar novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переупорядочение отключено во время фильтрации. Удалите ключевое слово или выберите «Все», чтобы снова изменить порядок."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "筛选中暂时不能拖拽排序，清除关键字或选择「全部」即可重新排序。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "篩選中暫時不能拖拽排序，清除關鍵字或選擇「全部」即可重新排序。"
          }
        }
      }
    },

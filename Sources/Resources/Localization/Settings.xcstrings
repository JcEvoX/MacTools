    "shortcuts.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتكوين الاختصارات العامة للإجراءات الشائعة. تسري التغييرات على الفور، ولا يمكن إزالة العناصر المطلوبة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurieren Sie globale Verknüpfungen für allgemeine Aktionen. Änderungen werden sofort wirksam und erforderliche Elemente können nicht entfernt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure global shortcuts for common actions. Changes take effect immediately, and required items cannot be removed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurar atajos globales para acciones comunes. Los cambios entran en vigor inmediatamente y los elementos requeridos no se pueden eliminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurez des raccourcis globaux pour les actions courantes. Les modifications prennent effet immédiatement et les éléments requis ne peuvent pas être supprimés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一般的なアクションのグローバル ショートカットを構成します。変更はすぐに有効になり、必須アイテムは削除できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일반적인 작업에 대한 전역 바로가기를 구성합니다. 변경 사항은 즉시 적용되며 필수 항목은 제거할 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure atalhos globais para ações comuns. As alterações entram em vigor imediatamente e os itens obrigatórios não podem ser removidos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте глобальные ярлыки для общих действий. Изменения вступают в силу немедленно, а необходимые элементы нельзя удалить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为常用动作配置全局快捷键。编辑后立即生效，必要项不可删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為常用動作配置全局快速鍵。編輯後立即生效，必要項不可刪除。"
          }
        }
      }
    },

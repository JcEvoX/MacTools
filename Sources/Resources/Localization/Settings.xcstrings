{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "about.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A free, open-source collection of macOS menu bar tools.\\nBuilt with SwiftUI."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一款免费、开源的 macOS 菜单栏工具集合。\\n使用 SwiftUI 构建。"
          }
        }
      }
    },
    "about.update.check": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check for Updates"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查更新"
          }
        }
      }
    },
    "about.update.detail.available": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A newer version is available. Choose “Update Now” to start the standard system update flow."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已发现更高版本，点击“立即更新”后会进入系统标准安装流程。"
          }
        }
      }
    },
    "about.update.detail.checking": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetching the latest release information."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在获取最新 Release 信息，请稍候。"
          }
        }
      }
    },
    "about.update.detail.upToDate": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are already on the latest version."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前已是最新版本。"
          }
        }
      }
    },
    "about.update.error.alreadyChecking": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An update check is already running. Try again shortly."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在检查更新，请稍后再试。"
          }
        }
      }
    },
    "about.update.error.diskImageLocation": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the app to Applications before updating. The app is still running from a disk image."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先将应用移到 Applications 再更新。当前应用仍在磁盘镜像中运行。"
          }
        }
      }
    },
    "about.update.error.moveToApplications": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the app to Applications before updating."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先将应用移到 Applications 再更新。"
          }
        }
      }
    },
    "about.update.error.quarantineLocation": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the app to Applications before updating. The app is still running from a translocated system location."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先将应用移到 Applications 再更新。当前应用仍在系统隔离位置中运行。"
          }
        }
      }
    },
    "about.update.error.readOnlyVolume": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the app to Applications before updating. The current volume is read-only."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先将应用移到 Applications 再更新。当前应用所在磁盘是只读的。"
          }
        }
      }
    },
    "about.update.error.servicePreparing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The update service is still preparing. Try again shortly."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更新服务正在准备中，请稍后再试。"
          }
        }
      }
    },
    "about.update.error.unwritableLocationUnknown": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The current install location could not be verified as writable. Move the app to Applications before updating."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法确认当前安装位置是否可写，请将应用移到 Applications 后再更新。"
          }
        }
      }
    },
    "about.update.headline.availableFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New version available: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检测到新版本 %@"
          }
        }
      }
    },
    "about.update.headline.blocked": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update cannot start yet"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂时无法启动更新"
          }
        }

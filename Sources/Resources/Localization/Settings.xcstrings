{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "about.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مجموعة مجانية ومفتوحة المصدر من أدوات شريط قوائم نظام التشغيل MacOS. تم إنشاؤه باستخدام SwiftUI."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine kostenlose Open-Source-Sammlung von macOS-Menüleistentools. Gebaut mit SwiftUI."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A free, open-source collection of macOS menu bar tools. Built with SwiftUI."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una colección gratuita y de código abierto de herramientas de la barra de menú de macOS. Construido con SwiftUI."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une collection gratuite et open source d'outils de barre de menu macOS. Construit avec SwiftUI."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS メニュー バー ツールの無料のオープンソース コレクション。 SwiftUI で構築されました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 메뉴 막대 도구의 무료 오픈 소스 컬렉션입니다. SwiftUI로 제작되었습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma coleção gratuita e de código aberto de ferramentas da barra de menus do macOS. Construído com SwiftUI."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Бесплатная коллекция инструментов строки меню macOS с открытым исходным кодом. Создано с помощью SwiftUI."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一款免费、开源的 macOS 菜单栏工具集合。使用 SwiftUI 构建。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一款免費、開源的 macOS 選單列工具集合。使用 SwiftUI 構建。"
          }
        }
      }
    },
    "about.update.check": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التحقق من وجود تحديثات"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach Updates suchen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check for Updates"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscar actualizaciones"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérifier les mises à jour"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アップデートを確認する"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업데이트 확인"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificar atualizações"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверить наличие обновлений"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查更新"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "檢查更新"
          }
        }
      }
    },
    "about.update.detail.available": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتوفر إصدار أحدث. اختر \"التحديث الآن\" لبدء تدفق تحديث النظام القياسي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine neuere Version ist verfügbar. Wählen Sie „Jetzt aktualisieren“, um den Standard-Systemaktualisierungsablauf zu starten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A newer version is available. Choose “Update Now” to start the standard system update flow."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hay una versión más nueva disponible. Elija \"Actualizar ahora\" para iniciar el flujo de actualización estándar del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une version plus récente est disponible. Choisissez « Mettre à jour maintenant » pour démarrer le flux de mise à jour standard du système."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいバージョンが利用可能です。 「今すぐ更新」を選択して、標準のシステム更新フローを開始します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최신 버전을 사용할 수 있습니다. 표준 시스템 업데이트 흐름을 시작하려면 \"지금 업데이트\"를 선택하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma versão mais recente está disponível. Escolha “Atualizar agora” para iniciar o fluxo padrão de atualização do sistema."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступна более новая версия. Выберите «Обновить сейчас», чтобы начать стандартный процесс обновления системы."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已发现更高版本，点击“立即更新”后会进入系统标准安装流程。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已發現更高版本，點擊“立即更新”後會進入系統標準安裝流程。"
          }
        }
      }
    },
    "about.update.detail.checking": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جلب أحدث معلومات الإصدار."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrufen der neuesten Versionsinformationen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetching the latest release information."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obteniendo la información de la versión más reciente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récupération des informations sur la dernière version."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最新のリリース情報を取得しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최신 릴리스 정보를 가져오는 중입니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscando as informações de lançamento mais recentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Получение информации о последней версии."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在获取最新 Release 信息，请稍候。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在獲取最新 Release 信息，請稍候。"
          }
        }
      }
    },
    "about.update.detail.upToDate": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت تستخدم الإصدار الأحدث بالفعل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie verwenden bereits die neueste Version."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are already on the latest version."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya estás en la última versión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous utilisez déjà la dernière version."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すでに最新バージョンを使用しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미 최신 버전을 사용하고 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você já está usando a versão mais recente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У вас уже установлена последняя версия."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前已是最新版本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前已是最新版本。"
          }
        }
      }
    },
    "about.update.error.alreadyChecking": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هناك عملية فحص للتحديث قيد التشغيل بالفعل. حاول مرة أخرى قريبًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Update-Prüfung läuft bereits. Versuchen Sie es in Kürze noch einmal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An update check is already running. Try again shortly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya se está ejecutando una comprobación de actualización. Inténtalo de nuevo en breve."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une vérification de mise à jour est déjà en cours. Réessayez sous peu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "更新チェックはすでに実行中です。しばらくしてからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업데이트 확인이 이미 실행 중입니다. 잠시 후 다시 시도해 보세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma verificação de atualização já está em execução. Tente novamente em breve."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка обновлений уже запущена. Повторите попытку позже."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在检查更新，请稍后再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在檢查更新，請稍後再試。"
          }
        }
      }
    },
    "about.update.error.diskImageLocation": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل التطبيق إلى التطبيقات قبل التحديث. لا يزال التطبيق قيد التشغيل من صورة قرص."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschieben Sie die App vor der Aktualisierung in die Anwendungen. Die App wird weiterhin von einem Disk-Image ausgeführt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the app to Applications before updating. The app is still running from a disk image."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueva la aplicación a Aplicaciones antes de actualizar. La aplicación todavía se está ejecutando desde una imagen de disco."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez l'application vers Applications avant la mise à jour. L'application s'exécute toujours à partir d'une image disque."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "更新する前に、アプリをアプリケーションに移動してください。アプリはまだディスク イメージから実行されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업데이트하기 전에 앱을 애플리케이션으로 이동하세요. 앱이 여전히 디스크 이미지에서 실행 중입니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova o aplicativo para Aplicativos antes de atualizar. O aplicativo ainda está sendo executado a partir de uma imagem de disco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед обновлением переместите приложение в Приложения. Приложение по-прежнему работает с образа диска."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先将应用移到 Applications 再更新。当前应用仍在磁盘镜像中运行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請先將應用移到 Applications 再更新。當前應用仍在磁盤鏡像中運行。"
          }
        }
      }
    },
    "about.update.error.moveToApplications": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل التطبيق إلى التطبيقات قبل التحديث."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschieben Sie die App vor der Aktualisierung in die Anwendungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the app to Applications before updating."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueva la aplicación a Aplicaciones antes de actualizarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez l'application vers Applications avant la mise à jour."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "更新する前にアプリをアプリケーションに移動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업데이트하기 전에 앱을 애플리케이션으로 이동하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova o aplicativo para Aplicativos antes de atualizar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед обновлением переместите приложение в Приложения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先将应用移到 Applications 再更新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請先將應用移到 Applications 再更新。"
          }
        }
      }
    },
    "about.update.error.quarantineLocation": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل التطبيق إلى التطبيقات قبل التحديث. لا يزال التطبيق قيد التشغيل من موقع النظام المنقول."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschieben Sie die App vor der Aktualisierung in den Bereich „Anwendungen“. Die App wird weiterhin von einem verschobenen Systemspeicherort ausgeführt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the app to Applications before updating. The app is still running from a translocated system location."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueva la aplicación a Aplicaciones antes de actualizar. La aplicación todavía se está ejecutando desde una ubicación del sistema trasladada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez l'application vers Applications avant la mise à jour. L'application est toujours en cours d'exécution à partir d'un emplacement système transféré."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "更新する前に、アプリをアプリケーションに移動してください。アプリは、移動されたシステムの場所から引き続き実行されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업데이트하기 전에 앱을 애플리케이션으로 이동하세요. 앱이 여전히 이동된 시스템 위치에서 실행 중입니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova o aplicativo para Aplicativos antes de atualizar. O aplicativo ainda está em execução em um local de sistema translocado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед обновлением переместите приложение в Приложения. Приложение по-прежнему работает из перемещенной системной папки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先将应用移到 Applications 再更新。当前应用仍在系统隔离位置中运行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請先將應用移到 Applications 再更新。當前應用仍在系統隔離位置中運行。"
          }
        }
      }
    },
    "about.update.error.readOnlyVolume": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل التطبيق إلى التطبيقات قبل التحديث. المجلد الحالي للقراءة فقط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschieben Sie die App vor der Aktualisierung in die Anwendungen. Das aktuelle Volume ist schreibgeschützt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the app to Applications before updating. The current volume is read-only."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueva la aplicación a Aplicaciones antes de actualizar. El volumen actual es de sólo lectura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez l'application vers Applications avant la mise à jour. Le volume actuel est en lecture seule."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "更新する前に、アプリをアプリケーションに移動してください。現在のボリュームは読み取り専用です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업데이트하기 전에 앱을 애플리케이션으로 이동하세요. 현재 볼륨은 읽기 전용입니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova o aplicativo para Aplicativos antes de atualizar. O volume atual é somente leitura."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед обновлением переместите приложение в Приложения. Текущий том доступен только для чтения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先将应用移到 Applications 再更新。当前应用所在磁盘是只读的。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請先將應用移到 Applications 再更新。當前應用所在磁盤是隻讀的。"
          }
        }
      }
    },
    "about.update.error.servicePreparing": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تزال خدمة التحديث قيد الإعداد. حاول مرة أخرى قريبًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Update-Dienst bereitet sich noch vor. Versuchen Sie es in Kürze noch einmal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The update service is still preparing. Try again shortly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servicio de actualización aún se está preparando. Inténtalo de nuevo en breve."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le service de mise à jour est toujours en préparation. Réessayez sous peu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "更新サービスはまだ準備中です。しばらくしてからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업데이트 서비스가 아직 준비 중입니다. 잠시 후 다시 시도해 보세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O serviço de atualização ainda está em preparação. Tente novamente em breve."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Служба обновлений все еще готовится. Повторите попытку позже."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更新服务正在准备中，请稍后再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "更新服務正在準備中，請稍後再試。"
          }
        }
      }
    },
    "about.update.error.unwritableLocationUnknown": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر التحقق من أن موقع التثبيت الحالي قابل للكتابة. انقل التطبيق إلى التطبيقات قبل التحديث."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der aktuelle Installationsort konnte nicht als beschreibbar überprüft werden. Verschieben Sie die App vor dem Aktualisieren in den Bereich „Anwendungen“."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The current install location could not be verified as writable. Move the app to Applications before updating."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo verificar que la ubicación de instalación actual sea escribible. Mueve la aplicación a Aplicaciones antes de actualizarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'emplacement d'installation actuel n'a pas pu être vérifié comme étant accessible en écriture. Déplacez l'application vers Applications avant la mise à jour."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のインストール場所が書き込み可能であることを確認できませんでした。更新する前に、アプリを「アプリケーション」に移動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 설치 위치가 쓰기 가능한지 확인할 수 없습니다. 업데이트하기 전에 앱을 애플리케이션으로 이동하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível verificar o local de instalação atual como gravável. Mova o aplicativo para Aplicativos antes de atualizar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось проверить текущее местоположение установки как доступное для записи. Перед обновлением переместите приложение в Приложения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法确认当前安装位置是否可写，请将应用移到 Applications 后再更新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法確認當前安裝位置是否可寫，請將應用移到 Applications 後再更新。"
          }
        }
      }
    },

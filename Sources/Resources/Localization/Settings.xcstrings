    "launchAtLogin.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start MacTools when you log in and keep it in the menu bar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录系统时自动启动 MacTools 并显示在菜单栏。"
          }
        }
      }
    },
    "launchAtLogin.error.disableFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not disable launch at login. Try again later or remove it manually in System Settings > General > Login Items."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法关闭开机自启动，请稍后重试或前往系统设置 > 通用 > 登录项中手动移除。"
          }
        }
      }
    },
    "launchAtLogin.error.enableFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not enable launch at login. Try again later or check permissions in System Settings > General > Login Items."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法开启开机自启动，请稍后重试或前往系统设置 > 通用 > 登录项中检查权限。"
          }
        }
      }
    },
    "launchAtLogin.help": {
      "extractionState": "manual",

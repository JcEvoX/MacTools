          "stringUnit": {
            "state": "translated",
            "value": "Siga el sistema automáticamente o mantenga una apariencia fija."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez le système automatiquement ou conservez une apparence fixe."
          }
        },

    "launchAtLogin.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابدأ MacTools عند تسجيل الدخول واحتفظ به في شريط القائمة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starten Sie MacTools, wenn Sie sich anmelden, und behalten Sie es in der Menüleiste."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start MacTools when you log in and keep it in the menu bar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicie MacTools cuando inicie sesión y manténgalo en la barra de menú."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Démarrez MacTools lorsque vous vous connectez et conservez-le dans la barre de menu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログイン時に MacTools を起動し、メニュー バーに保持します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인할 때 MacTools을(를) 시작하고 메뉴 표시줄에 유지하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicie MacTools ao fazer login e mantenha-o na barra de menu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запустите MacTools при входе в систему и сохраните его в строке меню."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录系统时自动启动 MacTools 并显示在菜单栏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "登錄系統時自動啟動 MacTools 並顯示在選單列。"
          }
        }
      }
    },
    "launchAtLogin.error.disableFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر تعطيل التشغيل عند تسجيل الدخول. حاول مرة أخرى لاحقًا أو قم بإزالته يدويًا في إعدادات النظام > عام > عناصر تسجيل الدخول."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Start beim Anmelden konnte nicht deaktiviert werden. Versuchen Sie es später noch einmal oder entfernen Sie es manuell unter Systemeinstellungen > Allgemein > Anmeldeelemente."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not disable launch at login. Try again later or remove it manually in System Settings > General > Login Items."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo desactivar el inicio al iniciar sesión. Vuelva a intentarlo más tarde o elimínelo manualmente en Configuración del sistema > General > Elementos de inicio de sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de désactiver le lancement lors de la connexion. Réessayez plus tard ou supprimez-le manuellement dans Paramètres système > Général > Éléments de connexion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログイン時の起動を無効にできませんでした。後でもう一度試すか、[システム設定] > [一般] > [ログイン項目] で手動で削除してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인 시 실행을 비활성화할 수 없습니다. 나중에 다시 시도하거나 시스템 설정 > 일반 > 로그인 항목에서 수동으로 제거하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível desativar a inicialização no login. Tente novamente mais tarde ou remova-o manualmente em Configurações do sistema > Geral > Itens de login."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось отключить запуск при входе в систему. Повторите попытку позже или удалите его вручную в разделе «Настройки системы» > «Основные» > «Элементы входа»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法关闭开机自启动，请稍后重试或前往系统设置 > 通用 > 登录项中手动移除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法關閉開機自啟動，請稍後重試或前往系統設定 > 通用 > 登錄項中手動移除。"
          }
        }
      }
    },
    "launchAtLogin.error.enableFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر تمكين التشغيل عند تسجيل الدخول. حاول مرة أخرى لاحقًا أو تحقق من الأذونات في إعدادات النظام > عام > عناصر تسجيل الدخول."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Start beim Anmelden konnte nicht aktiviert werden. Versuchen Sie es später noch einmal oder überprüfen Sie die Berechtigungen unter Systemeinstellungen > Allgemein > Anmeldeelemente."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not enable launch at login. Try again later or check permissions in System Settings > General > Login Items."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo habilitar el inicio al iniciar sesión. Vuelva a intentarlo más tarde o verifique los permisos en Configuración del sistema > General > Elementos de inicio de sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'activer le lancement lors de la connexion. Réessayez plus tard ou vérifiez les autorisations dans Paramètres système > Général > Éléments de connexion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログイン時の起動を有効にできませんでした。後でもう一度試すか、[システム設定] > [一般] > [ログイン項目] で権限を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인 시 실행을 활성화할 수 없습니다. 나중에 다시 시도하거나 시스템 설정 > 일반 > 로그인 항목에서 권한을 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível ativar a inicialização no login. Tente novamente mais tarde ou verifique as permissões em Configurações do sistema > Geral > Itens de login."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось включить запуск при входе в систему. Повторите попытку позже или проверьте разрешения в разделе «Системные настройки» > «Основные» > «Элементы входа»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法开启开机自启动，请稍后重试或前往系统设置 > 通用 > 登录项中检查权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法開啟開機自啟動，請稍後重試或前往系統設定 > 通用 > 登錄項中檢查權限。"
          }
        }
      }
    },

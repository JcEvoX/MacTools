{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "plugin.autoUpdate.detail.checking": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم فحص المكونات الإضافية المثبتة أولاً عند بدء تشغيل هذا الإصدار لأول مرة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installierte Plugins werden zuerst überprüft, wenn diese Version zum ersten Mal gestartet wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Installed plugins are checked first when this version starts for the first time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los complementos instalados se verifican primero cuando se inicia esta versión por primera vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les plugins installés sont vérifiés en premier lorsque cette version démarre pour la première fois."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このバージョンを初めて起動すると、インストールされているプラグインが最初にチェックされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 버전이 처음 시작되면 설치된 플러그인이 먼저 확인됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os plug-ins instalados são verificados primeiro quando esta versão é iniciada pela primeira vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установленные плагины проверяются в первую очередь при первом запуске этой версии."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新版首次启动时会先检查已安装插件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新版首次啟動時會先檢查已安裝外掛。"
          }
        }
      }
    },
    "plugin.autoUpdate.detail.completedFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تحديث %d المكونات الإضافية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Plugins für %d aktualisiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Updated %d plugins."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Complementos %d actualizados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plugins %d mis à jour."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%d プラグインを更新しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 플러그인이 업데이트되었습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Plugins %d atualizados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновлены плагины %d."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已更新 %d 个插件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已更新 %d 個外掛。"
          }
        }
      }
    },
    "plugin.autoUpdate.detail.failed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك إعادة المحاولة في هذه الصفحة لاحقًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können es später auf dieser Seite noch einmal versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can retry on this page later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes volver a intentarlo en esta página más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pourrez réessayer sur cette page plus tard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "後でこのページで再試行できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "나중에 이 페이지에서 다시 시도할 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode tentar novamente nesta página mais tarde."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете повторить попытку на этой странице позже."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "稍后可在此页面重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "稍後可在此頁面重試。"
          }
        }
      }
    },
    "plugin.autoUpdate.detail.noUpdates": {
      "extractionState": "manual",
      "localizations": {

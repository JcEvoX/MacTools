        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すでに最新です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미 최신 상태입니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Já atualizado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уже обновлено."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已是最新版本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已是最新版本。"
          }
        }
      }
    },
    "plugin.autoUpdate.detail.updatingFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحديث %d المكونات الإضافية المثبتة. سيستمر التحميل بعد التحديث."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktualisierung von %d installierten Plugins. Der Ladevorgang wird nach dem Update fortgesetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Updating %d installed plugins. Loading will continue after the update."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualizando %d complementos instalados. La carga continuará después de la actualización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mise à jour des plugins installés %d. Le chargement continuera après la mise à jour."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インストールされている %d プラグインを更新しています。アップデート後も読み込みは続行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 설치된 플러그인을 업데이트하는 중입니다. 업데이트 후에도 로딩이 계속됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualizando %d plug-ins instalados. O carregamento continuará após a atualização."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновление %d установленных плагинов. Загрузка продолжится после обновления."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在更新 %d 个已安装插件，完成后会继续加载。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在更新 %d 個已安裝外掛，完成後會繼續加載。"
          }
        }
      }
    },

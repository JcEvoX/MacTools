          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O pacote de plugins %@ deve retornar exatamente 1 plugin. Ele retornou %d."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пакет плагинов %@ должен возвращать ровно 1 плагин. Он вернул %d."

    "plugin.detail.restartRequiredAfterRemoval": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تمت إزالته من الواجهة. أعد التشغيل لتحرير الكود المحمل بالكامل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aus der Schnittstelle entfernt. Starten Sie neu, um den geladenen Code vollständig freizugeben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Removed from the interface. Restart to fully release loaded code."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminado de la interfaz. Reinicie para liberar completamente el código cargado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimé de l'interface. Redémarrez pour libérer complètement le code chargé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インターフェースから削除されました。再起動してロードされたコードを完全に解放します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인터페이스에서 제거되었습니다. 로드된 코드를 완전히 해제하려면 다시 시작하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Removido da interface. Reinicie para liberar totalmente o código carregado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удален из интерфейса. Перезапустите, чтобы полностью освободить загруженный код."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已移出界面，重启后彻底释放已加载代码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已移出界面，重啟後徹底釋放已加載代碼。"
          }
        }
      }
    },
    "plugin.detail.restartRequiredAfterUpdate": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم تمكين الإصدار الجديد بعد إعادة التشغيل، وسيتم إصدار التعليمات البرمجية القديمة بالكامل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die neue Version wird nach dem Neustart aktiviert und der alte Code wird vollständig freigegeben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The new version will be enabled after restart, and old code will be fully released."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La nueva versión se habilitará después del reinicio y el código antiguo se liberará por completo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La nouvelle version sera activée après le redémarrage et l'ancien code sera entièrement publié."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいバージョンは再起動後に有効になり、古いコードは完全にリリースされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 버전은 다시 시작한 후 활성화되며 이전 코드는 완전히 릴리스됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A nova versão será habilitada após a reinicialização e o código antigo será totalmente liberado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Новая версия будет активирована после перезапуска, а старый код будет полностью выпущен."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新版本将在重启后启用，旧代码将在重启后彻底释放。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新版本將在重啟後啟用，舊代碼將在重啟後徹底釋放。"
          }
        }
      }
    },

            "state": "translated",
            "value": "MacTools はカレンダー イベントを読み取り、カレンダー コンポーネントにスケジュールを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools은 캘린더 이벤트를 읽어 캘린더 구성요소에 일정을 표시합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools lê eventos da agenda para mostrar sua programação no componente da agenda."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools считывает события календаря, чтобы отобразить ваше расписание в компоненте календаря."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取系统日历事件，用于在右键日历组件中显示当天日程。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讀取系統日曆事件，用於在右鍵日曆組件中顯示當天行程。"
          }
        }
      }
    }
  },
  "version": "1.0"
}

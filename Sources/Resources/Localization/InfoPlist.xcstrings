{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "NSAppleEventsUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools يحتاج إلى التحكم في التقويم عند النقر على تاريخ حتى يتمكن من فتح ذلك اليوم في تطبيق تقويم النظام."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools muss den Kalender steuern, wenn Sie auf ein Datum klicken, damit er an diesem Tag in der Systemkalender-App geöffnet werden kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools needs to control Calendar when you click a date so it can open that day in the system Calendar app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools necesita controlar el Calendario cuando haces clic en una fecha para poder abrir ese día en la aplicación Calendario del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools doit contrôler le calendrier lorsque vous cliquez sur une date afin qu'il puisse s'ouvrir ce jour-là dans l'application Calendrier du système."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools は、日付をクリックしたときにシステムのカレンダー アプリでその日を開くことができるようにカレンダーを制御する必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools은 날짜를 클릭할 때 캘린더를 제어해야 시스템 캘린더 앱에서 해당 날짜를 열 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools precisa controlar o Agenda quando você clica em uma data para que ele possa abrir esse dia no aplicativo Agenda do sistema."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools необходимо управлять Календарем, когда вы нажимаете дату, чтобы он мог открыть этот день в системном приложении «Календарь»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击日历日期时需要控制系统日历应用并定位到对应日期。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊日曆日期時需要控制系統日曆應用並定位到對應日期。"
          }
        }
      }
    },
    "NSBluetoothAlwaysUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools يقرأ مستويات بطارية ملحق Bluetooth لإظهار حالة الماوس ولوحة المفاتيح وسماعات الرأس في مكون بطارية الجهاز."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools liest den Batteriestand des Bluetooth-Zubehörs, um den Maus-, Tastatur- und Headset-Status in der Batteriekomponente des Geräts anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools reads Bluetooth accessory battery levels to show mouse, keyboard, and headset status in the device battery component."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools lee los niveles de batería de los accesorios Bluetooth para mostrar el estado del mouse, el teclado y los auriculares en el componente de batería del dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools lit les niveaux de batterie des accessoires Bluetooth pour afficher l'état de la souris, du clavier et du casque dans le composant de batterie de l'appareil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools は Bluetooth アクセサリのバッテリー レベルを読み取り、デバイスのバッテリー コンポーネントのマウス、キーボード、ヘッドセットのステータスを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools은 Bluetooth 액세서리 배터리 수준을 읽어 장치 배터리 구성 요소에 마우스, 키보드 및 헤드셋 상태를 표시합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools lê os níveis de bateria dos acessórios Bluetooth para mostrar o status do mouse, teclado e fone de ouvido no componente da bateria do dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools считывает уровень заряда батареи аксессуара Bluetooth, чтобы показать состояние мыши, клавиатуры и гарнитуры в компоненте батареи устройства."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取蓝牙外设电量，用于在设备电量组件中显示鼠标、键盘和耳机状态。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讀取藍牙外設電量，用於在設備電量組件中顯示滑鼠、鍵盤和耳機狀態。"
          }
        }
      }
    },
    "NSCalendarsFullAccessUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools بقراءة أحداث التقويم لإظهار الجدول الزمني الخاص بك في مكون التقويم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools liest Kalenderereignisse, um Ihren Zeitplan in der Kalenderkomponente anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools reads calendar events to show your schedule in the calendar component."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools lee eventos del calendario para mostrar su programación en el componente de calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools lit les événements du calendrier pour afficher votre emploi du temps dans le composant Calendrier."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools はカレンダー イベントを読み取り、カレンダー コンポーネントにスケジュールを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools은 캘린더 이벤트를 읽어 캘린더 구성요소에 일정을 표시합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools lê eventos da agenda para mostrar sua programação no componente da agenda."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools считывает события календаря, чтобы отобразить ваше расписание в компоненте календаря."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取系统日历事件，用于在右键日历组件中显示当天日程。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讀取系統日曆事件，用於在右鍵日曆組件中顯示當天行程。"
          }
        }
      }
    },
    "NSCalendarsUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools يقرأ أحداث التقويم لعرض الجدول الزمني الخاص بك في مكون التقويم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools liest Kalenderereignisse, um Ihren Zeitplan in der Kalenderkomponente anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools reads calendar events to show your schedule in the calendar component."
          }
        },
        "es": {

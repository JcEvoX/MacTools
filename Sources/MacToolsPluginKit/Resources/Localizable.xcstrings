{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "shortcutRecorder.defaultPlaceholder": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not set"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未设置"
          }
        }
      }
    },
    "shortcutRecorder.escHint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press Esc to stop recording"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按下 ESC 退出录制"
          }
        }
      }
    },
    "shortcutRecorder.helpFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click to record %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击录制%@"
          }
        }
      }
    },
    "shortcutRecorder.previewPlaceholder": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press a shortcut"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按下录制快捷键"
          }
        }
      }
    },
    "shortcutValidation.duplicateFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This shortcut is already used by \"%@\"."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该快捷键已被“%@”占用。"
          }
        }
      }
    },
    "shortcutValidation.missingModifier": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcut must include at least one modifier key."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快捷键至少需要一个修饰键。"
          }
        }
      }
    },
    "shortcutValidation.modifierOnly": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcut must include a non-modifier key."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快捷键必须包含一个非修饰键。"
          }
        }
      }
    },
    "shortcutValidation.requiredShortcut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcut cannot be empty."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该快捷键不能为空。"
          }
        }
      }
    }
  },
  "version": "1.0"
}

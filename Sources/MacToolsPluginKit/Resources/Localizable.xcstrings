{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "shortcutRecorder.defaultPlaceholder": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير محدد"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht festgelegt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not set"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No establecido"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non défini"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未設定"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정되지 않음"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não definido"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не установлено"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未设置"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未設定"
          }
        }
      }
    },
    "shortcutRecorder.escHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على Esc لإيقاف التسجيل"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken Sie Esc, um die Aufnahme zu stoppen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press Esc to stop recording"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presiona Esc para detener la grabación"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur Échap pour arrêter l'enregistrement"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Esc キーを押して録音を停止します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹화를 중지하려면 Esc를 누르세요"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione Esc para parar a gravação"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите Esc, чтобы остановить запись"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按下 ESC 退出录制"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按下 ESC 退出錄製"
          }
        }
      }
    },
    "shortcutRecorder.helpFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقر للتسجيل %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicken Sie, um %@ aufzuzeichnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click to record %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haga clic para grabar %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez pour enregistrer %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリックして %@ を記録"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@을(를) 녹음하려면 클릭하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique para registrar %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите, чтобы записать %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击录制%@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊錄製%@"
          }
        }
      }
    },
    "shortcutRecorder.previewPlaceholder": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على الاختصار"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken Sie eine Verknüpfung"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press a shortcut"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presiona un atajo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur un raccourci"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットを押します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축키 누르기"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione um atalho"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите ярлык"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按下录制快捷键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按下錄製快速鍵"
          }
        }
      }
    },
    "shortcutValidation.duplicateFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الاختصار مستخدم بالفعل بواسطة \"%@\"."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Verknüpfung wird bereits von „%@“ verwendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This shortcut is already used by \"%@\"."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este acceso directo ya lo utiliza \"%@\"."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce raccourci est déjà utilisé par \"%@\"."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このショートカットは「%@」によってすでに使用されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 단축키는 \"%@\"에서 이미 사용하고 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este atalho já é usado por \"%@\"."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот ярлык уже используется «%@»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该快捷键已被“%@”占用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該快速鍵已被“%@”佔用。"
          }
        }
      }
    },
    "shortcutValidation.missingModifier": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجب أن يتضمن الاختصار مفتاح تعديل واحدًا على الأقل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Verknüpfung muss mindestens eine Zusatztaste enthalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcut must include at least one modifier key."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso directo debe incluir al menos una tecla modificadora."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le raccourci doit inclure au moins une touche de modification."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットには少なくとも 1 つの修飾キーが含まれている必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축키에는 최소한 하나의 수정자 키가 포함되어야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O atalho deve incluir pelo menos uma tecla modificadora."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ярлык должен включать хотя бы одну клавишу-модификатор."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快捷键至少需要一个修饰键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速鍵至少需要一個修飾鍵。"
          }
        }
      }
    },
    "shortcutValidation.modifierOnly": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجب أن يتضمن الاختصار مفتاحًا غير مفتاح التعديل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Tastenkombination muss eine nicht modifizierende Taste enthalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcut must include a non-modifier key."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso directo debe incluir una clave que no sea modificadora."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le raccourci doit inclure une touche non modificatrice."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットには非修飾キーが含まれている必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단축키에는 수정자 키가 아닌 키가 포함되어야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O atalho deve incluir uma tecla não modificadora."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ярлык должен включать в себя не модифицирующую клавишу."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快捷键必须包含一个非修饰键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速鍵必須包含一個非修飾鍵。"
          }
        }
      }
    },
    "shortcutValidation.requiredShortcut": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن أن يكون الاختصار فارغًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verknüpfung darf nicht leer sein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcut cannot be empty."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso directo no puede estar vacío."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le raccourci ne peut pas être vide."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットを空にすることはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "바로가기는 비워둘 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O atalho não pode ficar vazio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ярлык не может быть пустым."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该快捷键不能为空。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該快速鍵不能為空。"
          }
        }
      }
    }
  },
  "version": "1.0"
}

{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "دقة العرض"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anzeigeauflösung"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Display Resolution"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resolución de pantalla"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Résolution d'affichage"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスプレイ解像度"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스플레이 해상도"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Resolução da tela"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешение экрана"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示器分辨率"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "顯示器分辨率"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عرض وتبديل الدقة لكل شاشة عرض."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigen Sie die Auflösung für jede Anzeige an und wechseln Sie sie."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View and switch the resolution for each display."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver y cambiar la resolución de cada pantalla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affichez et changez la résolution de chaque écran."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ディスプレイの解像度を表示および切り替えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 디스플레이의 해상도를 보고 전환합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualize e altere a resolução de cada monitor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просмотр и переключение разрешения для каждого дисплея."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看并切换每个显示器的分辨率"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "查看並切換每個顯示器的分辨率"
          }
        }
      }
    },

    "settings.openWith.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اترك الامتدادات فارغة لتظهر لجميع الملفات. افصل بين الإضافات المتعددة بفواصل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lassen Sie die Erweiterungen leer, damit sie für alle Dateien angezeigt werden. Trennen Sie mehrere Erweiterungen durch Kommas."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave extensions empty to show for all files. Separate multiple extensions with commas."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Deje las extensiones vacías para mostrarlas en todos los archivos. Separe varias extensiones con comas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laissez les extensions vides pour les afficher pour tous les fichiers. Séparez plusieurs extensions par des virgules."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのファイルに対して表示するには、拡張子を空のままにします。複数の拡張子はカンマで区切ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 파일에 대해 표시하려면 확장자를 비워 두세요. 확장자가 여러 개인 경우 쉼표로 구분하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Deixe as extensões vazias para serem exibidas em todos os arquivos. Separe várias extensões com vírgulas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оставьте расширения пустыми, чтобы они отображались для всех файлов. Разделяйте несколько расширений запятыми."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扩展名留空表示对所有文件显示，多个扩展名用逗号分隔。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "擴展名留空表示對所有檔案顯示，多個擴展名用逗號分隔。"
          }
        }
      }
    },

    "permission.finderExtension.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المسار: عناصر وملحقات تسجيل الدخول > Finder الملحقات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pfad: Anmeldeelemente und Erweiterungen > Finder Erweiterungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Path: Login Items & Extensions > Finder Extensions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruta: Elementos y extensiones de inicio de sesión > Finder Extensiones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chemin : Éléments de connexion et extensions > Finder Extensions."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パス: ログイン項目と拡張機能 > Finder 拡張機能。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "경로: 로그인 항목 및 확장 > Finder 확장."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Caminho: Itens de login e extensões > Finder Extensões."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Путь: Элементы входа и расширения > Finder Расширения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "入口：登录项与扩展 > Finder 扩展。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "入口：登錄項與擴展 > Finder 擴展。"
          }
        }
      }
    },
    "configuration.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر عناصر قائمة السياق Finder التي سيتم عرضها وقم بإدارة التطبيقات في \"فتح باستخدام\"."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie aus, welche Finder-Kontextmenüelemente angezeigt werden, und verwalten Sie die Apps in „Öffnen mit“."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose which Finder context menu items are shown and manage the apps in Open With."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija qué Finder elementos del menú contextual se muestran y administre las aplicaciones en Abrir con."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les éléments du menu contextuel Finder à afficher et gérez les applications dans Ouvrir avec."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "表示する Finder コンテキスト メニュー項目を選択し、「プログラムから開く」でアプリを管理します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "표시되는 Finder 컨텍스트 메뉴 항목을 선택하고 연결 프로그램에서 앱을 관리하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quais Finder itens do menu de contexto serão exibidos e gerencie os aplicativos em Abrir com."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, какие Finder элементы контекстного меню будут отображаться, и управляйте приложениями с помощью функции «Открыть с помощью»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 Finder 右键菜单显示哪些项，并管理「用应用打开」的应用列表。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇 Finder 右鍵菜單顯示哪些項，並管理「用應用打開」的應用列表。"
          }
        }
      }
    },

{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Right Click"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "右键工具"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add quick Finder context menu actions for folders and paths."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Finder 右键菜单中快速新建文件夹和复制路径"
          }
        }
      }
    },
    "permission.finderExtension.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder Extension"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder 扩展"
          }
        }
      }
    },
    "permission.finderExtension.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on MacTools Right Click in System Settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在系统设置中打开 MacTools 右键工具。"
          }
        }
      }
    },
    "permission.finderExtension.status.disabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disabled"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未启用"
          }
        }
      }
    },
    "permission.finderExtension.status.enabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enabled"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已启用"
          }
        }
      }
    },
    "permission.finderExtension.footnote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Path: Login Items & Extensions > Finder Extensions."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "入口：登录项与扩展 > Finder 扩展。"
          }
        }
      }
    },
    "configuration.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose which Finder context menu items are shown and manage the apps in Open With."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 Finder 右键菜单显示哪些项，并管理「用应用打开」的应用列表。"
          }
        }
      }
    },
    "settings.addApp.button": {
      "extractionState": "manual",
      "localizations": {

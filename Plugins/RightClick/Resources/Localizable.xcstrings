{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقر بزر الماوس الأيمن"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechtsklick"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Right Click"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clic derecho"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clic droit"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "右クリック"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오른쪽 클릭"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique com o botão direito"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Щелкните правой кнопкой мыши"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "右键工具"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "右鍵工具"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف إجراءات قائمة السياق Finder السريعة للمجلدات والمسارات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie schnelle Finder-Kontextmenüaktionen für Ordner und Pfade hinzu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add quick Finder context menu actions for folders and paths."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregue acciones rápidas del menú contextual Finder para carpetas y rutas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des actions rapides de menu contextuel Finder pour les dossiers et les chemins."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォルダーとパスに対するクイック Finder コンテキスト メニュー アクションを追加します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "폴더 및 경로에 대한 빠른 Finder 컨텍스트 메뉴 작업을 추가합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione ações rápidas do menu de contexto Finder para pastas e caminhos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте быстрые действия контекстного меню Finder для папок и путей."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Finder 右键菜单中快速新建文件夹和复制路径"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Finder 右鍵菜單中快速新建資料夾和複製路徑"
          }
        }
      }
    },
    "permission.finderExtension.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder الامتداد"
          }
        },
        "de": {

          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder Extension"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder 拡張機能"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder 확장"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder Extensão"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder Расширение"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder 扩展"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder 擴展"
          }
        }
      }
    },
    "permission.finderExtension.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتشغيل MacTools انقر بزر الماوس الأيمن في إعدادات النظام."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie „MacTools“ mit der rechten Maustaste in den Systemeinstellungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on MacTools Right Click in System Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa MacTools Clic derecho en Configuración del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez MacTools Clic droit dans les paramètres système."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定で MacTools を右クリックしてオンにします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정에서 MacTools을(를) 마우스 오른쪽 버튼으로 클릭하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative MacTools Clique com o botão direito nas configurações do sistema."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите MacTools Щелкните правой кнопкой мыши в настройках системы."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在系统设置中打开 MacTools 右键工具。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在系統設定中打開 MacTools 右鍵工具。"
          }
        }
      }
    },

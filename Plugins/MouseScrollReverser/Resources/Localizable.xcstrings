{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "error.accessibilityRequired": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Scroll reversing needs Accessibility permission. Grant access in System Settings first." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "滚动翻转需要辅助功能权限，请先前往设置完成授权。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "滾動翻轉需要輔助使用權限，請先前往設定完成授權。" } }
      }
    },
    "error.accessibilityRevoked": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Accessibility permission is off. Scroll reversing has paused." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "辅助功能权限已关闭，滚动翻转已暂停。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "輔助使用權限已關閉，滾動翻轉已暫停。" } }
      }
    },
    "error.tapUnavailable": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Could not start scroll event monitoring. Confirm Accessibility permission and try again." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "无法启动滚动事件监听，请确认辅助功能授权后重试。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "無法啟動滾動事件監聽，請確認輔助使用授權後重試。" } }
      }
    },
    "metadata.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Reverse scrolling by device and axis." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "按设备和方向反转滚动" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "依裝置和方向反轉滾動" } }
      }
    },
    "metadata.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Scroll Reverser" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "鼠标滚动翻转" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "滑鼠滾動翻轉" } }
      }
    },
    "panel.subtitle.enabledFormat": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "On · %@ · %@" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "已开启 · %@ · %@" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "已開啟 · %@ · %@" } }
      }
    },
    "panel.subtitle.needsAccessibility": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Accessibility permission required before enabling" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "启用前需要辅助功能授权" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "啟用前需要輔助使用授權" } }
      }
    },
    "panel.subtitle.noAxis": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Choose horizontal or vertical" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "请选择水平或垂直方向" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "請選擇水平或垂直方向" } }
      }
    },
    "panel.subtitle.noDevice": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Choose mouse or trackpad" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "请选择鼠标或触控板" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "請選擇滑鼠或觸控板" } }
      }
    },
    "permission.accessibility.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Required to modify system scroll events." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "修改系统滚动事件需要辅助功能权限。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "修改系統滾動事件需要輔助使用權限。" } }
      }
    },
    "permission.accessibility.footnote": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Go to System Settings → Privacy & Security → Accessibility, then allow MacTools." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "前往系统设置 → 隐私与安全性 → 辅助功能，允许 MacTools。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "前往系統設定 → 隱私權與安全性 → 輔助使用，允許 MacTools。" } }
      }
    },
    "permission.accessibility.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Accessibility Permission" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "辅助功能授权" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "輔助使用授權" } }
      }
    },
    "permission.inputMonitoring.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Used to distinguish mouse wheel scrolling from trackpad gestures." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "用于区分鼠标滚轮和触控板手势，减少误判。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "用於區分滑鼠滾輪和觸控板手勢，減少誤判。" } }
      }
    },
    "permission.inputMonitoring.footnote": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Go to System Settings → Privacy & Security → Input Monitoring, then allow MacTools. Without it, continuous scrolling is handled conservatively to avoid affecting the trackpad." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "前往系统设置 → 隐私与安全性 → 输入监控，允许 MacTools。未授权时会保守处理连续滚动，避免误伤触控板。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "前往系統設定 → 隱私權與安全性 → 輸入監控，允許 MacTools。未授權時會保守處理連續滾動，避免影響觸控板。" } }
      }
    },
    "permission.inputMonitoring.granted": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "MacTools is allowed to use Input Monitoring and can distinguish mouse and trackpad scrolling more reliably." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "已允许 MacTools 使用输入监控，可更可靠地区分鼠标和触控板。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "已允許 MacTools 使用輸入監控，可更可靠地區分滑鼠和觸控板。" } }
      }
    },
    "permission.inputMonitoring.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Input Monitoring Permission" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "输入监控授权" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "輸入監控授權" } }
      }
    },
    "settings.behavior.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Scroll Reversing" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "滚动翻转" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "滾動翻轉" } }
      }
    },
    "settings.enabled.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Modify scroll events using the device and axis settings below." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "开启后按下方设备和方向设置修改滚动事件。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "開啟後依下方裝置和方向設定修改滾動事件。" } }
      }
    },
    "settings.enabled.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Enable Scroll Reversing" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "启用滚动翻转" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "啟用滾動翻轉" } }
      }
    },
    "settings.horizontal.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Reverse left and right scrolling." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "反转左右滚动方向。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "反轉左右滾動方向。" } }
      }
    },
    "settings.horizontal.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Horizontal Reversing" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "水平翻转" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "水平翻轉" } }
      }
    },
    "settings.mouse.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Reverse wheel mice and most third-party mouse scrolling." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "翻转滚轮鼠标和大多数第三方鼠标滚动。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "翻轉滾輪滑鼠和大多數第三方滑鼠滾動。" } }
      }
    },
    "settings.mouse.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Mouse" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "鼠标" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "滑鼠" } }
      }
    },
    "settings.scope.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Devices" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "作用设备" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "作用裝置" } }
      }
    },
    "settings.trackpad.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Reverse continuous scrolling from trackpads and Magic Mouse." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "翻转触控板和 Magic Mouse 的连续滚动。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "翻轉觸控板和 Magic Mouse 的連續滾動。" } }
      }
    },
    "settings.trackpad.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Trackpad" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "触控板" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "觸控板" } }
      }
    },
    "settings.vertical.description": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Reverse up and down scrolling." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "反转上下滚动方向。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "反轉上下滾動方向。" } }
      }
    },
    "settings.vertical.title": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Vertical Reversing" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "垂直翻转" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "垂直翻轉" } }
      }
    },
    "summary.axis.all": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "horizontal and vertical" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "水平和垂直" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "水平和垂直" } }
      }
    },
    "summary.axis.horizontal": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "horizontal" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "水平" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "水平" } }
      }
    },
    "summary.axis.none": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "no axis" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "未选方向" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "未選方向" } }
      }
    },
    "summary.axis.vertical": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "vertical" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "垂直" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "垂直" } }
      }
    },
    "summary.device.all": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "mouse and trackpad" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "鼠标和触控板" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "滑鼠和觸控板" } }
      }
    },
    "summary.device.mouse": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "mouse" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "鼠标" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "滑鼠" } }
      }
    },
    "summary.device.none": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "no device" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "未选设备" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "未選裝置" } }
      }
    },
    "summary.device.trackpad": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "trackpad" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "触控板" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "觸控板" } }
      }
    }
  },
  "version": "1.0"
}


    "settings.empty": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقر فوق \"إضافة\" لاختيار تطبيق وتعيين مفتاح التشغيل السريع."

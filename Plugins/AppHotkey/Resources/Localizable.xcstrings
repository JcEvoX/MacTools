{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App Hotkeys"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用快捷键"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bind global hotkeys to frequently used apps."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为常用应用绑定全局快捷键"
          }
        }
      }
    },
    "panel.subtitle.empty": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No bindings yet. Configure them in Settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无绑定，前往设置配置"
          }
        }
      }
    },
    "panel.subtitle.enabledCountFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d hotkeys enabled"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 个快捷键已启用"
          }
        }
      }
    },
    "panel.subtitle.paused": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hotkeys paused"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快捷键已暂停"
          }
        }
      }
    },
    "settings.section.bindings": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App Bindings"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用绑定"
          }
        }
      }
    },
    "settings.add": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加"
          }
        }
      }
    },
    "settings.empty": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click Add to choose an app and assign a hotkey."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击「添加」选择应用并绑定快捷键"
          }
        }
      }
    },
    "settings.shortcutConflictFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Conflicts with \"%@\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "与「%@」冲突"
          }
        }
      }
    },
    "openPanel.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose App"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择应用"
          }
        }
      }
    },
    "openPanel.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the app to bind to a hotkey."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择要绑定快捷键的应用"
          }
        }
      }
    },
    "settings.shortcutUnset": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not set"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未设置"
          }
        }
      }
    },
    "settings.pathUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App path unavailable"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用路径不可用"
          }
        }
      }
    },
    "settings.shortcutRecorderTitleFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Hotkey"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 快捷键"
          }
        }
      }
    },
    "settings.clearShortcut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear hotkey"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清除快捷键"
          }
        }
      }
    },
    "settings.deleteBinding": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete this binding"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除此绑定"
          }

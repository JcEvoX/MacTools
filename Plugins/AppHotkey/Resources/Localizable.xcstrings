{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مفاتيح التشغيل السريع للتطبيقات"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "App-Hotkeys"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App Hotkeys"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Teclas de acceso rápido a aplicaciones"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touches de raccourci d'application"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリのホットキー"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 단축키"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Teclas de atalho do aplicativo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Горячие клавиши приложения"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用快捷键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "應用快速鍵"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اربط مفاتيح التشغيل السريع العامة بالتطبيقات المستخدمة بشكل متكرر."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Globale Hotkeys an häufig verwendete Apps binden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bind global hotkeys to frequently used apps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vincular teclas de acceso rápido globales a aplicaciones de uso frecuente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Associez les raccourcis clavier globaux aux applications fréquemment utilisées."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "グローバル ホットキーを頻繁に使用するアプリにバインドします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자주 사용하는 앱에 전역 단축키를 바인딩합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vincule teclas de atalho globais a aplicativos usados com frequência."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Привяжите глобальные горячие клавиши к часто используемым приложениям."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为常用应用绑定全局快捷键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為常用應用綁定全局快速鍵"
          }
        }
      }
    },
    "panel.subtitle.empty": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد روابط بعد. قم بتكوينها في الإعدادات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Bindungen. Konfigurieren Sie sie in den Einstellungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No bindings yet. Configure them in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay enlaces. Configúrelos en Configuración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune liaison pour l'instant. Configurez-les dans Paramètres."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだバインディングがありません。 [設定] で設定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 바인딩이 없습니다. 설정에서 구성하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma ligação ainda. Configure-os em Configurações."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Привязок пока нет. Настройте их в настройках."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无绑定，前往设置配置"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "暫無綁定，前往設定配置"
          }
        }
      }
    },

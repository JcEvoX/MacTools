{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بإنهاء التطبيقات"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apps beenden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit Apps"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Salir de aplicaciones"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quitter les applications"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリを終了"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 종료"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sair dos aplicativos"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выйти из приложений"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出应用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "結束 App"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدد التطبيقات قيد التشغيل وقم بإنهاء تشغيلها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgeführte Apps auswählen und beenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select and quit running apps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona y cierra las aplicaciones en ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez et quittez les applications en cours d'exécution."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実行中のアプリを選択して終了します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실행 중인 앱을 선택하고 종료합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione e saia dos aplicativos em execução."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите и закройте запущенные приложения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择并退出正在运行的应用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇並退出正在運行的應用"
          }
        }
      }
    },

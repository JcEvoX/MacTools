    "manager.note.placeholder": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف ملاحظة محلية لعنصر التشغيل هذا. تبقى على هذا الـ Mac ولا تُكتب في plist."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie eine lokale Notiz für dieses Startelement hinzu. Es bleibt auf diesem Mac und wird nicht in die Plist geschrieben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a local note for this launch item. It stays on this Mac and is not written to the plist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade una nota local para este elemento de inicio. Se queda en este Mac y no se escribe en el plist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez une note locale à cet élément de lancement. Elle reste sur ce Mac et n’est pas écrite dans le plist."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この起動項目にローカルメモを追加します。この Mac にのみ保存され、plist には書き込まれません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 시작 항목에 로컬 메모를 추가합니다. 이 Mac에만 저장되며 plist에는 기록되지 않습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione uma nota local para este item de inicialização. Ela fica neste Mac e não é gravada no plist."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте локальную заметку для этого элемента запуска. Она останется на этом Mac и не будет записана в plist."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为这个启动项添加本地备注（仅保存在本机，不写入 plist）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為這個啟動項添加本地備註（僅保存在本機，不寫入 plist）。"
          }
        }
      }
    },

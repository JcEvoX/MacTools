          }
        }
      }
    },
    "manager.confirm.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nسيتم استدعاء launchctl %@. يمكن عادةً استعادة LaunchAgents الخاصة بالمستخدم، لكن التعطيل أو التفريغ أو الإيقاف قد يؤثر في المهام الخلفية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nDadurch wird launchctl %@ aufgerufen. Benutzer-LaunchAgents lassen sich normalerweise wiederherstellen, aber Deaktivieren, Entladen oder Stoppen kann Hintergrundaufgaben beeinträchtigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nThis will call launchctl %@. User LaunchAgents are usually recoverable, but disabling, unloading, or stopping may affect background tasks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nEsto llamará a launchctl %@. Los LaunchAgents de usuario suelen poder recuperarse, pero desactivarlos, descargarlos o detenerlos puede afectar a tareas en segundo plano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nCette action appellera launchctl %@. Les LaunchAgents utilisateur sont généralement récupérables, mais les désactiver, les décharger ou les arrêter peut affecter les tâches en arrière-plan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nlaunchctl %@ を呼び出します。ユーザー LaunchAgent は通常復旧できますが、無効化、アンロード、停止はバックグラウンドタスクに影響する場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nlaunchctl %@를 호출합니다. 사용자 LaunchAgent는 일반적으로 복구할 수 있지만 비활성화, 언로드 또는 중지는 백그라운드 작업에 영향을 줄 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nIsso chamará launchctl %@. LaunchAgents de usuário geralmente podem ser recuperados, mas desativar, descarregar ou parar pode afetar tarefas em segundo plano."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\nБудет вызван launchctl %@. Пользовательские LaunchAgents обычно можно восстановить, но отключение, выгрузка или остановка могут повлиять на фоновые задачи."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\n此操作会调用 launchctl %@。用户级 LaunchAgent 通常可以恢复，但禁用、卸载或停止可能影响后台任务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@\n%@\n\n此操作會調用 launchctl %@。用戶級 LaunchAgent 通常可以恢復，但禁用、卸載或停止可能影響後台任務。"
          }
        }
      }
    },
    "manager.confirm.title": {
      "extractionState": "manual",
      "localizations": {

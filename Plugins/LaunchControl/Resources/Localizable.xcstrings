    "controller.operation.readOnly": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تكون عناصر التشغيل العامة والنظام للقراءة فقط بشكل افتراضي لمنع التغييرات غير المقصودة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "System- und globale Startelemente sind standardmäßig schreibgeschützt, um versehentliche Änderungen zu verhindern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System and global launch items are read-only by default to prevent accidental changes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los elementos de inicio global y del sistema son de solo lectura de forma predeterminada para evitar cambios accidentales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments de lancement système et global sont en lecture seule par défaut pour éviter toute modification accidentelle."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムおよびグローバル起動項目は、誤って変更されることを防ぐため、デフォルトでは読み取り専用です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 및 전역 실행 항목은 실수로 인한 변경을 방지하기 위해 기본적으로 읽기 전용입니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os itens de lançamento global e do sistema são somente leitura por padrão para evitar alterações acidentais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Системные и глобальные элементы запуска по умолчанию доступны только для чтения, чтобы предотвратить случайные изменения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统或全局启动项默认只读，避免误操作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統或全局啟動項預設只讀，避免誤操作。"
          }
        }
      }
    },

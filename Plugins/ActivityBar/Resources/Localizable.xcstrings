    "settings.aiHooks.footnote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Writes hook settings for Claude Code, Cursor, and Codex. Scripts send activity events locally through a Unix socket."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击后会写入 Claude Code、Cursor 和 Codex 的 hook 配置；脚本只在本机通过 Unix socket 发送活动事件。"
          }
        }
      }
    },

    "settings.inputMonitoring.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحسب أحداث لوحة المفاتيح، والنقر بالماوس، والتمرير."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zählt Tastatur-, Mausklick- und Bildlaufereignisse."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Counts keyboard, mouse click, and scroll events."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuenta eventos de teclado, clic del mouse y desplazamiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Compte les événements de clavier, de clic de souris et de défilement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーボード、マウスのクリック、スクロールのイベントをカウントします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키보드, 마우스 클릭 및 스크롤 이벤트를 계산합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Conta eventos de teclado, clique do mouse e rolagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Считает события клавиатуры, щелчка мыши и прокрутки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于统计键盘、鼠标点击和滚动事件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用於統計鍵盤、滑鼠點擊和滾動事件。"
          }
        }
      }
    },
    "settings.inputMonitoring.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتطلب إحصائيات لوحة المفاتيح والماوس والتمرير السماح بـ MacTools في مراقبة الإدخال. لا يزال من الممكن تسجيل وقت استخدام التطبيق الأمامي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tastatur-, Maus- und Scroll-Statistiken erfordern die Zulassung von MacTools in der Eingabeüberwachung. Die Nutzungsdauer der Vordergrund-App kann weiterhin aufgezeichnet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keyboard, mouse, and scroll stats require allowing MacTools in Input Monitoring. Foreground app usage time can still be recorded."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las estadísticas de teclado, mouse y desplazamiento requieren permitir MacTools en Monitoreo de entrada. Aún se puede registrar el tiempo de uso de la aplicación en primer plano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les statistiques du clavier, de la souris et du défilement nécessitent l'autorisation de MacTools dans la surveillance des entrées. Le temps d'utilisation de l'application au premier plan peut toujours être enregistré."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーボード、マウス、およびスクロールの統計情報を使用するには、入力モニタリングで MacTools を許可する必要があります。フォアグラウンド アプリの使用時間は引き続き記録できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키보드, 마우스 및 스크롤 통계를 사용하려면 입력 모니터링에서 MacTools을 허용해야 합니다. 포그라운드 앱 사용 시간은 계속 기록될 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As estatísticas de teclado, mouse e rolagem exigem a permissão de MacTools no monitoramento de entrada. O tempo de uso do app em primeiro plano ainda pode ser registrado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Статистика клавиатуры, мыши и прокрутки требует разрешения MacTools в мониторинге ввода. Время использования приложений переднего плана по-прежнему можно записать."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "键盘、鼠标和滚动统计需要在系统设置中允许 MacTools 进行输入监控。前台应用使用时长仍可记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "鍵盤、滑鼠和滾動統計需要在系統設定中允許 MacTools 進行輸入監控。前臺應用使用時長仍可記錄。"
          }
        }
      }
    },

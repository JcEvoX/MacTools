    "component.funFact.clickMinutes": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لقد قمت بالنقر فوق %@ مرة. وهذا يشبه النقر على مكتبك لمدة %d دقيقة تقريبًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben %@ Mal geklickt. Das ist so, als würden Sie etwa %d Minuten lang auf Ihren Schreibtisch klopfen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You clicked %@ times. That's like tapping your desk for about %d minutes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiciste clic %@ veces. Eso es como tocar tu escritorio durante aproximadamente %d minutos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez cliqué %@ fois. C'est comme si vous tapotiez votre bureau pendant environ %d minutes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 回クリックしました。これは、約 %d 分間机をたたくことに似ています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@번 클릭하셨습니다. 이는 약 %d분 동안 책상을 두드리는 것과 같습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você clicou %@ vezes. Isso é como bater na sua mesa por cerca de %d minutos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы нажали %@ раз. Это все равно, что стучать по столу примерно %d минут."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你今天点击了 %@ 次，约等于敲桌子 %d 分钟。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你今天點擊了 %@ 次，約等於敲桌子 %d 分鐘。"
          }
        }
      }
    },
    "component.funFact.typedPages": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لقد أجريت %@ ضغطات على المفاتيح اليوم. يتعلق الأمر بكتابة %d صفحة كاملة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben heute %@ Tastenanschläge gemacht. Das bedeutet, dass %d ganze Seiten geschrieben werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You made %@ keystrokes today. That's about writing %d full pages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoy hiciste %@ pulsaciones de teclas. Se trata de escribir %d páginas completas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez effectué %@ frappes au clavier aujourd'hui. Il s'agit d'écrire %d pages complètes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日、%@ 回のキーストロークを行いました。つまり、%d ページ全体を書くことになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 %@ 키를 누르셨습니다. 그것은 %d 전체 페이지를 작성하는 것과 같습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pressionou %@ hoje. Trata-se de escrever %d páginas inteiras."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сегодня вы нажали %@ клавиш. Речь идет о написании %d полных страниц."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你今天敲了 %@ 次键盘，约等于写满 %d 页。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你今天敲了 %@ 次鍵盤，約等於寫滿 %d 頁。"
          }
        }
      }
    },
    "component.inputInsight.enableTracking": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امنح مراقبة الإدخال وقم بتشغيلها لبدء جمع الإحصائيات المحلية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gewähren Sie die Eingabeüberwachung und aktivieren Sie diese, um mit der Erfassung lokaler Statistiken zu beginnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant Input Monitoring and turn this on to start collecting local stats."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Otorgue monitoreo de entrada y actívelo para comenzar a recopilar estadísticas locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accordez la surveillance des entrées et activez-la pour commencer à collecter des statistiques locales."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "入力モニタリングを許可し、これをオンにしてローカル統計の収集を開始します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "입력 모니터링을 부여하고 이 기능을 켜면 로컬 통계 수집이 시작됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Conceda monitoramento de entrada e ative-o para começar a coletar estatísticas locais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешите мониторинг ввода и включите его, чтобы начать сбор локальной статистики."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "授权输入监控并开启后即可开始记录本地统计。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "授權輸入監控並開啟後即可開始記錄本地統計。"
          }
        }
      }
    },

    "settings.dragDetection.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أسقط ملف .app لإظهار نافذة الإصلاح والبدء تلقائيًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie eine .app-Datei ab, um das Reparaturfenster anzuzeigen und automatisch zu starten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drop a .app file to show the repair window and start automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Suelte un archivo .app para mostrar la ventana de reparación y comenzar automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déposez un fichier .app pour afficher la fenêtre de réparation et démarrer automatiquement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": ".app ファイルをドロップすると修復ウィンドウが表示され、自動的に開始されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "복구 창을 표시하고 자동으로 시작하려면 .app 파일을 삭제하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Solte um arquivo .app para mostrar a janela de reparo e iniciar automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите файл .app, чтобы открыть окно восстановления и запустить его автоматически."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖入 .app 文件后松手，自动弹出修复窗口并开始修复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "拖入 .app 檔案後鬆手，自動彈出修復窗口並開始修復。"
          }
        }
      }
    },

{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إصلاح التطبيقات التالفة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beschädigte Apps reparieren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fix Damaged Apps"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reparar aplicaciones dañadas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réparer les applications endommagées"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "破損したアプリを修復する"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "손상된 앱 수정"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Corrigir aplicativos danificados"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Исправить поврежденные приложения"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修复损坏应用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "修復損壞應用"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بإزالة سمات العزل لحل تحذيرات التطبيقات التالفة أو غير الموثوقة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernen Sie Quarantäneattribute, um Warnungen zu beschädigten oder nicht vertrauenswürdigen Apps zu beheben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove quarantine attributes to resolve damaged or untrusted app warnings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimine los atributos de cuarentena para resolver advertencias de aplicaciones dañadas o que no son de confianza."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimez les attributs de quarantaine pour résoudre les avertissements d'applications endommagées ou non fiables."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "破損したアプリまたは信頼できないアプリの警告を解決するには、隔離属性を削除します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "손상되었거나 신뢰할 수 없는 앱 경고를 해결하려면 격리 속성을 제거하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Remova atributos de quarentena para resolver avisos de aplicativos danificados ou não confiáveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалите атрибуты карантина, чтобы устранить предупреждения поврежденных или ненадежных приложений."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移除隔离属性，解决「已损坏」或「不受信任」提示"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "移除隔離屬性，解決「已損壞」或「不受信任」提示"
          }
        }
      }
    },
    "panel.button.choose": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",

{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fix Damaged Apps"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修复损坏应用"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove quarantine attributes to resolve damaged or untrusted app warnings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移除隔离属性，解决「已损坏」或「不受信任」提示"
          }
        }
      }
    },
    "panel.button.choose": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择"
          }
        }
      }
    },
    "panel.subtitle.chooseApp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a .app file to repair"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 .app 文件以修复"
          }
        }
      }
    },
    "panel.subtitle.running": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fixing…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修复中…"
          }
        }
      }
    },
    "panel.subtitle.successFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Repaired: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已修复：%@"
          }
        }
      }
    },
    "openPanel.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose App to Repair"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择要修复的应用"
          }
        }
      }
    },
    "openPanel.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose an app that shows a \"damaged\" or \"untrusted\" warning."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择显示「已损坏」或「不受信任」的应用"
          }
        }
      }
    },
    "settings.section.behavior": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Behavior"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "行为"
          }
        }
      }
    },
    "settings.dragDetection.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag Detection"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动检测"
          }
        }
      }
    },
    "settings.dragDetection.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drop a .app file to show the repair window and start automatically."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖入 .app 文件后松手，自动弹出修复窗口并开始修复。"
          }
        }
      }
    },
    "dropZone.waiting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drop a .app file here to repair it"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将 .app 文件拖到此处以修复"
          }
        }
      }
    },
    "dropZone.running": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fixing…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修复中…"
          }
        }
      }
    },
    "dropZone.successFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Repaired: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已修复：%@"
          }
        }
      }
    },
    "dropZone.close": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Close"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭"
          }
        }
      }
    },
    "error.fixFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Repair failed"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修复失败"
          }
        }
      }
    },
    "error.unsupportedPathCharacters": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app path contains unsupported characters (double quotes)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用路径包含不支持的字符（双引号）"
          }
        }
      }
    },
    "error.userCancelledAuthorization": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication was canceled."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户取消了授权"
          }
        }
      }
    },
    "error.fixFailedUnknown": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Repair failed with an unknown error."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修复失败（未知错误）"
          }
        }
      }
    }
  },
  "version": "1.0"
}

    "openPanel.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر تطبيقًا يعرض تحذيرًا \"تالفًا\" أو \"غير موثوق به\"."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie eine App aus, die eine „beschädigte“ oder „nicht vertrauenswürdige“ Warnung anzeigt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose an app that shows a \"damaged\" or \"untrusted\" warning."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija una aplicación que muestre una advertencia de \"dañada\" o \"no confiable\"."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une application qui affiche un avertissement « endommagé » ou « non fiable »."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「破損しています」または「信頼できない」という警告が表示されるアプリを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'손상됨' 또는 '신뢰할 수 없음' 경고를 표시하는 앱을 선택하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um aplicativo que mostre um aviso de \"danificado\" ou \"não confiável\"."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите приложение, которое показывает предупреждение «повреждено» или «ненадежно»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择显示「已损坏」或「不受信任」的应用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇顯示「已損壞」或「不受信任」的應用"
          }
        }
      }
    },

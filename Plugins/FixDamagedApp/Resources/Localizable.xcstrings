          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolher"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбрать"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇"
          }
        }
      }
    },
    "panel.subtitle.chooseApp": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر ملف .app لإصلاحه"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie eine .app-Datei zur Reparatur aus"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a .app file to repair"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija un archivo .app para reparar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un fichier .app à réparer"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "修復する .app ファイルを選択してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "복구할 .app 파일을 선택하세요"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um arquivo .app para reparar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите файл .app для восстановления"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 .app 文件以修复"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇 .app 檔案以修復"
          }
        }
      }
    },
    "panel.subtitle.running": {
      "extractionState": "manual",

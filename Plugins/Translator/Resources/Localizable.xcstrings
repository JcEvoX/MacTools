    "permission.screenRecording.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحتاج ترجمة لقطة الشاشة إلى قراءة منطقة الشاشة المحددة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Screenshot-Übersetzung muss den ausgewählten Bildschirmbereich lesen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screenshot translation needs to read the selected screen region."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La traducción de captura necesita leer la región de pantalla seleccionada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La traduction de capture d’écran doit lire la zone d’écran sélectionnée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スクリーンショット翻訳には、選択した画面領域の読み取りが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스크린샷 번역은 선택한 화면 영역을 읽어야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A tradução de captura de tela precisa ler a região selecionada da tela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для перевода скриншота нужно прочитать выбранную область экрана."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

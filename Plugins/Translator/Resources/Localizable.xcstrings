    "settings.defaultPromptTemplate": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ترجم النص التالي من {{source_language}} إلى {{target_language}}. أعد الترجمة فقط.\n\n{{text}}"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übersetze den folgenden Text von {{source_language}} nach {{target_language}}. Gib nur die Übersetzung zurück.\n\n{{text}}"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Translate the following text from {{source_language}} to {{target_language}}. Return only the translation.\n\n{{text}}"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Traduce el siguiente texto de {{source_language}} a {{target_language}}. Devuelve solo la traducción.\n\n{{text}}"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Traduisez le texte suivant de {{source_language}} vers {{target_language}}. Renvoyez uniquement la traduction.\n\n{{text}}"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次のテキストを {{source_language}} から {{target_language}} に翻訳してください。翻訳のみを返してください。\n\n{{text}}"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 텍스트를 {{source_language}}에서 {{target_language}}로 번역하세요. 번역문만 반환하세요.\n\n{{text}}"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Traduza o texto a seguir de {{source_language}} para {{target_language}}. Retorne apenas a tradução.\n\n{{text}}"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переведите следующий текст с {{source_language}} на {{target_language}}. Верните только перевод.\n\n{{text}}"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请将以下文本从 {{source_language}} 翻译为 {{target_language}}，只返回译文。\n\n{{text}}"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請將以下文字從 {{source_language}} 翻譯為 {{target_language}}，只返回譯文。\n\n{{text}}"
          }
        }
      }
    },

        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La traducción de selección necesita leer la selección actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La traduction de sélection doit lire la sélection actuelle."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択範囲の翻訳には、現在の選択内容の読み取りが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택 항목 번역은 현재 선택 내용을 읽어야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A tradução da seleção precisa ler a seleção atual."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для перевода выделенного текста нужно прочитать текущий выбор."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "划词翻译需要读取当前选中文本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "劃詞翻譯需要讀取目前選取的文字。"
          }
        }
      }
    },
    "permission.accessibility.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح إعدادات النظام > الخصوصية والأمان > إمكانية الوصول واسمح لـ MacTools."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnen Sie Systemeinstellungen > Datenschutz & Sicherheit > Bedienungshilfen und erlauben Sie MacTools."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open System Settings > Privacy & Security > Accessibility and allow MacTools."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre Ajustes del Sistema > Privacidad y seguridad > Accesibilidad y permite MacTools."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez Réglages Système > Confidentialité et sécurité > Accessibilité, puis autorisez MacTools."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定 > プライバシーとセキュリティ > アクセシビリティで MacTools を許可します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정 > 개인정보 보호 및 보안 > 손쉬운 사용에서 MacTools를 허용하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra Ajustes do Sistema > Privacidade e Segurança > Acessibilidade e permita MacTools."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте Системные настройки > Конфиденциальность и безопасность > Универсальный доступ и разрешите MacTools."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "前往系统设置 → 隐私与安全性 → 辅助功能，授权 MacTools。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "前往系統設定 → 隱私權與安全性 → 輔助使用，授權 MacTools。"
          }
        }
      }
    },

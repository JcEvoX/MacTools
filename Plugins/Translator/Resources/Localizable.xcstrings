    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ترجم النص المحدد أو مناطق لقطة الشاشة باستخدام اختصارات"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgewählten Text oder Screenshot-Bereiche per Kurzbefehl übersetzen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Translate selected text or screenshot regions with shortcuts"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Traduce texto seleccionado o regiones de captura con atajos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Traduit le texte sélectionné ou des zones de capture d’écran avec des raccourcis"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したテキストやスクリーンショット範囲をショートカットで翻訳します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 텍스트나 스크린샷 영역을 단축키로 번역합니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Traduz texto selecionado ou regiões de captura de tela com atalhos"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перевод выбранного текста или области снимка экрана по горячим клавишам"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "划词与截图快捷键翻译"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過快速鍵翻譯選取文字或截圖區域"
          }
        }
      }
    },

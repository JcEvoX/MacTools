    "permission.automation.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد تحتاج ترجمة التحديد في المتصفح إلى السماح لـ MacTools بالتحكم في المتصفح الحالي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Browser-Auswahlübersetzung benötigt eventuell die Berechtigung, den aktuellen Browser zu steuern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Browser selection translation may need permission for MacTools to control the current browser."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La traducción de selección en el navegador puede necesitar permiso para que MacTools controle el navegador actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La traduction de sélection dans le navigateur peut nécessiter l’autorisation de contrôler le navigateur actuel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザの選択範囲を翻訳するには、MacTools に現在のブラウザの制御を許可する必要がある場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "브라우저 선택 항목 번역은 MacTools가 현재 브라우저를 제어할 권한이 필요할 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A tradução de seleção no navegador pode exigir permissão para o MacTools controlar o navegador atual."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для перевода выделенного текста в браузере MacTools может понадобиться разрешение на управление текущим браузером."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "浏览器划词可能需要允许 MacTools 控制当前浏览器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "瀏覽器劃詞可能需要允許 MacTools 控制目前的瀏覽器。"
          }
        }
      }
    },
    "permission.automation.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيطلب macOS إذن الأتمتة عند التحكم في المتصفح لأول مرة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS fragt beim ersten Steuern eines Browsers nach der Automationsberechtigung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS asks for automation permission the first time a browser is controlled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS solicita permiso de automatización la primera vez que se controla un navegador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS demande l’autorisation d’automatisation lors du premier contrôle d’un navigateur."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS は、ブラウザを初めて制御するときに自動化の許可を求めます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS는 브라우저를 처음 제어할 때 자동화 권한을 요청합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O macOS solicita permissão de automação na primeira vez que um navegador é controlado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS запрашивает разрешение на автоматизацию при первом управлении браузером."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 会在首次控制浏览器时请求自动化授权。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 會在首次控制瀏覽器時要求自動化授權。"
          }
        }
      }
    },

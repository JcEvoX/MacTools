    "error.muteFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل كتم صوت الميكروفون."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofon konnte nicht stummgeschaltet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to mute microphone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo silenciar el micrófono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la mise en sourdine du microphone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクをミュートできませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마이크를 음소거하지 못했습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao silenciar o microfone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось отключить микрофон."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "静音操作失败"

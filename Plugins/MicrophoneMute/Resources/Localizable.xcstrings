    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كتم صوت الميكروفون"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofon-Stummschaltung"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Microphone Mute"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Silenciar micrófono"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Microphone muet"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクミュート"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마이크 음소거"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Silenciar microfone"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключение микрофона"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "麦克风静音"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "麥克風靜音"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كتم صوت إدخال الميكروفون الافتراضي أو استعادته بسرعة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnell stummschalten oder den Standard-Mikrofoneingang wiederherstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quickly mute or restore the default microphone input."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencia o restablece rápidamente la entrada de micrófono predeterminada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettez rapidement en sourdine ou restaurez l'entrée microphone par défaut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトのマイク入力を素早くミュートまたは復元します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 마이크 입력을 빠르게 음소거하거나 복원합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencie rapidamente ou restaure a entrada de microfone padrão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Быстро отключите звук или восстановите вход микрофона по умолчанию."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速静音或恢复默认麦克风输入"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速靜音或恢復預設麥克風輸入"
          }
        }
      }
    },

        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No adjustable displays detected"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se detectaron pantallas ajustables"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun affichage réglable détecté"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "調整可能なディスプレイが検出されませんでした"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "조정 가능한 디스플레이가 감지되지 않았습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma tela ajustável detectada"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настраиваемые дисплеи не обнаружены"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未检测到可调节亮度的显示器"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未檢測到可調節亮度的顯示器"
          }
        }
      }
    },

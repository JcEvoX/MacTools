            "value": "ディスプレイの明るさ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스플레이 밝기"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Brilho da tela"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Яркость дисплея"

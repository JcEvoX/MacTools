    "shortcut.settingsGroupDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ضبط سطوع الشاشة باستخدام النطاق المستهدف المحدد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passen Sie die Displayhelligkeit mithilfe des ausgewählten Zielbereichs an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust display brightness using the selected target scope."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta el brillo de la pantalla usando el alcance objetivo seleccionado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustez la luminosité de l'écran à l'aide de la portée cible sélectionnée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したターゲット スコープを使用してディスプレイの明るさを調整します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 대상 범위를 사용하여 디스플레이 밝기를 조정합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste o brilho da tela usando o escopo de destino selecionado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отрегулируйте яркость дисплея, используя выбранную целевую область."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按所选作用范围调整显示器亮度。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按所選作用範圍調整顯示器亮度。"
          }
        }
      }
    },

            "state": "translated",
            "value": "顯示器亮度"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ضبط السطوع بسرعة لكل شاشة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passen Sie die Helligkeit für jedes Display schnell an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quickly adjust brightness for each display."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta rápidamente el brillo de cada pantalla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustez rapidement la luminosité de chaque écran."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ディスプレイの明るさをすばやく調整します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 디스플레이의 밝기를 빠르게 조정하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste rapidamente o brilho de cada tela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Быстрая настройка яркости для каждого дисплея."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速调节每个显示器的亮度"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速調節每個顯示器的亮度"
          }
        }
      }
    },
    "panel.subtitle.noDisplays": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم اكتشاف أي شاشات قابلة للتعديل"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",

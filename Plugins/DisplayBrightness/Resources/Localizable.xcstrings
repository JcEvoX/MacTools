{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Display Brightness"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示器亮度"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quickly adjust brightness for each display."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速调节每个显示器的亮度"
          }
        }
      }
    },
    "panel.subtitle.noDisplays": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No adjustable displays detected"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未检测到可调节亮度的显示器"
          }
        }
      }
    },
    "panel.subtitle.displayCountFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d displays"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 个显示器"
          }
        }
      }
    },
    "shortcut.direction.decrease": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Decrease"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "降低"
          }
        }
      }
    },
    "shortcut.direction.increase": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Increase"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "增加"
          }
        }
      }
    },
    "shortcut.titleFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ Brightness"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@亮度"
          }
        }
      }
    },
    "shortcut.descriptionFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ display brightness."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@显示器亮度。"
          }
        }
      }
    },
    "shortcut.settingsGroupTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Brightness Shortcuts"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "亮度快捷键"
          }
        }
      }
    },
    "shortcut.settingsGroupDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust display brightness using the selected target scope."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按所选作用范围调整显示器亮度。"
          }
        }
      }
    },
    "settings.shortcutTarget.sectionTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Target Scope"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "作用范围"
          }
        }
      }
    },
    "settings.shortcutTarget.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcut Target"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快捷键目标"
          }
        }
      }
    },
    "settings.shortcutTarget.followsMouse": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow Mouse"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跟随鼠标"
          }
        }
      }
    },
    "settings.shortcutTarget.allDisplays": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All Displays"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有显示器"
          }
        }
      }
    },
    "settings.shortcutTarget.followsMouseDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only adjusts the display under the pointer."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只调整光标所在屏幕。"
          }
        }
      }
    },
    "settings.shortcutTarget.allDisplaysDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjusts every controllable display together."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步调整所有可控显示器。"
          }
        }
      }
    },
    "displayDisable.action.disable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn Off Built-in Display"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭内建显示屏"
          }
        }
      }
    },
    "displayDisable.action.restore": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restore Built-in Display"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "恢复内建显示屏"
          }
        }
      }
    },
    "error.displayUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The display has disconnected."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示器已断开连接"
          }
        }
      }
    },
    "error.brightnessUnavailableFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ cannot read brightness right now"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 当前无法读取亮度"
          }
        }
      }
    },
    "error.nativeAPINotAvailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System brightness API is unavailable."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统亮度接口不可用"
          }
        }
      }
    },
    "error.genericBrightnessUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The display cannot read brightness right now"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示器当前无法读取亮度"
          }
        }
      }
    },
    "error.i2cUnavailableFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ does not support DDC/CI"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 不支持 DDC/CI"
          }
        }
      }
    },
    "error.unsupportedReplyFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ returned invalid brightness data"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 返回了无效亮度数据"
          }
        }
      }
    },

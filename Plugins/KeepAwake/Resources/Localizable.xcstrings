          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Para automaticamente em %d horas"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Останавливается автоматически через %d часов"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 小时后自动停止"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 小時後自動停止"
          }
        }
      }
    },
    "panel.subtitle.remainingHoursMinutesFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {

{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep Awake"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止休眠"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prevent idle system sleep while allowing display sleep."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止系统空闲休眠，允许显示器息屏"
          }
        }
      }
    },
    "panel.subtitle.enabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enabled"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已启用"
          }
        }
      }
    },
    "panel.duration.forever": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Never"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永不"
          }
        }
      }
    },
    "panel.subtitle.remainingMinutesFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stops automatically in %d minutes"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 分钟后自动停止"
          }
        }
      }
    },
    "panel.subtitle.remainingHoursFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stops automatically in %d hours"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 小时后自动停止"
          }
        }
      }
    },
    "panel.subtitle.remainingHoursMinutesFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stops automatically in %d hours %d minutes"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 小时 %d 分钟后自动停止"
          }
        }
      }
    },
    "error.invalidEndDate": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The automatic stop time must be later than now."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动停止时间必须晚于当前时间。"
          }
        }
      }
    },
    "error.assertionCreationFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to keep the system awake. System error %d."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法启用阻止休眠，系统返回错误 %d。"
          }
        }
      }
    }
  },
  "version": "1.0"
}

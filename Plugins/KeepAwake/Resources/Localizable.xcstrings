{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "البقاء مستيقظًا"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wach bleiben"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep Awake"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenerse despierto"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rester éveillé"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "起きていてください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "깨어 있으십시오"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha-se acordado"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не спать"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止休眠"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止休眠"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "منع سكون النظام في وضع الخمول مع السماح بسكون العرض."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verhindern Sie den Ruhezustand des Systems und ermöglichen Sie gleichzeitig den Ruhezustand des Displays."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prevent idle system sleep while allowing display sleep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Evita que el sistema esté inactivo y al mismo tiempo permite la suspensión de la pantalla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Empêcher la mise en veille du système tout en autorisant la mise en veille de l'affichage."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスプレイのスリープを許可しながら、システムのアイドル状態のスリープを防止します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스플레이 절전을 허용하는 동안 유휴 시스템 절전을 방지합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Evita a suspensão ociosa do sistema enquanto permite a suspensão da tela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предотвращать спящий режим системы, одновременно разрешая спящий режим дисплея."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止系统空闲休眠，允许显示器息屏"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止系統空閒休眠，允許顯示器息螢幕"
          }
        }
      }
    },
    "panel.subtitle.enabled": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ممكّن"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviert"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enabled"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilitado"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성화됨"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativado"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включено"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已启用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已啟用"
          }
        }
      }
    },
    "panel.duration.forever": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أبدًا"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Niemals"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Never"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nunca"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Jamais"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "決して"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "절대로"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nunca"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Никогда"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永不"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "永不"
          }
        }
      }
    },
    "panel.subtitle.remainingMinutesFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتوقف تلقائيًا خلال %d دقيقة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stoppt automatisch in %d Minuten"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stops automatically in %d minutes"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se detiene automáticamente en %d minutos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S'arrête automatiquement dans %d minutes"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 分後に自動的に停止します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%d분 후에 자동으로 중지"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Para automaticamente em %d minutos"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Останавливается автоматически через %d минут"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 分钟后自动停止"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 分鐘後自動停止"
          }
        }
      }
    },

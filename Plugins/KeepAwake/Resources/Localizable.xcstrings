          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stoppt automatisch in %d Stunden %d Minuten"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stops automatically in %d hours %d minutes"
          }
        },
        "es": {
          "stringUnit": {

    "error.invalidEndDate": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجب أن يكون وقت التوقف التلقائي متأخرًا عن الآن."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die automatische Stoppzeit muss später als jetzt liegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The automatic stop time must be later than now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La hora de parada automática debe ser posterior a la actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'heure d'arrêt automatique doit être postérieure à celle actuelle."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動停止時刻は現在より遅くする必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동 정지 시간은 지금보다 이후여야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O horário de parada automática deve ser posterior ao atual."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Время автоматической остановки должно быть позже, чем сейчас."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动停止时间必须晚于当前时间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動停止時間必須晚於當前時間。"
          }
        }
      }
    },
    "error.assertionCreationFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على إبقاء النظام نشطًا. خطأ في النظام %d."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das System kann nicht wach gehalten werden. Systemfehler %d."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to keep the system awake. System error %d."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede mantener el sistema despierto. Error del sistema %d."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de maintenir le système éveillé. Erreur système %d."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムを起動状態に保つことができません。システム エラー %d。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템을 활성 상태로 유지할 수 없습니다. 시스템 오류 %d."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não é possível manter o sistema ativado. Erro de sistema %d."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Невозможно поддерживать бодрствование системы. Системная ошибка %d."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法启用阻止休眠，系统返回错误 %d。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法啟用阻止休眠，系統返回錯誤 %d。"
          }
        }
      }
    }
  },
  "version": "1.0"
}

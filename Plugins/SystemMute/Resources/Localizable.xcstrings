    "error.muteFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل كتم الصوت."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio konnte nicht stummgeschaltet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to mute audio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo silenciar el audio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la mise en sourdine du son."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声をミュートできませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오디오를 음소거하지 못했습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao silenciar o áudio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось отключить звук."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "静音操作失败"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "靜音操作失敗"
          }
        }
      }
    },

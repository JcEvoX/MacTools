{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كتم صوت النظام"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemstummschaltung"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System Mute"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencio del sistema"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Système muet"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムミュート"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 음소거"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema mudo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключение звука"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统静音"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統靜音"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كتم صوت إخراج صوت النظام أو استعادته بسرعة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "System-Audioausgabe schnell stummschalten oder wiederherstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quickly mute or restore system audio output."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencia o restaura rápidamente la salida de audio del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettre ou restaurer rapidement la sortie audio du système."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムオーディオ出力を素早くミュートまたは復元します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 오디오 출력을 빠르게 음소거하거나 복원합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Silencie ou restaure rapidamente a saída de áudio do sistema."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Быстро отключить или восстановить звук системы."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速静音或恢复系统音频输出"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速靜音或恢復系統音頻輸出"
          }
        }
      }
    },

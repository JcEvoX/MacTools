            "value": "فشل إلغاء كتم الصوت."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Stummschaltung des Tons konnte nicht aufgehoben werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to unmute audio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo reactivar el audio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la réactivation du son."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声のミュートを解除できませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오디오 음소거를 해제하지 못했습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao ativar o som do áudio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось включить звук."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "取消静音失败"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",

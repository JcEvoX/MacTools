    "editor.missingFile.createDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقر على إنشاء ملف لإنشاء %@ في مجلدك الرئيسي مع تعليقات توضيحية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicken Sie auf „Datei erstellen“, um %@ mit erklärenden Kommentaren im Home-Ordner zu erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click Create File to create %@ in your home folder with explanatory comments."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en Crear archivo para crear %@ en tu carpeta de inicio con comentarios explicativos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur Créer un fichier pour créer %@ dans votre dossier personnel avec des commentaires explicatifs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「ファイルを作成」をクリックすると、ホームフォルダに説明コメント付きの %@ を作成します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일 생성을 클릭하면 홈 폴더에 설명 주석과 함께 %@이(가) 생성됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique em Criar arquivo para criar %@ na sua pasta pessoal com comentários explicativos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите «Создать файл», чтобы создать %@ в домашней папке с поясняющими комментариями."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击“创建文件”将在家目录生成 %@ 并填入说明注释。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按一下「建立檔案」會在個人資料夾建立 %@，並填入說明註解。"
          }
        }
      }
    },
    "editor.missingFile.readOnlyDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المجلد الرئيسي غير قابل للكتابة، لذلك لا يمكن إنشاء هذا الملف. تحقق من أذونات القرص."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Home-Ordner ist nicht beschreibbar. Diese Datei kann nicht erstellt werden. Prüfen Sie die Zugriffsrechte."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your home folder is not writable, so this file cannot be created. Check disk permissions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu carpeta de inicio no permite escritura, por lo que no se puede crear este archivo. Revisa los permisos del disco."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre dossier personnel n’est pas accessible en écriture. Impossible de créer ce fichier. Vérifiez les autorisations du disque."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホームフォルダに書き込めないため、このファイルを作成できません。ディスクのアクセス権を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "홈 폴더에 쓸 수 없어 이 파일을 만들 수 없습니다. 디스크 권한을 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua pasta pessoal não permite gravação, então este arquivo não pode ser criado. Verifique as permissões do disco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Домашняя папка недоступна для записи, поэтому файл нельзя создать. Проверьте права доступа к диску."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "家目录不可写，无法创建此文件。请检查磁盘权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "個人資料夾不可寫入，無法建立此檔案。請檢查磁碟權限。"
          }
        }
      }
    },

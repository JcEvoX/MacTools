    "editor.action.save.help": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم حفظ نسخة احتياطية باسم %@.bak قبل الكتابة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vor dem Schreiben wird eine Sicherung als %@.bak gespeichert"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A backup is saved as %@.bak before writing"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se guarda una copia como %@.bak antes de escribir"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une sauvegarde %@.bak est créée avant l’écriture"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書き込み前に %@.bak としてバックアップします"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "쓰기 전에 %@.bak로 백업됩니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Um backup é salvo como %@.bak antes de gravar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед записью создается резервная копия %@.bak"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存前会自动备份为 %@.bak"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "儲存前會自動備份為 %@.bak"
          }
        }
      }
    },

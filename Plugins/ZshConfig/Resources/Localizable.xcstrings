{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "configuration.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعرض وحرر ملفات إعداد zsh داخل التطبيق، مع إدراج سريع للمقتطفات الشائعة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "zsh-Konfigurationsdateien in der App anzeigen und bearbeiten, mit Schnelleinfügung häufiger Snippets."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View and edit zsh config files in the app, with quick insertion for common snippets."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve y edita archivos de config. zsh en la app, con inserción rápida de fragmentos comunes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affichez et modifiez les fichiers de config. zsh dans l’app, avec insertion rapide d’extraits courants."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "App 内で zsh 設定ファイルを表示、編集し、よく使うスニペットをすばやく挿入できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱에서 zsh 설정 파일을 보고 편집하며, 자주 쓰는 스니펫을 빠르게 삽입합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja e edite arquivos de config. zsh no app, com inserção rápida de trechos comuns."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просматривайте и редактируйте файлы zsh в приложении, быстро вставляя типовые фрагменты."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在应用内查看和编辑 zsh 配置文件，并快速插入常用片段。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 App 內檢視和編輯 zsh 設定檔，並快速插入常用片段。"
          }
        }
      }
    },
    "editor.action.createFile": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إنشاء ملف"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Datei erstellen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create File"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crear archivo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créer un fichier"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルを作成"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일 생성"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Criar arquivo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создать файл"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建文件"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "建立檔案"
          }
        }
      }
    },
    "editor.action.openExternal": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فتح في محرر النظام"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im Systemeditor öffnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open in System Editor"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir en el editor del sistema"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrir dans l’éditeur système"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムエディタで開く"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 편집기에서 열기"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir no editor do sistema"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открыть в системном редакторе"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在系统编辑器中打开"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在系統編輯器中開啟"
          }
        }
      }
    },
    "editor.action.openExternal.help": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح هذا الملف في محرر النصوص الافتراضي"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Datei im Standard-Texteditor öffnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open this file in the default text editor"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre este archivo en el editor de texto predeterminado"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrir ce fichier dans l’éditeur de texte par défaut"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このファイルをデフォルトのテキストエディタで開く"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 파일을 기본 텍스트 편집기에서 열기"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra este arquivo no editor de texto padrão"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открыть файл в текстовом редакторе по умолчанию"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在系统默认文本编辑器中打开此文件"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在系統預設文字編輯器中開啟此檔案"
          }
        }
      }
    },

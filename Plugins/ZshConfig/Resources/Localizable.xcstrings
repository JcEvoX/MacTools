    "store.header.reloadHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد الحفظ، شغّل %@ في Terminal لتطبيق التغييرات فوراً (.zshrc فقط)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach dem Speichern %@ in Terminal ausführen, um Änderungen sofort zu übernehmen (nur .zshrc)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After saving, run %@ in Terminal to apply changes immediately (.zshrc only)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Después de guardar, ejecuta %@ en Terminal para aplicar los cambios de inmediato (solo .zshrc)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après l’enregistrement, exécutez %@ dans Terminal pour appliquer immédiatement les changements (.zshrc uniquement)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存後、ターミナルで %@ を実行するとすぐに反映されます（.zshrc のみ）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장 후 터미널에서 %@을(를) 실행하면 변경 사항이 즉시 적용됩니다(.zshrc만)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Depois de salvar, execute %@ no Terminal para aplicar as alterações imediatamente (somente .zshrc)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "После сохранения выполните %@ в Terminal, чтобы сразу применить изменения (только .zshrc)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存后，在终端执行 %@ 即可立即生效（仅 .zshrc）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "儲存後，在終端機執行 %@ 即可立即生效（僅 .zshrc）。"
          }
        }
      }
    },

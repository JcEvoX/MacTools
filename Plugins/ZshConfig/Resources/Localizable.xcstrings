    "editor.emptyFile.placeholder": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الملف فارغ. اكتب هنا أو انتقل إلى الإدراج السريع لإضافة إعدادات شائعة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Datei ist leer. Hier tippen oder per Schnelleinfügung häufige Einstellungen hinzufügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file is empty. Type here, or switch to Quick Insert to add common settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo está vacío. Escribe aquí o usa Inserción rápida para añadir ajustes comunes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier est vide. Saisissez du texte ici ou utilisez Insertion rapide pour ajouter des réglages courants."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルは空です。ここに入力するか、クイック挿入でよく使う設定を追加します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일이 비어 있습니다. 여기에 입력하거나 빠른 삽입으로 일반 설정을 추가하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivo está vazio. Digite aqui ou use Inserção rápida para adicionar ajustes comuns."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Файл пуст. Введите текст здесь или откройте быструю вставку для типовых настроек."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件为空。可直接输入，或切换到“快速插入”添加常用配置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "檔案是空的。可直接輸入，或切換到「快速插入」加入常用設定。"
          }
        }
      }
    },
    "editor.fileInfo.help": {
      "extractionState": "manual",
      "localizations": {
        "ar": {

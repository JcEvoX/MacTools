    "editor.savedHint.reloadDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شغّل هذا لتطبيق التغييرات دون إعادة تشغيل Terminal."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausführen, um Änderungen ohne Neustart von Terminal zu übernehmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Run this to apply changes without restarting Terminal."
          }

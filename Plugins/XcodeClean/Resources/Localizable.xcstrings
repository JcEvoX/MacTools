    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تنظيف DerivedData ودعم الأجهزة والأرشيفات وذاكرات Xcode المؤقتة حسب الفئة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Xcode-DerivedData, Geräteunterstützung, Archive und Caches nach Kategorie bereinigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clean Xcode DerivedData, device support files, archives, and caches by category."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpia DerivedData, soporte de dispositivos, archivos y cachés de Xcode por categoría."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nettoie DerivedData, la prise en charge d’appareils, les archives et les caches Xcode par catégorie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Xcode の DerivedData、デバイスサポート、アーカイブ、キャッシュをカテゴリ別に整理します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Xcode DerivedData, 기기 지원 파일, 아카이브 및 캐시를 분류별로 정리합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpa DerivedData, suporte de dispositivos, arquivos e caches do Xcode por categoria."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очищает DerivedData, файлы поддержки устройств, архивы и кэши Xcode по категориям."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分类清理 Xcode DerivedData、设备支持、归档与缓存"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "分類清理 Xcode DerivedData、裝置支援、封存與快取"
          }
        }
      }
    },

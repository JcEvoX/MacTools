    "category.simulatorCaches.summary": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ذاكرات تشغيل المحاكي المؤقتة. لن تتأثر المحاكيات الحالية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laufzeit-Caches des Simulators. Vorhandene Simulatoren sind nicht betroffen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulator runtime caches. Existing simulators are not affected."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cachés de ejecución del simulador. No afectan a los simuladores existentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Caches d’exécution du simulateur. Les simulateurs existants ne sont pas affectés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "シミュレータのランタイムキャッシュ。既存のシミュレータには影響しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시뮬레이터 런타임 캐시입니다. 기존 시뮬레이터에는 영향이 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Caches de tempo de execução do simulador. Simuladores existentes não são afetados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кэши среды симулятора. Существующие симуляторы не затрагиваются."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟器运行时缓存，不影响已创建的模拟器"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模擬器執行階段快取，不影響已建立的模擬器"
          }
        }
      }
    },

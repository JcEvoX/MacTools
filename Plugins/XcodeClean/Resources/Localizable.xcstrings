{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "category.archives.summary": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أرشيفات وملفات dSYM للإصدارات المنشورة. نظّف بحذر."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Archive und dSYM veröffentlichter Builds. Vorsichtig bereinigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Released build archives and dSYM files. Clean with care."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivos y dSYM de compilaciones publicadas. Límpialos con cuidado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Archives et dSYM des builds publiés. Nettoyer avec prudence."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リリース済みビルドのアーカイブと dSYM。慎重に削除してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "릴리스된 빌드의 아카이브 및 dSYM입니다. 신중하게 정리하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Arquivos e dSYM de builds publicados. Limpe com cuidado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Архивы и dSYM выпущенных сборок. Очищайте осторожно."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已发布构建的归档与 dSYM，谨慎清理"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已發布建置的封存與 dSYM，謹慎清理"
          }
        }
      }
    },

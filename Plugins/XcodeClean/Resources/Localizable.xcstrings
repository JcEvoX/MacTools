    "detail.xcodeRunning.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أغلق Xcode لتجنب التأثير على عمليات البناء أو الفهرسة النشطة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beenden Sie Xcode, damit aktive Builds oder Indizes nicht beeinträchtigt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit Xcode to avoid affecting active builds or indexes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cierra Xcode para evitar afectar compilaciones o índices activos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quittez Xcode pour éviter d’affecter les builds ou index actifs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行中のビルドやインデックス作成に影響しないよう、Xcode を終了してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진행 중인 빌드나 인덱스에 영향을 주지 않도록 Xcode를 종료하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Feche o Xcode para evitar afetar builds ou índices ativos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Закройте Xcode, чтобы не повлиять на активные сборки или индексы."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先退出 Xcode，避免影响正在进行的构建或索引。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請先結束 Xcode，避免影響正在進行的建置或索引。"
          }
        }
      }
    },

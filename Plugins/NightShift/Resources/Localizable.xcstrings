    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تقليل الضوء الأزرق وجعل ألوان العرض أكثر دفئًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reduzieren Sie blaues Licht und machen Sie die Displayfarben wärmer."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reduce blue light and make display colors warmer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reduce la luz azul y hace que los colores de la pantalla sean más cálidos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réduisez la lumière bleue et réchauffez les couleurs de l'écran."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブルーライトを軽減し、ディスプレイの色を温かみのある色にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "블루라이트를 줄이고 디스플레이 색상을 더 따뜻하게 만듭니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reduza a luz azul e torne as cores da tela mais quentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уменьшите количество синего света и сделайте цвета дисплея теплее."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "降低蓝光，使屏幕颜色更暖"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "降低藍光，使螢幕顏色更暖"
          }
        }
      }
    },

{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "error.helperInstall.authorizationScriptUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على إنشاء البرنامج النصي للتفويض."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Autorisierungsskript konnte nicht erstellt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to create the authorization script."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede crear el script de autorización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de créer le script d'autorisation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認可スクリプトを作成できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인증 스크립트를 생성할 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível criar o script de autorização."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Невозможно создать скрипт авторизации."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法创建授权脚本"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法創建授權腳本"
          }
        }
      }
    },
    "error.helperInstall.missingAfterInstall": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يزال يتعذر العثور على المكون بعد التثبيت."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Komponente kann nach der Installation immer noch nicht gefunden werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The component still cannot be found after installation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no se puede encontrar el componente después de la instalación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le composant est toujours introuvable après l'installation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インストール後もコンポーネントが見つかりません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설치 후에도 구성 요소를 찾을 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O componente ainda não foi encontrado após a instalação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Компонент по-прежнему не найден после установки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安装后仍无法找到组件"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "安裝後仍無法找到組件"
          }
        }
      }
    },
    "error.helperInstallFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل تثبيت مكون التحكم في البطارية: %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Batteriesteuerungskomponente konnte nicht installiert werden: %@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to install battery control component: %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error al instalar el componente de control de batería: %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'installation du composant de contrôle de la batterie : %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バッテリー制御コンポーネントのインストールに失敗しました: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "배터리 제어 구성요소 설치 실패: %@"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao instalar o componente de controle da bateria: %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось установить компонент управления аккумулятором: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安装电池控制组件失败：%@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "安裝電池控制組件失敗：%@"
          }
        }
      }
    },
    "error.helperNotFound": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم العثور على مكون التحكم في البطارية المجمع. أعد تثبيت المكوّن الإضافي Battery Charge Limit."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die mitgelieferte Batteriesteuerungskomponente wurde nicht gefunden. Installieren Sie das Plugin „Battery Charge Limit“ neu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The bundled battery control component was not found. Reinstall the Battery Charge Limit plugin."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontró el componente de control de batería incluido. Vuelva a instalar el complemento Límite de carga de la batería."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le composant de contrôle de batterie fourni est introuvable. Réinstallez le plug-in Battery Charge Limit."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バンドルされているバッテリー制御コンポーネントが見つかりませんでした。 Battery Charge Limit プラグインを再インストールします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "번들 배터리 제어 구성 요소를 찾을 수 없습니다. 배터리 충전 제한 플러그인을 다시 설치하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O componente de controle da bateria incluído não foi encontrado. Reinstale o plug-in Battery Charge Limit."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Входящий в комплект поставки компонент управления аккумулятором не найден. Переустановите плагин ограничения заряда батареи."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到内置电池控制组件。请重新安装电池充电上限插件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到內置電池控制組件。請重新安裝電池充電上限外掛。"
          }
        }
      }
    },
    "error.helperVerificationFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل التحقق من مكون التحكم في البطارية. أعد تثبيت المكوّن الإضافي Battery Charge Limit."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überprüfung der Batteriesteuerungskomponente fehlgeschlagen. Installieren Sie das Plugin „Battery Charge Limit“ neu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery control component verification failed. Reinstall the Battery Charge Limit plugin."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error en la verificación del componente de control de la batería. Vuelva a instalar el complemento Límite de carga de la batería."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La vérification des composants de contrôle de la batterie a échoué. Réinstallez le plug-in Battery Charge Limit."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バッテリー制御コンポーネントの検証に失敗しました。 Battery Charge Limit プラグインを再インストールします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "배터리 제어 구성 요소 확인에 실패했습니다. 배터리 충전 제한 플러그인을 다시 설치하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha na verificação do componente de controle da bateria. Reinstale o plug-in Battery Charge Limit."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка компонента управления аккумулятором не удалась. Переустановите плагин ограничения заряда батареи."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "电池控制组件校验失败。请重新安装电池充电上限插件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "電池控制組件校驗失敗。請重新安裝電池充電上限外掛。"
          }
        }
      }
    },
    "error.noSupportedSMCKey": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يعرض برنامج Mac الثابت هذا مفتاحًا للتحكم في الشحن قابلاً للكتابة. ربما قام نظام التشغيل macOS بتغيير الدعم في هذا الإصدار."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Mac-Firmware stellt keinen beschreibbaren Ladekontrollschlüssel zur Verfügung. Möglicherweise hat macOS in dieser Version die Unterstützung geändert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac firmware does not expose a writable charge control key. macOS may have changed support in this version."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este firmware de Mac no expone una clave de control de carga grabable. Es posible que macOS haya cambiado la compatibilidad en esta versión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce micrologiciel Mac n'expose pas de clé de contrôle de charge inscriptible. macOS a peut-être changé de prise en charge dans cette version."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac ファームウェアは書き込み可能な充電制御キーを公開しません。 macOS は、このバージョンでのサポートが変更されている可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac 펌웨어는 쓰기 가능한 충전 제어 키를 노출하지 않습니다. macOS가 이 버전에서 지원을 변경했을 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este firmware Mac não expõe uma chave de controle de carga gravável. O macOS pode ter alterado o suporte nesta versão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта прошивка Mac не предоставляет записываемый ключ управления зарядом. Поддержка macOS в этой версии могла быть изменена."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 Mac 固件未提供可写的充电控制键。可能是 macOS 已升级到不支持的版本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前 Mac 固件未提供可寫的充電控制鍵。可能是 macOS 已升級到不支持的版本。"
          }
        }
      }
    },
    "error.write.inhibitCharging": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على إيقاف الشحن"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ladevorgang konnte nicht gestoppt werden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to stop charging"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede detener la carga"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'arrêter la charge"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "充電を停止できません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "충전을 중지할 수 없습니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não é possível interromper o carregamento"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Невозможно остановить зарядку"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法停止充电"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法停止充電"
          }
        }
      }
    },
    "error.write.resumeCharging": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على استئناف الشحن"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ladevorgang kann nicht fortgesetzt werden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to resume charging"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede reanudar la carga"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de reprendre le chargement"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "充電を再開できません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "충전을 재개할 수 없습니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não é possível retomar o carregamento"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Невозможно возобновить зарядку"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法恢复充电"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法恢復充電"
          }
        }
      }
    },
    "error.write.toggleDischarge": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على تبديل وضع التفريغ"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entlademodus kann nicht umgeschaltet werden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to switch discharge mode"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede cambiar el modo de descarga"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de changer de mode de décharge"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "放電モードを切り替えられません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "방전 모드를 전환할 수 없습니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não é possível alternar o modo de descarga"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Невозможно переключить режим разрядки"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法切换放电模式"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法切換放電模式"
          }
        }
      }
    },
    "error.writeFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشلت كتابة حالة التحكم في البطارية: %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Batteriekontrollstatus konnte nicht geschrieben werden: %@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to write battery control state: %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error al escribir el estado de control de la batería: %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'écriture de l'état de contrôle de la batterie : %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バッテリー制御状態の書き込みに失敗しました: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "배터리 제어 상태를 쓰지 못했습니다: %@"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao gravar o estado de controle da bateria: %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось записать состояние управления батареей: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "写入充电控制失败：%@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "寫入充電控制失敗：%@"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الحد من شحن البطارية إلى المستوى المختار."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Begrenzen Sie die Akkuladung auf ein ausgewähltes Niveau."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Limit battery charging to a chosen level."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Limite la carga de la batería a un nivel elegido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Limiter la charge de la batterie à un niveau choisi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バッテリーの充電を選択したレベルに制限します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "배터리 충전을 선택한 수준으로 제한하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Limite o carregamento da bateria a um nível escolhido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ограничить зарядку аккумулятора до выбранного уровня."
          }
        },
        "zh-Hans": {

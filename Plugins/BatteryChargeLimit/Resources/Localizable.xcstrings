{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "error.helperInstall.authorizationScriptUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to create the authorization script."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法创建授权脚本"
          }
        }
      }
    },
    "error.helperInstall.missingAfterInstall": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The component still cannot be found after installation."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安装后仍无法找到组件"
          }
        }
      }
    },
    "error.helperInstallFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to install battery control component: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安装电池控制组件失败：%@"
          }
        }
      }
    },
    "error.helperNotFound": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The bundled battery control component was not found. Reinstall the Battery Charge Limit plugin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到内置电池控制组件。请重新安装电池充电上限插件。"
          }
        }
      }
    },
    "error.helperVerificationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery control component verification failed. Reinstall the Battery Charge Limit plugin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "电池控制组件校验失败。请重新安装电池充电上限插件。"
          }
        }
      }
    },
    "error.noSupportedSMCKey": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac firmware does not expose a writable charge control key. macOS may have changed support in this version."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 Mac 固件未提供可写的充电控制键。可能是 macOS 已升级到不支持的版本。"
          }
        }
      }
    },
    "error.write.inhibitCharging": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to stop charging"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法停止充电"
          }
        }
      }
    },
    "error.write.resumeCharging": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to resume charging"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法恢复充电"
          }
        }
      }
    },
    "error.write.toggleDischarge": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to switch discharge mode"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法切换放电模式"
          }
        }
      }
    },
    "error.writeFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to write battery control state: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "写入充电控制失败：%@"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Limit battery charging to a chosen level."
          }

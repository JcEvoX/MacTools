          }
        }
      }
    },
    "panel.action.missingHelper": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery control component missing"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "电池控制组件缺失"

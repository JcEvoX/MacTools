          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "充电上限"
          }
        }
      }
    },
    "panel.subtitle.charging": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Charging · %d%% → %d%%"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "充电中 · %d%% → %d%%"
          }
        }
      }
    },
    "panel.subtitle.chargingStopped": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Charging stopped · %d%% / %d%%"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已停止充电 · %d%% / %d%%"
          }
        }
      }
    },
    "panel.subtitle.disabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Off · %d%%"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未启用 · %d%%"
          }
        }
      }
    },
    "panel.subtitle.discharging": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discharging · %d%% → %d%%"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "放电中 · %d%% → %d%%"
          }
        }
      }
    },
    "panel.subtitle.limitReached": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Limit reached · %d%% / %d%%"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已达上限 · %d%% / %d%%"
          }
        }
      }
    },
    "panel.subtitle.noBattery": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No battery detected"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未检测到电池"
          }
        }
      }
    },
    "settings.behavior.noAutoResume.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When the battery drops below the limit, charging will not resume automatically. Click \"Start Charging\" in the menu bar when you want to continue. This differs from macOS Optimized Battery Charging, which keeps trickle charging near the limit."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "电量低于上限时不会自动充电，需要在菜单栏点击「开始充电」才会继续。这与系统自带的「优化电池充电」不同——系统会持续微充电以贴近上限。"
          }
        }
      }
    },
    "settings.behavior.noAutoResume.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Do Not Resume Automatically"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不自动恢复充电"
          }
        }
      }
    },
    "settings.behavior.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Charging Behavior"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "充电行为"
          }
        }
      }
    },
    "settings.compatibility.controlMethod": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Charge Control Method"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "充电控制方式"
          }
        }
      }
    },
    "settings.compatibility.forceDischarge": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Force Discharge"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "强制放电"
          }
        }
      }
    },
    "settings.compatibility.forceDischarge.supported": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Supported (CH0I)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "支持（CH0I）"
          }
        }
      }
    },
    "settings.compatibility.intelLimit.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac only supports BCLM. When the battery drops below the limit, the system may still charge it back to the limit. The \"do not resume automatically\" behavior cannot be guaranteed on Intel Macs."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 Mac 仅支持 BCLM，电量低于上限时仍可能被系统自动充至上限。「不自动恢复」语义在 Intel Mac 上无法保证。"
          }
        }
      }
    },
    "settings.compatibility.intelLimit.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Intel Mac Limitation"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Intel Mac 限制"
          }
        }
      }
    },
    "settings.compatibility.noSMCKey": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No available SMC charge control key detected"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未检测到可用的 SMC 充电控制键"
          }
        }
      }
    },
    "settings.compatibility.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hardware Compatibility"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "硬件兼容"
          }
        }
      }
    },
    "settings.limit.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Charging stops automatically at this level."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "达到此电量后自动停止充电。"
          }
        }
      }
    },
    "settings.limit.target": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Target Level"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目标电量"
          }
        }
      }
    },
    "settings.limit.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Charge Limit"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "充电上限"
          }
        }
      }
    }
  },
  "version": "1.0"
}

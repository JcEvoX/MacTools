{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إخفاء النوتش"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kerbe ausblenden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hide Notch"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar muesca"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquer l'encoche"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ノッチを隠す"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "노치 숨기기"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar entalhe"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скрыть вырез"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏刘海"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "隱藏劉海"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إخفاء المنطقة العلوية المحيطة بحز الشاشة تلقائيًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Maskieren Sie automatisch den oberen Bereich um eine Anzeigekerbe."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatically mask the top area around a display notch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enmascare automáticamente el área superior alrededor de una muesca de la pantalla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquer automatiquement la zone supérieure autour d'une encoche d'affichage."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスプレイ ノッチの周囲の上部領域を自動的にマスクします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스플레이 노치 주변의 상단 영역을 자동으로 마스킹합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mascarar automaticamente a área superior ao redor de um entalhe da tela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически маскировать верхнюю область вокруг выреза дисплея."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动遮挡刘海屏顶部区域"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動遮擋劉海螢幕頂部區域"
          }
        }
      }
    },
    "panel.subtitle.enabled": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تشغيل"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activado"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オン"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜기"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativado"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включено"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已开启"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已開啟"
          }
        }
      }
    },
    "panel.subtitle.noSupportedDisplay": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم اكتشاف شاشة مسننة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine gekerbte Anzeige erkannt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No notched display detected"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se detectó ninguna pantalla con muescas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun affichage cranté détecté"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ノッチ付きディスプレイが検出されませんでした"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "노치 디스플레이가 감지되지 않음"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma tela com entalhe detectada"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дисплей с вырезом не обнаружен"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未检测到刘海屏"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未檢測到劉海螢幕"
          }
        }
      }
    },
    "panel.subtitle.closing": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إيقاف"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausschalten"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turning off"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apagar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactiver"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフにします"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "끄는 중"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Desligando"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выключение"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在关闭"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在關閉"
          }
        }
      }
    },
    "error.maskWindowCreationFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على إنشاء طبقة قناع الشق."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Kerbmaskenebene konnte nicht erstellt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to create the notch mask layer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede crear la capa de máscara de muesca."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de créer le calque de masque d'entaille."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ノッチ マスク レイヤを作成できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "노치 마스크 레이어를 생성할 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível criar a camada de máscara de entalhe."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Невозможно создать слой маски выреза."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法创建隐藏刘海遮挡层。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法創建隱藏劉海遮擋層。"
          }
        }
      }
    },
    "error.maskWindowCreationFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على إنشاء طبقة قناع الشق لـ %@: %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kerbmaskenebene für %@: %@ konnte nicht erstellt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to create the notch mask layer for %@: %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede crear la capa de máscara de muesca para %@: %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de créer le calque de masque d'encoche pour %@ : %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ のノッチ マスク レイヤを作成できません: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@에 대한 노치 마스크 레이어를 생성할 수 없습니다: %@"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não é possível criar a camada de máscara de entalhe para %@: %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Невозможно создать слой маски выреза для %@: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法为 %@ 创建刘海遮挡层：%@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法為 %@ 創建劉海遮擋層：%@"
          }
        }
      }
    }
  },
  "version": "1.0"
}

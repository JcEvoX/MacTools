    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatically mask the top area around a display notch."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动遮挡刘海屏顶部区域"

    "speed.waiting.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بالتحديث لقياس التنزيل والتحميل ووقت الاستجابة والاستجابة بالتسلسل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktualisieren, um Download, Upload, Latenz und Reaktionsfähigkeit nacheinander zu messen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refresh to measure download, upload, latency, and responsiveness in sequence."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualice para medir la descarga, carga, latencia y capacidad de respuesta en secuencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualisez pour mesurer le téléchargement, l’envoi, la latence et la réactivité dans l’ordre."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "更新して、ダウンロード、アップロード、遅延、応答性を順番に測定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드, 업로드, 대기 시간 및 응답성을 순서대로 측정하려면 새로고침하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualize para medir download, upload, latência e capacidade de resposta em sequência."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновите, чтобы последовательно измерить загрузку, выгрузку, задержку и скорость отклика."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击刷新后，会顺序测量下载、上传、延迟和响应性。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊刷新後，會順序測量下載、上傳、延遲和響應性。"
          }
        }
      }
    },

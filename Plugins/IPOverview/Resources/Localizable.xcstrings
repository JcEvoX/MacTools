    "privacy.footer": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تطلب عمليات التحقق من عنوان IP العام والموقع والاتصال خدمات خارجية. تتم قراءة العناوين المحلية على جهاز Mac هذا فقط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffentliche IP-, Standort- und Konnektivitätsprüfungen fordern externe Dienste an. Lokale Adressen sind auf diesem Mac schreibgeschützt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Public IP, location, and connectivity checks request external services. Local addresses are read only on this Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las comprobaciones de conectividad, ubicación y IP pública solicitan servicios externos. Las direcciones locales son de solo lectura en esta Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les vérifications d'adresse IP publique, d'emplacement et de connectivité nécessitent des services externes. Les adresses locales sont en lecture seule sur ce Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パブリック IP、所在地、接続の検査では外部サービスへリクエストします。ローカルアドレスはこの Mac 上でのみ読み取られます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "공용 IP, 위치, 연결 확인을 통해 외부 서비스를 요청합니다. 이 Mac에서는 로컬 주소를 읽을 수만 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As verificações de IP público, localização e conectividade solicitam serviços externos. Os endereços locais são somente leitura neste Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверки публичного IP, местоположения и подключения обращаются к внешним службам. Локальные адреса считываются только на этом Mac."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "公网、归属地和连通性检测会请求外部服务；本地地址仅在本机读取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "公網、歸屬地和連通性檢測會請求外部服務；本地地址僅在本機讀取。"
          }
        }
      }
    },

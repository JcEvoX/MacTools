    "webrtc.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WebRTC often establishes direct UDP connections. If this test returns your real IP, your proxy settings are not covering those connections. In addition to checking the IP used for WebRTC, it also checks your NAT type. NAT detection is not 100% accurate and is only for reference."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "WebRTC 往往通过 UDP 直连进行建立，如果测试返回了真实 IP，则意味着你的代理设置没有覆盖这些连接。除了检测你连接 WebRTC 时所使用的 IP，我们还会检测你的 NAT 类型。然而，NAT 类型的检测并不是 100% 准确的，仅供参考。"
          }
        }
      }
    },

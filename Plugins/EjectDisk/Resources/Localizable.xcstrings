  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eject Disks"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "推出磁盘"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eject all removable disks."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "推出所有可移动磁盘"
          }
        }
      }
    },
    "panel.button.eject": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eject"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "推出"
          }
        }
      }
    },
    "panel.subtitle.ejecting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejecting…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "推出中..."
          }
        }
      }
    },
    "panel.subtitle.none": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No ejectable disks"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无可推出的磁盘"
          }
        }
      }
    },

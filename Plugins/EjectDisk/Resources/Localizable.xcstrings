      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d ejectable disks"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 个可推出的磁盘"
          }
        }
      }
    },
    "error.volumesUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The /Volumes directory is unavailable."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "/Volumes 目录不可用"
          }
        }
      }

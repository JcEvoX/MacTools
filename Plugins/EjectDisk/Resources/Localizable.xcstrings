    "error.partialFailureFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إخراج %d من الأقراص. %d فشل:\n%@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgeworfene %d Datenträger. %d fehlgeschlagen:\n%@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejected %d disks. %d failed:\n%@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Discos %d expulsados. %d falló:\n%@"
          }

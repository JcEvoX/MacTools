    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أخرج كافة الأقراص القابلة للإزالة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Wechseldatenträger auswerfen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eject all removable disks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Expulse todos los discos extraíbles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Éjectez tous les disques amovibles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのリムーバブル ディスクを取り出します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 이동식 디스크를 꺼냅니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ejete todos os discos removíveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Извлечь все съемные диски."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "推出所有可移动磁盘"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "推出所有可移動磁盤"
          }
        }
      }
    },

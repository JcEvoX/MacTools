{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Middle Click"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟鼠标中键"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn trackpad taps into middle-clicks."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "触控板轻点 → 模拟鼠标中键"
          }
        }
      }
    },
    "panel.subtitle.enabledFingerCountFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d-finger tap → middle-click"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "触控板%d指轻点 → 鼠标中键"
          }
        }
      }
    },
    "panel.subtitle.enabledDefault": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Three-finger tap → middle-click"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "触控板三指轻点 → 鼠标中键"
          }
        }
      }
    },
    "panel.subtitle.needsAccessibility": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Requires Accessibility permission"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用前需要辅助功能授权"
          }
        }
      }
    },
    "permission.accessibility.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能授权"
          }
        }
      }
    },
    "permission.accessibility.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Middle Click needs Accessibility permission to send mouse events."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟鼠标中键需要辅助功能权限才能正常工作。"
          }
        }
      }
    },
    "permission.accessibility.footnote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open System Settings > Privacy & Security > Accessibility and allow MacTools."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "前往系统设置 → 隐私与安全性 → 辅助功能，授权 MacTools。"
          }
        }
      }
    },
    "error.accessibilityRequired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Middle Click requires Accessibility permission. Grant it in Settings first."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟鼠标中键需要辅助功能权限，请先前往设置完成授权。"
          }
        }
      }
    },
    "settings.section.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置"
          }
        }
      }
    },
    "settings.fingerCount.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Finger Count"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手指数量"
          }
        }
      }
    },
    "settings.fingerCount.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the trackpad with the selected number of fingers to send a middle-click."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用指定数量的手指在触控板上轻点，将模拟鼠标中键点击"
          }
        }
      }
    },
    "settings.fingerCount.optionFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d fingers"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d指"
          }
        }
      }
    }
  },
  "version": "1.0"
}

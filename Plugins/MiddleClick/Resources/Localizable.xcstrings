    "settings.fingerCount.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقر على لوحة التتبع بعدد الأصابع المحدد لإرسال نقرة متوسطة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie mit der ausgewählten Anzahl von Fingern auf das Trackpad, um einen Mittelklick zu senden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the trackpad with the selected number of fingers to send a middle-click."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el trackpad con el número de dedos seleccionado para enviar un clic central."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur le trackpad avec le nombre de doigts sélectionné pour envoyer un clic du milieu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した指の数でトラックパッドをタップして、中クリックを送信します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 손가락 개수로 트랙패드를 탭하여 가운데 클릭을 보냅니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque no trackpad com o número selecionado de dedos para enviar um clique com o botão do meio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Коснитесь трекпада выбранным количеством пальцев, чтобы отправить средний щелчок."
          }

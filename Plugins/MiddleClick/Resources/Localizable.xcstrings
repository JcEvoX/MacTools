{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النقر الأوسط"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mittelklick"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Middle Click"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clic central"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clic du milieu"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Middle Click"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가운데 클릭"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique do meio"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Средний щелчок"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟鼠标中键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模擬滑鼠中鍵"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحويل نقرات لوحة التتبع إلى نقرات متوسطة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwandeln Sie das Tippen auf dem Trackpad in mittlere Klicks."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn trackpad taps into middle-clicks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Convierte los toques del trackpad en clics centrales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Transformez les appuis sur le trackpad en clics du milieu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トラックパッドのタップを中クリックに変えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "트랙패드 탭을 중간 클릭으로 전환하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Transforme os toques do trackpad em cliques do meio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Превратите касания трекпада в щелчки средней кнопкой мыши."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "触控板轻点 → 模拟鼠标中键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "觸控板輕點 → 模擬滑鼠中鍵"
          }
        }
      }
    },
    "panel.subtitle.enabledFingerCountFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%d النقر بإصبعك → النقر الأوسط"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%d-Fingertippen → Mittelklick"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d-finger tap → middle-click"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%d-toque con el dedo → clic central"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%d – appui du doigt → clic du milieu"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%d - 指でタップ → 中クリック"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%d-손가락 탭 → 가운데 클릭"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "%d toque com o dedo → clique com o meio"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%d — нажатие пальца → щелчок средней кнопкой мыши"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "触控板%d指轻点 → 鼠标中键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "觸控板%d指輕點 → 滑鼠中鍵"
          }
        }
      }
    },
    "panel.subtitle.enabledDefault": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النقر بثلاثة أصابع ← النقر الأوسط"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drei-Finger-Tippen → Mittelklick"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Three-finger tap → middle-click"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque con tres dedos → clic central"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez avec trois doigts → clic du milieu"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "3 本指タップ → 中クリック"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세 손가락 탭 → 가운데 클릭"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque com três dedos → clique com o meio"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите тремя пальцами → щелкните средней кнопкой мыши"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "触控板三指轻点 → 鼠标中键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "觸控板三指輕點 → 滑鼠中鍵"
          }
        }
      }
    },
    "panel.subtitle.needsAccessibility": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب إذن الوصول"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfordert die Berechtigung zur Barrierefreiheit"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Requires Accessibility permission"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Requiere permiso de accesibilidad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nécessite une autorisation d'accessibilité"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティ権限が必要です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "접근성 권한이 필요합니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Requer permissão de acessibilidade"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Требуется разрешение на доступ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用前需要辅助功能授权"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用前需要輔助使用授權"
          }
        }
      }
    },
    "permission.accessibility.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إمكانية الوصول"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Barrierefreiheit"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesibilidad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibilité"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "접근성"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Acessibilidade"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступность"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能授权"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輔助使用授權"
          }
        }
      }
    },
    "permission.accessibility.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج النقر الأوسط إلى إذن الوصول لإرسال أحداث الماوس."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mittleres Klicken benötigt die Berechtigung „Barrierefreiheit“, um Mausereignisse zu senden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Middle Click needs Accessibility permission to send mouse events."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El clic central necesita permiso de Accesibilidad para enviar eventos del mouse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le clic du milieu nécessite l'autorisation d'accessibilité pour envoyer des événements de souris."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "中クリックでマウス イベントを送信するには、アクセシビリティ権限が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마우스 이벤트를 보내려면 가운데 클릭에 대한 접근성 권한이 필요합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O clique do meio precisa de permissão de acessibilidade para enviar eventos de mouse."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для отправки событий мыши среднему клику требуется разрешение на доступ к специальным возможностям."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟鼠标中键需要辅助功能权限才能正常工作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模擬滑鼠中鍵需要輔助使用權限才能正常工作。"
          }
        }
      }
    },
    "permission.accessibility.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح إعدادات النظام > الخصوصية والأمان > إمكانية الوصول واسمح بـ MacTools."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnen Sie Systemeinstellungen > Datenschutz und Sicherheit > Barrierefreiheit und erlauben Sie MacTools."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open System Settings > Privacy & Security > Accessibility and allow MacTools."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre Configuración del sistema > Privacidad y seguridad > Accesibilidad y permite MacTools."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez Paramètres système > Confidentialité et sécurité > Accessibilité et autorisez MacTools."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "[システム設定] > [プライバシーとセキュリティ] > [アクセシビリティ] を開き、MacTools を許可します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정 > 개인 정보 보호 및 보안 > 접근성을 열고 MacTools을(를) 허용하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra Configurações do sistema > Privacidade e segurança > Acessibilidade e permita MacTools."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте «Настройки системы» > «Конфиденциальность и безопасность» > «Доступность» и разрешите MacTools."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "前往系统设置 → 隐私与安全性 → 辅助功能，授权 MacTools。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "前往系統設定 → 隱私權與安全性 → 輔助使用，授權 MacTools。"
          }
        }
      }
    },
    "error.accessibilityRequired": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب النقر الأوسط الحصول على إذن الوصول. امنحها في الإعدادات أولاً."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mittleres Klicken ist eine Barrierefreiheitsberechtigung erforderlich. Gewähren Sie es zuerst in den Einstellungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Middle Click requires Accessibility permission. Grant it in Settings first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El clic central requiere permiso de accesibilidad. Concédelo primero en Configuración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le clic du milieu nécessite une autorisation d'accessibilité. Accordez-le d'abord dans les paramètres."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "中クリックにはアクセシビリティ権限が必要です。まず設定で許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가운데 클릭을 하면 접근성 권한이 필요합니다. 먼저 설정에서 부여하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O clique do meio requer permissão de acessibilidade. Conceda-o primeiro nas configurações."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Средним щелчком мыши требуется разрешение специальных возможностей. Сначала разрешите это в настройках."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模拟鼠标中键需要辅助功能权限，请先前往设置完成授权。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模擬滑鼠中鍵需要輔助使用權限，請先前往設定完成授權。"
          }
        }
      }
    },

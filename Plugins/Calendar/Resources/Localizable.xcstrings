    "permission.automation.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتحكم في تطبيق تقويم النظام لفتح التاريخ المحدد عند النقر فوق يوم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Steuert die Kalender-App des Systems, um das ausgewählte Datum zu öffnen, wenn Sie auf einen Tag klicken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Controls the system Calendar app to open the selected date when you click a day."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla la aplicación Calendario del sistema para abrir la fecha seleccionada cuando haces clic en un día."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Contrôle l'application Calendrier du système pour ouvrir la date sélectionnée lorsque vous cliquez sur un jour."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "日付をクリックすると、選択した日付が開くようにシステム カレンダー アプリを制御します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "날짜를 클릭하면 선택한 날짜가 열리도록 시스템 캘린더 앱을 제어합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla o aplicativo Calendário do sistema para abrir a data selecionada quando você clica em um dia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Управляет системным приложением «Календарь», открывая выбранную дату при нажатии на день."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击日期时需要控制系统日历应用，打开并定位到对应日期。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊日期時需要控制系統日曆App，打開並定位到對應日期。"
          }
        }
      }
    },
    "permission.automation.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيطلب نظام التشغيل macOS الإذن للتحكم في التقويم في المرة الأولى التي تفتح فيها تاريخًا. إذا رفضت ذلك من قبل، فاسمح بذلك في إعدادات التشغيل الآلي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS bittet Sie um Erlaubnis, den Kalender zu steuern, wenn Sie zum ersten Mal ein Datum öffnen. Wenn Sie es zuvor abgelehnt haben, lassen Sie es in den Automatisierungseinstellungen zu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS will ask for permission to control Calendar the first time you open a date. If you denied it before, allow it in Automation settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS le pedirá permiso para controlar el Calendario la primera vez que abra una fecha. Si lo negaste antes, permítelo en la configuración de Automatización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS demandera l'autorisation de contrôler le calendrier la première fois que vous ouvrirez une date. Si vous l'avez déjà refusé, autorisez-le dans les paramètres d'automatisation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS は、日付を初めて開くときに、カレンダーを制御する許可を求めます。以前に拒否した場合は、オートメーション設定で許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS는 날짜를 처음 열 때 캘린더 제어 권한을 요청합니다. 이전에 거부했다면 자동화 설정에서 허용하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O macOS solicitará permissão para controlar o Calendário na primeira vez que você abrir uma data. Se você negou antes, permita nas configurações de automação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS запросит разрешение на управление Календарем при первом открытии даты. Если вы ранее отклонили это, разрешите это в настройках автоматизации."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "首次定位系统日历时 macOS 会请求控制“日历”的权限；若曾拒绝，请在系统设置的自动化中允许。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "首次定位系統日曆時 macOS 會請求控制“日曆”的權限；若曾拒絕，請在系統設定的自動化中允許。"
          }
        }
      }
    },
    "permission.automation.status": {

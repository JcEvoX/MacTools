    "permission.events.denied": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. السماح بالوصول مرة أخرى في إعدادات خصوصية التقويم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. Erlauben Sie den Zugriff in den Datenschutzeinstellungen des Kalenders erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. Allow access again in Calendar privacy settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. Permita el acceso nuevamente en la configuración de privacidad de Calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. Autorisez à nouveau l'accès dans les paramètres de confidentialité de Calendrier."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@。カレンダーのプライバシー設定でアクセスを再度許可します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. 캘린더 개인정보 보호 설정에서 다시 액세스를 허용하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. Permita o acesso novamente nas configurações de privacidade do Agenda."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. Снова разрешите доступ в настройках конфиденциальности Календаря."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@。可在系统设置的日历隐私项中重新允许。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@。可在系統設定的日曆隱私項中重新允許。"
          }
        }
      }
    },
    "permission.events.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقرأ أحداث التقويم حتى يظهر جدول اليوم في مكون التقويم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Liest Kalenderereignisse, damit der heutige Zeitplan in der Kalenderkomponente angezeigt werden kann."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reads calendar events so today's schedule can appear in the calendar component."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee eventos del calendario para que el programa de hoy pueda aparecer en el componente del calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lit les événements du calendrier afin que le planning du jour puisse apparaître dans le composant Calendrier."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダー イベントを読み取り、今日のスケジュールをカレンダー コンポーネントに表示できるようにします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘의 일정이 캘린더 구성요소에 표시될 수 있도록 캘린더 이벤트를 읽습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê eventos da agenda para que a programação de hoje possa aparecer no componente da agenda."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Считывает события календаря, чтобы расписание на сегодня могло отображаться в компоненте календаря."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取系统日历事件，用于在日历组件中显示当天日程。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讀取系統日曆事件，用於在日曆組件中顯示當天行程。"
          }
        }
      }
    },
    "permission.events.notDetermined": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد طلب الوصول، سيسألك macOS عما إذا كان سيسمح بقراءة أحداث التقويم أم لا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nachdem Sie den Zugriff angefordert haben, fragt macOS, ob das Lesen von Kalenderereignissen zugelassen werden soll."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After you request access, macOS will ask whether to allow reading calendar events."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Después de solicitar acceso, macOS le preguntará si permite la lectura de eventos del calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après avoir demandé l'accès, macOS vous demandera s'il est autorisé à lire les événements du calendrier."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセスをリクエストすると、macOS はカレンダー イベントの読み取りを許可するかどうかを尋ねます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "액세스를 요청하면 macOS에서 캘린더 이벤트 읽기를 허용할지 묻습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Depois que você solicitar acesso, o macOS perguntará se permite a leitura de eventos da agenda."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "После того, как вы запросите доступ, macOS спросит, разрешить ли чтение событий календаря."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击请求授权后，系统会询问是否允许读取日历事件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊請求授權後，系統會詢問是否允許讀取日曆事件。"
          }
        }
      }
    },

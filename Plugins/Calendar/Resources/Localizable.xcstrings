    "authorization.denied": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم منح حق الوصول إلى التقويم"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalenderzugriff wurde nicht gewährt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendar access has not been granted"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se ha concedido el acceso al calendario"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au calendrier n'a pas été accordé"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーへのアクセスが許可されていません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 액세스 권한이 부여되지 않았습니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso ao calendário não foi concedido"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к календарю не предоставлен"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未获得日历访问权限"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未獲得日曆訪問權限"
          }
        }
      }
    },
    "authorization.restricted": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوصول إلى التقويم مقيد من قبل النظام"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Zugriff auf den Kalender ist vom System eingeschränkt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendar access is restricted by the system"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El acceso al calendario está restringido por el sistema"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au calendrier est restreint par le système"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーへのアクセスはシステムによって制限されています"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 접근이 시스템에 의해 제한되어 있습니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso ao calendário é restrito pelo sistema"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к календарю ограничен системой"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统限制了日历访问"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統限制了日曆訪問"
          }
        }
      }
    },
    "authorization.unknown": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يسمح هذا النظام بقراءة التقاويم"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses System erlaubt das Lesen von Kalendern nicht"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This system does not allow reading calendars"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este sistema no permite leer calendarios"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce système ne permet pas de lire les calendriers"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このシステムではカレンダーを読み取ることができません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 시스템은 달력 읽기를 허용하지 않습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este sistema não permite a leitura de calendários"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта система не позволяет читать календари"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前系统不允许读取日历"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前系統不允許讀取日曆"
          }
        }
      }
    },
    "authorization.writeOnly": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُسمح فقط بالوصول إلى الكتابة في التقويم، لذا لا يمكن قراءة الأحداث"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es ist nur Schreibzugriff auf den Kalender zulässig, sodass Ereignisse nicht gelesen werden können"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only calendar write access is allowed, so events cannot be read"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se permite el acceso de escritura al calendario, por lo que los eventos no se pueden leer"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seul l'accès en écriture à l'agenda est autorisé, les événements ne peuvent donc pas être lus"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーへの書き込みアクセスのみが許可されるため、イベントを読み取ることはできません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 쓰기 권한만 허용되어 일정을 읽을 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas o acesso de gravação do calendário é permitido, portanto os eventos não podem ser lidos"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешен только доступ к календарю для записи, поэтому события нельзя читать"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅允许写入日历，无法读取日程"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅允許寫入日曆，無法讀取行程"
          }
        }
      }
    },

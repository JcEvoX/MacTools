    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عرض التواريخ والعطلات وأحداث التقويم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Termine, Feiertage und Kalenderereignisse anzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View dates, holidays, and calendar events."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver fechas, días festivos y eventos del calendario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Afficher les dates, les jours fériés et les événements du calendrier."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "日付、休日、カレンダーイベントを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "날짜, 공휴일 및 달력 이벤트를 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja datas, feriados e eventos da agenda."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просмотр дат, праздников и событий календаря."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看日期、节假日和系统日程"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "查看日期、節假日和系統行程"
          }
        }
      }
    },

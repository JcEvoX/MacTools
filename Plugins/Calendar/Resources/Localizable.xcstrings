    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View dates, holidays, and calendar events."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看日期、节假日和系统日程"
          }
        }
      }
    },
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendar"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "日历"
          }
        }
      }
    },
    "month.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$04d/%2$02d"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%04d年%02d月"
          }
        }
      }
    },
    "permission.automation.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Controls the system Calendar app to open the selected date when you click a day."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击日期时需要控制系统日历应用，打开并定位到对应日期。"
          }
        }
      }
    },
    "permission.automation.footnote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS will ask for permission to control Calendar the first time you open a date. If you denied it before, allow it in Automation settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "首次定位系统日历时 macOS 会请求控制“日历”的权限；若曾拒绝，请在系统设置的自动化中允许。"
          }
        }
      }
    },
    "permission.automation.status": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Confirm when needed"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按需确认"
          }
        }
      }
    },
    "permission.automation.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Dates in Calendar"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "定位系统日历"
          }
        }
      }
    },
    "permission.events.denied": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@. Allow access again in Calendar privacy settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@。可在系统设置的日历隐私项中重新允许。"
          }
        }
      }
    },
    "permission.events.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reads calendar events so today's schedule can appear in the calendar component."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "读取系统日历事件，用于在日历组件中显示当天日程。"
          }
        }
      }
    },
    "permission.events.notDetermined": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After you request access, macOS will ask whether to allow reading calendar events."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击请求授权后，系统会询问是否允许读取日历事件。"
          }
        }
      }
    },
    "permission.events.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendar Events"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统日历事件"
          }
        }
      }
    },

{
  "id": "calendar",
  "displayName": "日历",
  "summary": "查看日期、节假日和系统日程",
  "version": "1.0.5",
  "minHostVersion": "1.0.2",
  "pluginKitVersion": 2,
  "bundleRelativePath": "Calendar.bundle",
  "factoryClass": "CalendarPlugin.CalendarPluginFactory",
  "build": {
    "project": "../../MacTools.xcodeproj",
    "scheme": "CalendarPlugin"
  },
  "capabilities": {
    "primaryPanel": false,
    "componentPanel": true,
    "configuration": false
  },
  "permissions": [
    "calendarFullAccess",
    "automation"
  ],
  "category": "productivity"
}

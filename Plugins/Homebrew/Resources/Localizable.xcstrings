    "detail.diagnostics.cleanup.desc": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إزالة التنزيلات والملفات المؤقتة القديمة لتحرير مساحة القرص."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove outdated local downloads and caches to reclaim disk space."
          }

    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عرض مستويات البطارية لجهاز Mac، وملحقات Bluetooth، وأجهزة الماوس Rapoo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigen Sie den Akkustand Ihres Mac, Ihres Bluetooth-Zubehörs und Ihrer Rapoo Mäuse an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View battery levels for your Mac, Bluetooth accessories, and Rapoo mice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver los niveles de batería de tu Mac, accesorios Bluetooth y Rapoo ratones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affichez les niveaux de batterie de votre Mac, de vos accessoires Bluetooth et de vos souris Rapoo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac、Bluetooth アクセサリ、Rapoo マウスのバッテリー レベルを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac, Bluetooth 액세서리 및 Rapoo 마우스의 배터리 잔량을 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja os níveis de bateria do seu Mac, acessórios Bluetooth e mouses Rapoo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просматривайте уровень заряда батареи вашего Mac, аксессуаров Bluetooth и мышей Rapoo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看 Mac、蓝牙外设和雷柏鼠标电量"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "查看 Mac、藍牙外設和雷柏滑鼠電量"
          }
        }
      }
    },

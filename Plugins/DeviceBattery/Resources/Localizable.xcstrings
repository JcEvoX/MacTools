    "permission.inputMonitoring.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقرأ مستوى البطارية وحالة الشحن والطراز والاسم من أجهزة الماوس المدعومة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Liest Akkustand, Ladezustand, Modell und Namen von unterstützten Mäusen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reads battery level, charging state, model, and name from supported mice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee el nivel de la batería, el estado de carga, el modelo y el nombre de los ratones compatibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lit le niveau de la batterie, l'état de charge, le modèle et le nom des souris prises en charge."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サポートされているマウスからバッテリー レベル、充電状態、モデル、名前を読み取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지원되는 마우스에서 배터리 잔량, 충전 상태, 모델 및 이름을 읽습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê o nível da bateria, estado de carregamento, modelo e nome dos mouses compatíveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Считывает уровень заряда батареи, состояние зарядки, модель и название поддерживаемых мышей."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于读取已适配厂商 HID 鼠标的电量、充电状态、设备型号和名称。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用於讀取已適配廠商 HID 滑鼠的電量、充電狀態、設備型號和名稱。"
          }
        }
      }
    },
    "permission.inputMonitoring.granted.connected": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools يمكنه استخدام مراقبة الإدخال وقد قرأ معلومات الماوس المدعومة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools kann die Eingabeüberwachung verwenden und hat unterstützte Mausinformationen gelesen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools can use Input Monitoring and has read supported mouse information."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools puede usar la supervisión de entrada y ha leído la información del mouse compatible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools peut utiliser la surveillance des entrées et a lu les informations de souris prises en charge."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools は入力モニタリングを使用でき、サポートされているマウス情報を読み取っています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools은(는) 입력 모니터링을 사용할 수 있으며 지원되는 마우스 정보를 읽었습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools pode usar o monitoramento de entrada e leu as informações suportadas do mouse."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools может использовать мониторинг ввода и прочитал поддерживаемую информацию о мыши."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已允许 MacTools 使用输入监控，并已读取到厂商 HID 鼠标信息。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已允許 MacTools 使用輸入監控，並已讀取到廠商 HID 滑鼠信息。"
          }
        }
      }
    },

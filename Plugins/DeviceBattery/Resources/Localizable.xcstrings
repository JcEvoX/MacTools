    "permission.inputMonitoring.openSettingsFootnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انتقل إلى إعدادات النظام > الخصوصية والأمان > مراقبة الإدخال واسمح بـ MacTools."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gehen Sie zu Systemeinstellungen > Datenschutz und Sicherheit > Eingabeüberwachung und erlauben Sie MacTools."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Go to System Settings > Privacy & Security > Input Monitoring and allow MacTools."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaya a Configuración del sistema > Privacidad y seguridad > Monitoreo de entrada y permita MacTools."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accédez à Paramètres système > Confidentialité et sécurité > Surveillance des entrées et autorisez MacTools."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "[システム設定] > [プライバシーとセキュリティ] > [入力モニタリング] に移動し、MacTools を許可します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 설정 > 개인정보 보호 및 보안 > 입력 모니터링으로 이동하여 MacTools을(를) 허용하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vá para Configurações do sistema > Privacidade e segurança > Monitoramento de entrada e permita MacTools."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перейдите в «Настройки системы» > «Конфиденциальность и безопасность» > «Мониторинг ввода» и разрешите MacTools."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "前往系统设置 → 隐私与安全性 → 输入监控，允许 MacTools。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "前往系統設定 → 隱私權與安全性 → 輸入監控，允許 MacTools。"
          }
        }
      }
    },

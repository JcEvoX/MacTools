    "permission.inputMonitoring.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reads battery level, charging state, model, and name from supported mice."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于读取已适配厂商 HID 鼠标的电量、充电状态、设备型号和名称。"
          }
        }
      }
    },
    "permission.inputMonitoring.granted.connected": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools can use Input Monitoring and has read supported mouse information."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已允许 MacTools 使用输入监控，并已读取到厂商 HID 鼠标信息。"
          }
        }
      }
    },
    "permission.inputMonitoring.granted.default": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools can use Input Monitoring to read supported mice."

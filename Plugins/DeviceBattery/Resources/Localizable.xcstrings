    "permission.inputMonitoring.unauthorized.default": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امنح هذا الإذن لقراءة مستويات بطارية الماوس المدعومة. ولا تزال بطارية Mac المدمجة وأجهزة Bluetooth الخاصة بالنظام وملحقات Apple تعمل بدونها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gewähren Sie diese Berechtigung, um den unterstützten Batteriestand der Maus zu lesen. Der eingebaute Mac-Akku, System-Bluetooth-Geräte und Apple-Zubehör funktionieren auch ohne ihn."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant this permission to read supported mouse battery levels. The built-in Mac battery, system Bluetooth devices, and Apple accessories still work without it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conceda este permiso para leer los niveles de batería del mouse admitidos. La batería integrada del Mac, los dispositivos Bluetooth del sistema y los accesorios de Apple siguen funcionando sin ella."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accordez cette autorisation pour lire les niveaux de batterie de la souris pris en charge. La batterie Mac intégrée, les appareils Bluetooth du système et les accessoires Apple fonctionnent toujours sans elle."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サポートされているマウスのバッテリー レベルを読み取るために、このアクセス許可を付与します。 Mac の内蔵バッテリー、システム Bluetooth デバイス、Apple アクセサリは、バッテリーなしでも動作します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지원되는 마우스 배터리 수준을 읽으려면 이 권한을 부여하세요. 내장 Mac 배터리, 시스템 Bluetooth 장치 및 Apple 액세서리는 이 배터리가 없어도 계속 작동합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Conceda esta permissão para ler os níveis de bateria do mouse suportados. A bateria integrada do Mac, os dispositivos Bluetooth do sistema e os acessórios da Apple ainda funcionam sem ela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предоставьте это разрешение для чтения поддерживаемых уровней заряда батареи мыши. Встроенный аккумулятор Mac, системные устройства Bluetooth и аксессуары Apple по-прежнему работают без него."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "授权后可读取厂商 HID 鼠标信息；未授权不影响 Mac 内置电池、系统蓝牙设备和 Apple 外设电量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "授權後可讀取廠商 HID 滑鼠信息；未授權不影響 Mac 內置電池、系統藍牙設備和 Apple 外設電量。"
          }
        }
      }
    },
    "permission.inputMonitoring.unauthorized.failed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امنح هذا الإذن لقراءة مستويات بطارية الماوس المدعومة. فشلت القراءة الأخيرة: %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erteilen Sie diese Berechtigung, um den unterstützten Batteriestand der Maus zu lesen. Letzter Lesevorgang fehlgeschlagen: %@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant this permission to read supported mouse battery levels. Last read failed: %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Otorgue este permiso para leer los niveles de batería del mouse admitidos. Última lectura fallida: %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accordez cette autorisation pour lire les niveaux de batterie de la souris pris en charge. Échec de la dernière lecture : %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サポートされているマウスのバッテリー レベルを読み取るために、このアクセス許可を付与します。前回の読み取りに失敗しました: %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지원되는 마우스 배터리 수준을 읽으려면 이 권한을 부여하세요. 마지막 읽기 실패: %@"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Conceda esta permissão para ler os níveis de bateria do mouse suportados. Falha na última leitura: %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предоставьте это разрешение для чтения поддерживаемых уровней заряда батареи мыши. Последнее чтение не удалось: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "授权后可读取厂商 HID 鼠标信息。最近读取失败：%@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "授權後可讀取廠商 HID 滑鼠信息。最近讀取失敗：%@"
          }
        }
      }
    },
    "rapoo.detail.idle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الانتظار"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten"
          }
        },

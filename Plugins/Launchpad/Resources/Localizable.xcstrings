    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح شبكة التطبيقات، وابحث وشغّل التطبيقات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "App-Raster öffnen, Apps suchen und starten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the app grid, search, and launch apps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre la cuadrícula de apps, busca y abre apps."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez la grille d’apps, recherchez et lancez des apps."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリグリッドを開き、検索して起動します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 그리드를 열고 검색해 실행합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra a grade de apps, pesquise e abra apps."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте сетку приложений, найдите и запустите приложения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

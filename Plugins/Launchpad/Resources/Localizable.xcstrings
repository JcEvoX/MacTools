    "shortcut.toggle.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم اختصارًا عامًا لفتح شبكة التطبيقات أو إغلاقها. لا يوجد اختصار افتراضي؛ خصصه هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit einem globalen Kurzbefehl das App-Raster öffnen oder schließen. Kein Standard festgelegt; hier anpassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a global shortcut to open or close the app grid. No default is set; customize it here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa un atajo global para abrir o cerrar la cuadrícula de apps. No hay valor predeterminado; configúralo aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez un raccourci global pour ouvrir ou fermer la grille d’apps. Aucun raccourci par défaut ; personnalisez-le ici."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "グローバルショートカットでアプリグリッドを開閉します。デフォルトは未設定です。ここで変更できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전역 단축키로 앱 그리드를 열거나 닫습니다. 기본값은 없으며 여기서 설정할 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Use um atalho global para abrir ou fechar a grade de apps. Não há padrão; personalize aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте глобальное сочетание клавиш, чтобы открыть или закрыть сетку приложений. По умолчанию не задано; настройте здесь."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全局快捷键唤出或收起应用网格。默认未设置，可在此自定义。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用全域快速鍵打開或收起 App 網格。預設未設定，可在此自定義。"
          }
        }
      }
    },

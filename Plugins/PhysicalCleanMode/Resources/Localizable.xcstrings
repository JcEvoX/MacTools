    },
    "error.accessibilityRevokedEmergencyExit": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إبطال إذن الوصول. لقد تم الخروج من الوضع النظيف."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriffsberechtigung wurde widerrufen. Der Reinigungsmodus wurde beendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission was revoked. Clean Mode has exited."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se revocó el permiso de accesibilidad. El modo de limpieza ha salido."

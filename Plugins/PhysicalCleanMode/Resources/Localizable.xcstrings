{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الوضع النظيف"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinigungsmodus"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clean Mode"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo de limpieza"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode nettoyage"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリーンモード"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클린 모드"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo Limpo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим очистки"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清洁模式"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "清潔模式"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعتيم الشاشة وحظر إدخال لوحة المفاتيح مؤقتًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Den Bildschirm verdunkeln und Tastatureingaben vorübergehend blockieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Black out the screen and temporarily block keyboard input."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apague la pantalla y bloquee temporalmente la entrada del teclado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Obscurcissez l'écran et bloquez temporairement la saisie au clavier."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面をブラックアウトし、キーボード入力を一時的にブロックします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화면을 검게 만들고 키보드 입력을 일시적으로 차단합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escureça a tela e bloqueie temporariamente a entrada do teclado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Затемните экран и временно заблокируйте ввод с клавиатуры."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "屏幕全黑并临时禁用键盘输入"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "螢幕全黑並臨時禁用鍵盤輸入"
          }
        }
      }
    },
    "permission.accessibility.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إمكانية الوصول"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Barrierefreiheit"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesibilidad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibilité"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "접근성"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Acessibilidade"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступность"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能授权"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輔助使用授權"
          }
        }
      }
    },
    "permission.accessibility.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلزم الحصول على إذن الوصول للوضع النظيف."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für den Reinigungsmodus ist eine Barrierefreiheitsberechtigung erforderlich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission is required for Clean Mode."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se requiere permiso de accesibilidad para el modo limpio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une autorisation d'accessibilité est requise pour le mode nettoyage."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリーン モードにはアクセシビリティ権限が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클린모드를 위해서는 접근성 권한이 필요합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "É necessária permissão de acessibilidade para o Modo Limpo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для чистого режима требуется разрешение на доступ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能权限是清洁模式运行所需的必要权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輔助使用權限是清潔模式運行所需的必要權限。"
          }
        }
      }
    },
    "shortcut.exit.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الخروج من الوضع النظيف"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reinigungsmodus verlassen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exit Clean Mode"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Salir del modo de limpieza"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quitter le mode nettoyage"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリーン モードを終了"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클린 모드 종료"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sair do modo limpo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выйти из режима очистки"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出清洁模式"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "退出清潔模式"
          }
        }
      }
    },
    "shortcut.exit.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستعيد الإدخال ويغلق تراكب الشاشة السوداء أثناء تنشيط الوضع النظيف."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stellt die Eingabe wieder her und schließt die schwarze Bildschirmüberlagerung, während der Reinigungsmodus aktiv ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restores input and closes the black screen overlay while Clean Mode is active."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaura la entrada y cierra la superposición de pantalla negra mientras el Modo Limpieza está activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rétablit l'entrée et ferme la superposition d'écran noir lorsque le mode nettoyage est actif."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリーン モードがアクティブな間、入力を復元し、黒い画面オーバーレイを閉じます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클린 모드가 활성화된 동안 입력을 복원하고 검은색 화면 오버레이를 닫습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaura a entrada e fecha a sobreposição da tela preta enquanto o Modo Limpeza está ativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Восстанавливает ввод и закрывает наложение черного экрана, пока активен режим очистки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清洁模式启用时用于恢复输入和关闭黑屏覆盖的快捷键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "清潔模式啟用時用於恢復輸入和關閉黑螢幕覆蓋的快速鍵。"
          }
        }
      }
    },
    "shortcut.exit.settingsGroupTitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الخروج من الاختصار"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verknüpfung beenden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exit Shortcut"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Salir del acceso directo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccourci de sortie"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ショートカットを終了"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "바로가기 종료"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sair do atalho"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ярлык выхода"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出快捷键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "退出快速鍵"
          }
        }
      }
    },

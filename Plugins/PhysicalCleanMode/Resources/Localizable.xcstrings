    "session.error.eventTapUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على إنشاء اعتراض الإدخال. تأكد من منح إذن الوصول."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Eingabe-Interceptor konnte nicht erstellt werden. Bestätigen Sie, dass die Barrierefreiheitsberechtigung erteilt wurde."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to create the input interceptor. Confirm Accessibility permission is granted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede crear el interceptor de entrada. Confirme que se haya concedido el permiso de accesibilidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de créer l'intercepteur d'entrée. Confirmez que l'autorisation d'accessibilité est accordée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "入力インターセプターを作成できません。アクセシビリティ権限が付与されていることを確認します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "입력 인터셉터를 생성할 수 없습니다. 접근성 권한이 부여되었는지 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível criar o interceptor de entrada. Confirme se a permissão de acessibilidade foi concedida."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Невозможно создать перехватчик ввода. Подтвердите, что разрешение на доступ предоставлено."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法创建输入拦截器，请确认已授予辅助功能权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",

          }
        }
      }
    },
    "panel.subtitle.enabledExitFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تشغيل. اضغط %@ للخروج."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein. Drücken Sie %@, um den Vorgang zu beenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On. Press %@ to exit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activado. Presione %@ para salir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activé. Appuyez sur %@ pour quitter."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オン。 %@ を押して終了します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜짐. 종료하려면 %@을 누르세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativado. Pressione %@ para sair."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включено. Нажмите %@ для выхода."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已启用，使用 %@ 退出"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已啟用，使用 %@ 退出"
          }
        }
      }
    },
    "panel.subtitle.needsAccessibility": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب إذن الوصول"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfordert die Berechtigung zur Barrierefreiheit"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Requires Accessibility permission"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Requiere permiso de accesibilidad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nécessite une autorisation d'accessibilité"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティ権限が必要です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "접근성 권한이 필요합니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Requer permissão de acessibilidade"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Требуется разрешение на доступ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用前需要辅助功能授权"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用前需要輔助使用授權"
          }
        }
      }
    },
    "error.accessibilityRequired": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتطلب الوضع النظيف إذن الوصول. امنحها في الإعدادات أولاً."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für den Reinigungsmodus ist eine Barrierefreiheitsberechtigung erforderlich. Gewähren Sie es zuerst in den Einstellungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clean Mode requires Accessibility permission. Grant it in Settings first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo limpio requiere permiso de accesibilidad. Concédelo primero en Configuración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode Nettoyage nécessite une autorisation d'accessibilité. Accordez-le d'abord dans les paramètres."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリーン モードにはアクセシビリティ権限が必要です。まず設定で許可してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클린 모드에는 접근성 권한이 필요합니다. 먼저 설정에서 승인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Modo Limpo requer permissão de acessibilidade. Conceda-o primeiro nas configurações."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для режима очистки требуется разрешение специальных возможностей. Сначала разрешите это в настройках."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清洁模式需要辅助功能权限，请先前往设置完成授权。"
          }
        },
        "zh-Hant": {
          "stringUnit": {

    "overlay.exit.rightMouseFormat": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أو اضغط مع الاستمرار على زر الماوس الأيمن لمدة %ds"

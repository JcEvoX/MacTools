          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Восстанавливает ввод и закрывает наложение черного экрана, пока активен режим очистки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

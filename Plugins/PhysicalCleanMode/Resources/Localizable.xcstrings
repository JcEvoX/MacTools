        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "접근성 권한이 취소되었습니다. 클린 모드가 종료되었습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A permissão de acessibilidade foi revogada. O modo limpo foi encerrado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешение на доступ было отозвано. Режим очистки завершен."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能授权已失效，已自动退出清洁模式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輔助使用授權已失效，已自動退出清潔模式。"
          }
        }
      }
    },
    "error.invalidExitShortcut": {

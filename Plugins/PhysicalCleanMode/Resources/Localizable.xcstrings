    "session.error.overlayWindowUnexpectedlyClosed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إغلاق تراكب الوضع النظيف بشكل غير متوقع. تمت استعادة إدخال النظام."
          }
        },
        "de": {

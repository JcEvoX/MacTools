        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メニュー バーのアイコンを移動できない"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메뉴 표시줄 아이콘을 이동할 수 없습니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O ícone da barra de menu não pode ser movido"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Значок строки меню нельзя переместить"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "菜单栏图标不可移动"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選單列圖標不可移動"
          }
        }
      }
    },

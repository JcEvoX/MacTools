    "settings.alwaysHidden.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسمح للرموز بالبقاء مخفية حتى عند إيقاف تشغيل مفتاح الإخفاء."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ermöglicht, dass Symbole ausgeblendet bleiben, auch wenn der Ausblenden-Schalter ausgeschaltet ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allows icons to stay hidden even when the hide switch is off."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite que los iconos permanezcan ocultos incluso cuando el interruptor para ocultar está desactivado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Permet aux icônes de rester masquées même lorsque le bouton de masquage est désactivé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非表示スイッチがオフの場合でもアイコンを非表示のままにできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "숨기기 스위치가 꺼진 경우에도 아이콘이 숨겨진 상태로 유지되도록 허용합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite que os ícones permaneçam ocultos mesmo quando o botão Ocultar está desativado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Позволяет значкам оставаться скрытыми, даже если переключатель скрытия выключен."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后可将图标放入永久隐藏栏，隐藏开关关闭时也不会显示"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後可將圖標放入永久隱藏欄，隱藏開關關閉時也不會顯示"
          }
        }
      }
    },

    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إخفاء أيقونات شريط القائمة، وترتيبها عن طريق السحب، وفتح الأيقونات المخفية من اللوحة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Menüleistensymbole ausblenden, durch Ziehen anordnen und ausgeblendete Symbole in einem Bedienfeld öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hide menu bar icons, arrange them by dragging, and open hidden icons from a panel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar iconos de la barra de menú, organizarlos arrastrándolos y abrir iconos ocultos desde un panel."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Masquer les icônes de la barre de menus, les organiser en les faisant glisser et ouvrir les icônes masquées à partir d'un panneau."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メニュー バー アイコンを非表示にし、ドラッグして配置し、パネルから非表示のアイコンを開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메뉴 표시줄 아이콘을 숨기고 드래그하여 정렬하고 패널에서 숨겨진 아이콘을 엽니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Oculte os ícones da barra de menu, organize-os arrastando e abra ícones ocultos em um painel."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скрыть значки строки меню, упорядочить их путем перетаскивания и открыть скрытые значки на панели."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏菜单栏图标并支持拖拽布局与点击转发"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "隱藏選單列圖標並支持拖拽佈局與點擊轉發"
          }
        }
      }
    },

    "settings.hideIcons.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التمكين، يقوم المقسم الموجود على يمين عناصر الحالة بإخفاء كافة الرموز الموجودة على يساره."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn diese Option aktiviert ist, werden durch die Trennlinie rechts neben den Statuselementen alle Symbole links davon ausgeblendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, the divider to the right of status items hides all icons to its left."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está habilitado, el divisor a la derecha de los elementos de estado oculta todos los iconos a su izquierda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsqu'il est activé, le séparateur à droite des éléments d'état masque toutes les icônes à sa gauche."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、ステータス項目の右側にある仕切りにより、左側にあるすべてのアイコンが非表示になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성화되면 상태 항목 오른쪽에 있는 구분선이 왼쪽에 있는 모든 아이콘을 숨깁니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, o divisor à direita dos itens de status oculta todos os ícones à sua esquerda."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если этот параметр включен, разделитель справа от элементов статуса скрывает все значки слева от него."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后状态栏图标右侧的扩展条会隐藏其左侧的所有图标"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後狀態列圖標右側的擴展條會隱藏其左側的所有圖標"
          }
        }
      }
    },

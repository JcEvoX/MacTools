{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "alert.hostIconCannotHide.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app's own menu bar icon must stay in the visible section."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用本身的菜单栏图标必须保留在显示区域。"
          }
        }
      }
    },
    "alert.hostIconCannotHide.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools Icon Cannot Be Hidden"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools 图标不能隐藏"
          }
        }
      }
    },
    "alert.itemCannotMove.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS does not allow moving \"%@\"."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 不允许移动“%@”。"
          }
        }
      }
    },
    "alert.itemCannotMove.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu Bar Icon Cannot Be Moved"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "菜单栏图标不可移动"
          }
        }
      }
    },
    "compat.unsupported.detail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The system menu bar architecture changed and icon enumeration is unavailable; related features are disabled."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统菜单栏架构变化导致图标枚举不可用，相关功能已停用"
          }
        }
      }
    },
    "compat.unsupported.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu bar icon hiding is not yet compatible with this version of macOS."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 macOS 版本暂不兼容菜单栏隐藏"
          }
        }
      }
    },
    "compat.unsupported.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not compatible"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂不兼容"
          }
        }
      }
    },
    "component.subtitle.count": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d hidden icons"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 个隐藏图标"
          }
        }
      }
    },
    "component.subtitle.count.singular": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d hidden icon"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%d 个隐藏图标"
          }
        }
      }
    },
    "component.subtitle.empty": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No hidden icons"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无隐藏图标"
          }
        }
      }
    },
    "eventError.eventCreationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to create mouse event."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法创建鼠标事件"
          }
        }
      }
    },
    "eventError.notTrusted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission is not granted."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能权限未授予"
          }
        }
      }
    },
    "eventError.pidDead": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Target process %d has exited."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目标进程 %d 已退出"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hide menu bar icons, arrange them by dragging, and open hidden icons from a panel."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏菜单栏图标并支持拖拽布局与点击转发"
          }
        }
      }
    },
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hide Menu Bar Icons"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏菜单栏图标"
          }
        }
      }
    },
    "panel.subtitle.disabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Off"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已关闭"
          }
        }
      }
    },
    "panel.subtitle.enabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已启用"
          }
        }
      }
    },
    "permission.accessibility.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uses mouse events to drag menu bar icons and open hidden icons from the panel."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于合成鼠标事件以拖拽菜单栏图标并转发点击"
          }
        }
      }
    },
    "permission.accessibility.footnote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The hide switch still works, but dragging and opening hidden icons are unavailable."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未授权时仍可使用隐藏开关，但无法拖拽或转发点击"
          }
        }
      }
    },
    "permission.accessibility.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能"
          }
        }
      }
    },
    "permission.screenRecording.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Captures the real appearance of menu bar icons for viewing and clicking in the panel."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于捕获菜单栏图标的真实外观，仅授权后才能在面板中查看与点击"
          }
        }
      }
    },
    "permission.screenRecording.footnote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The hide switch still works, but the layout strip and hidden icons panel are unavailable."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未授权时仍可使用隐藏开关，但布局栏与弹窗不可用"
          }
        }
      }
    },
    "permission.screenRecording.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen Recording"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "屏幕录制"
          }
        }
      }
    },
    "popup.empty": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No hidden menu bar icons"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有隐藏的菜单栏图标"
          }
        }
      }
    },
    "popup.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hidden Icons"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏图标"
          }
        }
      }
    },
    "section.alwaysHidden": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Always Hidden"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永久隐藏"
          }
        }
      }
    },
    "section.hidden": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hidden"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏"
          }
        }
      }
    },
    "section.visible": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visible"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示"
          }
        }
      }
    },
    "settings.alwaysHidden.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allows icons to stay hidden even when the hide switch is off."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后可将图标放入永久隐藏栏，隐藏开关关闭时也不会显示"
          }
        }
      }
    },
    "settings.alwaysHidden.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Always Hide"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永久隐藏"
          }
        }
      }
    },
    "settings.behavior.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Behavior"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "行为"
          }
        }
      }
    },
    "settings.hideIcons.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, the divider to the right of status items hides all icons to its left."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后状态栏图标右侧的扩展条会隐藏其左侧的所有图标"
          }
        }
      }
    },
    "settings.hideIcons.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hide Menu Bar Icons"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐藏菜单栏图标"
          }
        }
      }
    },
    "settings.layout.authorizationRequired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Permission Required"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要授权"
          }
        }
      }
    },
    "settings.layout.emptyDropTarget": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag menu bar icons here"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖入菜单栏图标到此区域"
          }
        }
      }
    },
    "settings.layout.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Menu Bar Layout"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "菜单栏布局"
          }
        }
      }
    },
    "settings.showInPanel.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows hidden icons in the left-click menu panel."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后左键菜单面板显示隐藏图标卡片"
          }
        }
      }
    },
    "settings.showInPanel.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show Hidden Icons in Panel"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "面板中显示隐藏图标"
          }
        }
      }
    }
  },
  "version": "1.0"
}

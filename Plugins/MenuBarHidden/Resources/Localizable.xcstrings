    "eventError.eventCreationFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على إنشاء حدث الماوس."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mausereignis konnte nicht erstellt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to create mouse event."
          }
        },
        "es": {
          "stringUnit": {

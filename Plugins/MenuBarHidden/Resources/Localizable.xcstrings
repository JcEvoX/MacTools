            "value": "無法創建滑鼠事件"
          }
        }
      }
    },
    "eventError.notTrusted": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم منح إذن الوصول."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriffsberechtigung wurde nicht erteilt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission is not granted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se concede el permiso de accesibilidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'autorisation d'accessibilité n'est pas accordée."
          }
        },
        "ja": {

    "permission.accessibility.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم أحداث الماوس لسحب أيقونات شريط القائمة وفتح الأيقونات المخفية من اللوحة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwendet Mausereignisse, um Menüleistensymbole zu ziehen und ausgeblendete Symbole aus dem Bedienfeld zu öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uses mouse events to drag menu bar icons and open hidden icons from the panel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utiliza eventos del mouse para arrastrar íconos de la barra de menú y abrir íconos ocultos desde el panel."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise les événements de la souris pour faire glisser les icônes de la barre de menus et ouvrir les icônes cachées depuis le panneau."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マウス イベントを使用して、メニュー バー アイコンをドラッグし、パネルから非表示のアイコンを開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마우스 이벤트를 사용하여 메뉴 표시줄 아이콘을 드래그하고 패널에서 숨겨진 아이콘을 엽니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa eventos de mouse para arrastar ícones da barra de menu e abrir ícones ocultos do painel."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Использует события мыши для перетаскивания значков в строке меню и открытия скрытых значков на панели."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于合成鼠标事件以拖拽菜单栏图标并转发点击"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用於合成滑鼠事件以拖拽選單列圖標並轉發點擊"
          }
        }
      }
    },
    "permission.accessibility.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يزال مفتاح الإخفاء يعمل، لكن سحب الرموز المخفية وفتحها غير متاح."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Schalter zum Ausblenden funktioniert weiterhin, aber das Ziehen und Öffnen ausgeblendeter Symbole ist nicht verfügbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The hide switch still works, but dragging and opening hidden icons are unavailable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El interruptor para ocultar sigue funcionando, pero arrastrar y abrir iconos ocultos no está disponible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le bouton Masquer fonctionne toujours, mais le glisser-déposer et l'ouverture des icônes masquées ne sont pas disponibles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非表示スイッチは引き続き機能しますが、非表示アイコンをドラッグしたり開いたりすることはできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "숨기기 스위치는 계속 작동하지만 숨겨진 아이콘을 끌어서 열 수는 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A opção de ocultar ainda funciona, mas arrastar e abrir ícones ocultos não está disponível."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переключатель скрытия по-прежнему работает, но перетаскивание и открытие скрытых значков недоступны."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未授权时仍可使用隐藏开关，但无法拖拽或转发点击"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未授權時仍可使用隱藏開關，但無法拖拽或轉發點擊"
          }
        }
      }
    },

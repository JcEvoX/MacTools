    "permission.screenRecording.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلتقط المظهر الحقيقي لأيقونات شريط القائمة للعرض والنقر في اللوحة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfasst das tatsächliche Erscheinungsbild von Menüleistensymbolen zum Anzeigen und Klicken im Bedienfeld."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Captures the real appearance of menu bar icons for viewing and clicking in the panel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura la apariencia real de los íconos de la barra de menú para verlos y hacer clic en el panel."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture l'apparence réelle des icônes de la barre de menus pour les afficher et cliquer dans le panneau."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パネル内で表示およびクリックできるように、メニュー バー アイコンの実際の外観をキャプチャします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "패널에서 보고 클릭할 수 있는 메뉴 표시줄 아이콘의 실제 모양을 캡처합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura a aparência real dos ícones da barra de menu para visualização e clique no painel."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фиксирует реальный внешний вид значков строки меню для просмотра и нажатия на панели."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于捕获菜单栏图标的真实外观，仅授权后才能在面板中查看与点击"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用於捕獲選單列圖標的真實外觀，僅授權後才能在面板中查看與點擊"
          }
        }
      }
    },
    "permission.screenRecording.footnote": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يزال مفتاح الإخفاء يعمل، ولكن شريط التخطيط ولوحة الرموز المخفية غير متاحة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Schalter zum Ausblenden funktioniert weiterhin, aber die Layoutleiste und das Bedienfeld mit ausgeblendeten Symbolen sind nicht verfügbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The hide switch still works, but the layout strip and hidden icons panel are unavailable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El interruptor para ocultar sigue funcionando, pero la franja de diseño y el panel de iconos ocultos no están disponibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le bouton Masquer fonctionne toujours, mais la bande de mise en page et le panneau d'icônes masquées ne sont pas disponibles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非表示スイッチは引き続き機能しますが、レイアウト ストリップと非表示のアイコン パネルは使用できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "숨기기 스위치는 계속 작동하지만 레이아웃 스트립과 숨겨진 아이콘 패널은 사용할 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A opção ocultar ainda funciona, mas a faixa de layout e o painel de ícones ocultos não estão disponíveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переключатель скрытия по-прежнему работает, но полоса макета и панель скрытых значков недоступны."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未授权时仍可使用隐藏开关，但布局栏与弹窗不可用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未授權時仍可使用隱藏開關，但佈局欄與彈窗不可用"
          }
        }
      }
    },

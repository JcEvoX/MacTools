{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "alert.hostIconCannotHide.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجب أن يظل رمز شريط القائمة الخاص بالتطبيق في القسم المرئي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das eigene Menüleistensymbol der App muss im sichtbaren Bereich bleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app's own menu bar icon must stay in the visible section."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El icono de la barra de menú de la aplicación debe permanecer en la sección visible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'icône de la barre de menu de l'application doit rester dans la section visible."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリ独自のメニュー バー アイコンは、表示されるセクションに存在する必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱 자체 메뉴 표시줄 아이콘은 보이는 섹션에 있어야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O ícone da barra de menu do próprio aplicativo deve permanecer na seção visível."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Значок строки меню приложения должен оставаться в видимой части."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用本身的菜单栏图标必须保留在显示区域。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "應用本身的選單列圖標必須保留在顯示區域。"
          }
        }
      }
    },
    "alert.hostIconCannotHide.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools لا يمكن إخفاء الرمز"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools-Symbol kann nicht ausgeblendet werden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools Icon Cannot Be Hidden"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools El icono no se puede ocultar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'icône MacTools ne peut pas être masquée"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools アイコンは非表示にできません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools 아이콘은 숨길 수 없습니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ícone MacTools não pode ser ocultado"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools Значок нельзя скрыть"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools 图标不能隐藏"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "MacTools 圖標不能隱藏"
          }
        }
      }
    },
    "alert.itemCannotMove.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يسمح نظام التشغيل macOS بنقل \"%@\"."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS erlaubt das Verschieben von „%@“ nicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS does not allow moving \"%@\"."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS no permite mover \"%@\"."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS n'autorise pas le déplacement de \"%@\"."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS では「%@」の移動は許可されていません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS는 \"%@\" 이동을 허용하지 않습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O macOS não permite mover \"%@\"."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS не позволяет перемещать «%@»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 不允许移动“%@”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 不允許移動“%@”。"
          }
        }
      }
    },
    "alert.itemCannotMove.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",

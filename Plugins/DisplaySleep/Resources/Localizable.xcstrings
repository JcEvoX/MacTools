    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل شاشات العرض في وضع السكون على الفور."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anzeigen sofort in den Ruhezustand versetzen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Put displays to sleep immediately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pon las pantallas en modo de suspensión inmediatamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettez les écrans en veille immédiatement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスプレイをすぐにスリープ状態にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스플레이를 즉시 절전 모드로 전환하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloque os monitores em hibernação imediatamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Немедленно перевести дисплеи в спящий режим."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "立即让显示器休眠"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "立即讓顯示器休眠"
          }
        }
      }
    },

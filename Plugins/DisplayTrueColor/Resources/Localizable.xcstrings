    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ضبط لون الشاشة تلقائيًا ليناسب الإضاءة المحيطة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anzeigefarbe automatisch an das Umgebungslicht anpassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatically adapt display color to ambient light."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Adapte automáticamente el color de la pantalla a la luz ambiental."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Adaptez automatiquement la couleur de l'affichage à la lumière ambiante."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスプレイの色を周囲の光に自動的に適応させます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스플레이 색상을 주변 조명에 자동으로 적응시킵니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adaptar automaticamente a cor da tela à luz ambiente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически адаптировать цвет дисплея к окружающему освещению."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动调节显示器颜色以适应环境光"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動調節顯示器顏色以適應環境光"
          }
        }
      }
    },

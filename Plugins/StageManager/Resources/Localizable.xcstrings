{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "metadata.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stage Manager"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "台前调度"
          }
        }
      }
    },
    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Stage Manager to focus the current window and keep others at the side."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启台前调度，集中显示当前窗口并把其他窗口收纳到侧边"
          }
        }
      }
    },
    "panel.subtitle.enabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已开启"
          }
        }
      }
    },
    "panel.subtitle.disabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Off"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已关闭"
          }
        }
      }
    },
    "error.preferencesUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to access Stage Manager preferences."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法访问台前调度偏好设置"
          }
        }
      }
    }
  },
  "version": "1.0"
}

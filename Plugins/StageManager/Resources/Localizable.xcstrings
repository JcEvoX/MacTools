    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتمكين Stage Manager لتركيز النافذة الحالية وإبقاء النوافذ الأخرى جانبًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie Stage Manager, um das aktuelle Fenster zu fokussieren und andere an der Seite zu halten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Stage Manager to focus the current window and keep others at the side."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilite Stage Manager para enfocar la ventana actual y mantener otras al lado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez Stage Manager pour concentrer la fenêtre actuelle et garder les autres à côté."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Stage Manager を有効にして、現在のウィンドウにフォーカスし、他のウィンドウを脇に置いておきます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 창에 초점을 맞추고 다른 창은 옆에 두려면 Stage Manager을 활성화하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative Stage Manager para focar a janela atual e manter as outras ao lado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите Stage Manager, чтобы сфокусировать текущее окно и оставить другие в стороне."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启台前调度，集中显示当前窗口并把其他窗口收纳到侧边"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟幕前調度，集中顯示當前窗口並把其他窗口收納到側邊"
          }
        }
      }
    },

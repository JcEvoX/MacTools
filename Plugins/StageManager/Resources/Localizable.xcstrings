        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Stage Manager 환경설정에 액세스할 수 없습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível acessar as preferências de Stage Manager."
          }
        },
        "ru": {

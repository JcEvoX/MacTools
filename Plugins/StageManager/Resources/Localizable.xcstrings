    "error.preferencesUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير قادر على الوصول إلى Stage Manager التفضيلات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf Stage Manager-Einstellungen nicht möglich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to access Stage Manager preferences."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede acceder a Stage Manager preferencias."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'accéder aux préférences Stage Manager."
          }
        },
        "ja": {

    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إفراغ كافة العناصر الموجودة في سلة المهملات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leeren Sie alle Elemente im Papierkorb."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Empty all items in the Trash."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaciar todos los elementos de la Papelera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Videz tous les éléments de la corbeille."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゴミ箱内のすべてのアイテムを空にします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "휴지통의 모든 항목을 비웁니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Esvazie todos os itens da Lixeira."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистить все элементы в корзине."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清空废纸篓中的所有项目"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "清空垃圾桶中的所有項目"
          }
        }
      }
    },

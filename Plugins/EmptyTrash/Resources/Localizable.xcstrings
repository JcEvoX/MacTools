    "error.emptyFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل في إفراغ سلة المهملات. تحقق من إذن الأتمتة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Papierkorb konnte nicht geleert werden. Überprüfen Sie die Automatisierungsberechtigung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to empty Trash. Check Automation permission."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo vaciar la Papelera. Verifique el permiso de automatización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la suppression de la corbeille. Vérifiez l'autorisation d'automatisation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゴミ箱を空にできませんでした。自動化の許可を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "휴지통을 비우지 못했습니다. 자동화 권한을 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao esvaziar a Lixeira. Verifique a permissão de automação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось очистить корзину. Проверьте разрешение автоматизации."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清空废纸篓失败，请检查“自动操作”权限"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "清空垃圾桶失敗，請檢查“自動操作”權限"
          }
        }
      }

    "metadata.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "امسح محتويات الحافظة الحالية بنقرة واحدة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löschen Sie den aktuellen Inhalt der Zwischenablage mit einem Klick."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear the current clipboard contents with one click."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra el contenido actual del portapapeles con un solo clic."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Effacez le contenu actuel du presse-papiers en un seul clic."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワンクリックで現在のクリップボードの内容をクリアします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 번의 클릭으로 현재 클립보드 내용을 지웁니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpe o conteúdo atual da área de transferência com um clique."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистите текущее содержимое буфера обмена одним щелчком мыши."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一键清空当前剪贴板内容"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一鍵清空當前剪貼板內容"
          }
        }
      }
